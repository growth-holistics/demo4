      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        metric_value {
          font_size: 30
        }
      }
    }
  }
  block t2_kpi_labour_pct: VizBlock {
    label: 'Labour % of Sales'
    viz: MetricKpi {
      dataset: marlin_hospitality_mart
      value: VizFieldFull {
        label: ' '
        ref: r(marlin_hospitality_mart.labour_pct_of_sales)
        format {
          type: 'number'
          pattern: 'inherited'
