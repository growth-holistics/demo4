      content: @md <style>
  .cmp {
    display: flex;
    gap: 16px;
    padding: 18px 16px 8px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Montserrat", sans-serif;
  }
  .cmp .panel {
    flex: 1;
    padding: 18px 22px 16px;
    border-radius: 14px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    box-sizing: border-box;
  }
  .cmp .panel.m { background: #eff6ff; border-color: #bfdbfe; }
  .cmp .panel.n { background: #f5f3ff; border-color: #ddd6fe; }
  .cmp .badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    margin-bottom: 14px;
  }
  .cmp .panel.m .badge { background: #1d4ed8; color: #fff; }
  .cmp .panel.n .badge { background: #7c3aed; color: #fff; }

  .cmp .kpis {
    display: flex;
    gap: 24px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(0,0,0,0.07);
    margin-bottom: 14px;
  }
  .cmp .kpi { display: flex; flex-direction: column; }
  .cmp .kpi-lbl {
    font-size: 9px;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .cmp .kpi-val {
    font-size: 20px;
    font-weight: 700;
    color: #0f172a;
    line-height: 1;
  }

  .cmp .cat-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin: 10px 0 4px;
    font-size: 12px;
  }
  .cmp .cat-head .cat-lbl {
    color: #64748b;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 10px;
  }
  .cmp .cat-head .cat-val {
    color: #0f172a;
    font-weight: 700;
    font-size: 14px;
  }
  .cmp .cat-bar {
    height: 6px;
    background: rgba(0,0,0,0.06);
    border-radius: 3px;
    overflow: hidden;
  }
  .cmp .cat-fill {
    height: 100%;
    border-radius: 3px;
    width: calc(var(--v, 0) / 60000 * 100%);
    max-width: 100%;
  }
  .cmp .panel.m .cat-fill { background: #2563eb; }
  .cmp .panel.n .cat-fill { background: #8b5cf6; }

  .cmp-note {
    padding: 0 18px 12px;
    color: #94a3b8;
    font-size: 11px;
    font-style: italic;
  }
</style>

<div class="cmp">
{% map(rows) %}
{% map(values) %}
<div class="panel m">
<div class="badge">Members</div>
<div class="kpis">
<div class="kpi"><span class="kpi-lbl">Revenue</span><span class="kpi-val">{{ value.`Member Revenue (est)` }}</span></div>
<div class="kpi"><span class="kpi-lbl">Transactions</span><span class="kpi-val">{{ value.`Member Transactions (est)` }}</span></div>
<div class="kpi"><span class="kpi-lbl">Avg Txn</span><span class="kpi-val">{{ value.`Member Avg Txn (est)` }}</span></div>
</div>
<div class="cat-head"><span class="cat-lbl">Food</span><span class="cat-val">{{ value.`Member Food (est)` }}</span></div>
<div class="cat-bar"><div class="cat-fill" style="--v: {{ value.`Member Food (est)`.raw }};"></div></div>
<div class="cat-head"><span class="cat-lbl">Beverage</span><span class="cat-val">{{ value.`Member Beverage (est)` }}</span></div>
<div class="cat-bar"><div class="cat-fill" style="--v: {{ value.`Member Beverage (est)`.raw }};"></div></div>
<div class="cat-head"><span class="cat-lbl">Other</span><span class="cat-val">{{ value.`Member Other (est)` }}</span></div>
<div class="cat-bar"><div class="cat-fill" style="--v: {{ value.`Member Other (est)`.raw }};"></div></div>
</div>
<div class="panel n">
<div class="badge">Non-Members</div>
<div class="kpis">
<div class="kpi"><span class="kpi-lbl">Revenue</span><span class="kpi-val">{{ value.`Non-Member Revenue` }}</span></div>
<div class="kpi"><span class="kpi-lbl">Transactions</span><span class="kpi-val">{{ value.`Non-Member Transactions (est)` }}</span></div>
<div class="kpi"><span class="kpi-lbl">Avg Txn</span><span class="kpi-val">{{ value.`Non-Member Avg Txn (est)` }}</span></div>
</div>
<div class="cat-head"><span class="cat-lbl">Food</span><span class="cat-val">{{ value.`Non-Member Food (est)` }}</span></div>
<div class="cat-bar"><div class="cat-fill" style="--v: {{ value.`Non-Member Food (est)`.raw }};"></div></div>
<div class="cat-head"><span class="cat-lbl">Beverage</span><span class="cat-val">{{ value.`Non-Member Beverage (est)` }}</span></div>
<div class="cat-bar"><div class="cat-fill" style="--v: {{ value.`Non-Member Beverage (est)`.raw }};"></div></div>
<div class="cat-head"><span class="cat-lbl">Other</span><span class="cat-val">{{ value.`Non-Member Other (est)` }}</span></div>
<div class="cat-bar"><div class="cat-fill" style="--v: {{ value.`Non-Member Other (est)`.raw }};"></div></div>
</div>
{% end %}
{% end %}
</div>
<div class="cmp-note">Member / non-member split is estimated via transaction-share ratio. Category mix is assumed uniform across segments until per-member category data is available in production.</div>
;;
    }
  }

  block t3_chart_visit_dist: VizBlock {
    label: 'Member Visit Distribution'
    viz: ColumnChart {
      dataset: marlin_hospitality_mart
      x_axis: VizFieldFull {
        ref: ref('marlin_dim_member', 'visit_count_bucket')
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: 'distinct_members'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
    }
  }
  block t3_chart_points: VizBlock {
    label: 'Points Earned & Redeemed by Venue'
    viz: ColumnChart {
      dataset: marlin_hospitality_mart
      x_axis: VizFieldFull {
        ref: ref('marlin_dim_venue', 'venue_name')
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: 'waterfall_points_earned'
            format {
              type: 'number'
