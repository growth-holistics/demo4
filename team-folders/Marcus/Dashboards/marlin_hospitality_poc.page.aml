  }
  block t3_waterfall: VizBlock {
    label: 'Monthly Member Waterfall'
    viz: MarkdownViz {
      dataset: marlin_hospitality_mart
      rows: [
        VizFieldFull {
          ref: r(marlin_waterfall_unpivot.label)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(marlin_waterfall_unpivot.bar_class)
          format {
            type: 'text'
          }
        }
      ]
      columns: [
        VizFieldFull {
          ref: r(marlin_waterfall_unpivot.value_label)
          format {
            type: 'text'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(marlin_waterfall_unpivot.amount)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(marlin_waterfall_unpivot.bar_min)
          format {
            type: 'number'
          }
        },
        VizFieldFull {
          ref: r(marlin_waterfall_unpivot.bar_max)
          format {
            type: 'number'
          }
        }
      ]
      content: @md <style>
  .wf {
    display: flex;
    align-items: stretch;
    gap: 8px;
    padding: 28px 16px 48px;
    height: 400px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Montserrat", sans-serif;
    position: relative;
    --top: 200000;
  }
  .wf .col {
    flex: 1;
    min-width: 110px;
    position: relative;
    height: 100%;
  }
  .wf .bar {
    position: absolute;
    left: 10px;
    right: 10px;
    bottom: calc(var(--min, 0) / var(--top, 1) * 100%);
    height: calc((var(--max-y, 0) - var(--min, 0)) / var(--top, 1) * 100%);
    min-height: 3px;
    border-radius: 6px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
  }
  .wf .col .val {
    position: absolute;
    left: 0;
    right: 0;
    bottom: calc(var(--max-y, 0) / var(--top, 1) * 100% + 4px);
    text-align: center;
    font-size: 14px;
    font-weight: 700;
    color: #1e293b;
    line-height: 1;
  }
  .wf .col .axis-lbl {
    position: absolute;
    bottom: -32px;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    font-weight: 600;
    color: #475569;
  }
  .wf .bar.total { background: #fef3c7; border: 1px solid #fde68a; }
  .wf .bar.add { background: #d1fae5; border: 1px solid #a7f3d0; }
  .wf .bar.sub { background: #fee2e2; border: 1px solid #fecaca; }
  .wf .col.total .val { color: #78350f; }
  .wf .col.add .val { color: #065f46; }
  .wf .col.sub .val { color: #991b1b; }
</style>

<div class="wf">
{% map(rows) %}
{% map(values) %}
<div class="col {{ `Bar Class`.raw }}" style="--min: {{ value.`Bar Min`.raw }}; --max-y: {{ value.`Bar Max`.raw }};">
<div class="bar {{ `Bar Class`.raw }}"></div>
<div class="val">{{ value.`Amount` }}</div>
<div class="axis-lbl">{{ `Label` }}</div>
</div>
{% end %}
{% end %}
</div>
;;
    }
  }
