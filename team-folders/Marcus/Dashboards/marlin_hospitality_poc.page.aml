  block t2_chart_daily: VizBlock {
    label: 'Daily Net Sales'
    viz: LineChart {
      dataset: marlin_hospitality_mart
      x_axis: VizFieldFull {
        ref: ref('marlin_rpt_daily_venue_sales', 'shift_date')
        transformation: 'datetrunc day'
        format {
          type: 'date'
          pattern: 'LLL dd'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: 'total_net_sales'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
        series {
          field: VizFieldFull {
            ref: 'gross_profit'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
        series {
          field: VizFieldFull {
            ref: 'total_labour_cost'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
    }
  }
  block t2_chart_split: VizBlock {
    label: 'Sales by Category'
    viz: ColumnChart {
      dataset: marlin_hospitality_mart
      x_axis: VizFieldFull {
        ref: ref('marlin_rpt_daily_venue_sales', 'shift_date')
        transformation: 'datetrunc day'
        format {
          type: 'date'
          pattern: 'LLL dd'
        }
      }
      y_axis {
        settings {
          stack_series_by: 'value'
          show_stack_total: true
        }
        series {
          field: VizFieldFull {
            ref: 'food_sales'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
        series {
          field: VizFieldFull {
            ref: 'beverage_sales'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
        series {
          field: VizFieldFull {
            ref: 'other_sales'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
    }
  }
  block t2_table_daily: VizBlock {
    label: 'Daily Performance Detail'
    viz: DataTable {
      dataset: marlin_hospitality_mart
      fields: [
        VizFieldFull {
          ref: r(marlin_rpt_daily_venue_sales.shift_date)
          format {
            type: 'date'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(marlin_hospitality_mart.total_net_sales)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(marlin_hospitality_mart.food_sales)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(marlin_hospitality_mart.beverage_sales)
          format {
            type: 'number'
            pattern: 'inherited'
