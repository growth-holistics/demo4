  block t1_kpi_points_net: VizBlock {
    label: 'Points Earned − Redeemed'
    viz: MetricKpi {
      dataset: marlin_hospitality_mart
      value: VizFieldFull {
        label: 'Net Points'
        ref: r(marlin_hospitality_mart.points_earned_daily)
