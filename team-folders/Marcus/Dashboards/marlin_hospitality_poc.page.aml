            }
          }
        }
        series {
          field: VizFieldFull {
            ref: 'waterfall_points_redeemed'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
    }
  }
  block t4_header: TextBlock {
    content: @md # Promotional Product Usage
**Data gap — placeholder.** The current data mart does not include a promotions dimension, promotional-price flag, or transaction-line grain.

**To enable this dashboard the warehouse needs:**
- `dim_promotion` table (id, name, start/end, type)
- `is_promo_priced` flag on `fact_daily_sales` (or finer-grained `fact_transaction_lines`)
- Basket-level (transaction) grain for basket-size analyses

Once those are wired in, this tab will cover: full-price vs promo splits, time-of-day comparisons, basket size, and per-basket purchase distribution.;;
  }
  block t5_header: TextBlock {
    content: @md # Ad Hoc Analysis
Open exploration using the full-grain fact tables. Filter by date, venue, and category to drill into product, member, and category-mix questions.;;
  }
  block t5_filter_date: FilterBlock {
    label: 'Date'
    type: 'field'
    source: FieldFilterSource {
      dataset: marlin_hospitality_mart
      field: r(marlin_fact_daily_sales.shift_date)
    }
    default {
      operator: 'matches'
      value: '2026'
    }
  }
  block t5_filter_venue: FilterBlock {
    label: 'Venue'
    type: 'field'
    source: FieldFilterSource {
      dataset: marlin_hospitality_mart
      field: r(marlin_dim_venue.venue_name)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
  }
  block t5_filter_category: FilterBlock {
    label: 'Category L1'
    type: 'field'
    source: FieldFilterSource {
      dataset: marlin_hospitality_mart
      field: r(marlin_dim_item.category_l1)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
  }
  block t5_table_top_products: VizBlock {
    label: 'Top Products by Revenue'
    viz: DataTable {
      dataset: marlin_hospitality_mart
      fields: [
        VizFieldFull {
          ref: ref('marlin_dim_item', 'product_name')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('marlin_dim_item', 'category_l1')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('marlin_dim_item', 'category_l2')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'units_sold'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: 'product_revenue'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: 'product_cogs'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: 'product_gp'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
      ]
      settings {
        row_limit: 50
      }
    }
  }
  block t5_chart_category_mix: VizBlock {
    label: 'Category Mix Over Time'
    viz: ColumnChart {
      dataset: marlin_hospitality_mart
      x_axis: VizFieldFull {
        ref: ref('marlin_fact_daily_sales', 'shift_date')
        transformation: 'datetrunc week'
        format {
          type: 'date'
          pattern: 'LLL dd'
        }
      }
      legend: VizFieldFull {
        ref: ref('marlin_dim_item', 'category_l1')
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          stack_series_by: 'value'
          show_stack_total: true
        }
        series {
          field: VizFieldFull {
            ref: 'product_revenue'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
    }
  }
  block t5_chart_venue_compare: VizBlock {
    label: 'Multi-Venue Comparison'
    viz: ColumnChart {
      dataset: marlin_hospitality_mart
      x_axis: VizFieldFull {
        ref: ref('marlin_dim_venue', 'venue_name')
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: 'total_net_sales'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
        series {
          field: VizFieldFull {
            ref: 'gross_profit'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
        series {
          field: VizFieldFull {
            ref: 'gpal'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
    }
  }
  block t5_table_member: VizBlock {
    label: 'Member RFM-lite'
    viz: DataTable {
      dataset: marlin_hospitality_mart
      fields: [
        VizFieldFull {
          ref: ref('marlin_dim_member', 'member_id')
          format {
            type: 'number'
            pattern: 'inherited'
          }
