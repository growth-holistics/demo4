    tab promo_product: CanvasLayout {
      label: 'Promotional Product'
      height: 600
      width: 1300
      grid_size: 20
      auto_expand_vertically: true

      block t4_header {
        position: pos(20, 20, 1240, 400)
      }
    }

    tab ad_hoc: CanvasLayout {
      label: 'Ad Hoc Analysis'
      height: 1480
      width: 1300
      grid_size: 20
      auto_expand_vertically: true

      block t5_header {
        position: pos(20, 20, 1240, 60)
      }
      block t5_filter_date {
        position: pos(20, 100, 400, 60)
      }
      block t5_filter_venue {
        position: pos(440, 100, 400, 60)
      }
      block t5_filter_category {
        position: pos(860, 100, 400, 60)
      }

      // KPI row
      block t5_kpi_distinct_members {
