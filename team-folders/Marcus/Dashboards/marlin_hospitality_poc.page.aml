            pattern: 'inherited'
          }
        },
      ]
      settings {
        row_limit: 100
      }
    }
  }
  block t5_kpi_distinct_members: VizBlock {
    label: 'Distinct Members'
    viz: MetricKpi {
      dataset: marlin_hospitality_mart
      value: VizFieldFull {
        label: ' '
        ref: r(marlin_hospitality_mart.distinct_members)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        metric_value {
          font_size: 30
        }
      }
    }
  }
  block t5_kpi_avg_spend: VizBlock {
