      }
      block t5_kpi_avg_spend {
        position: pos(440, 180, 400, 120)
      }
      block t5_kpi_avg_visits {
        position: pos(860, 180, 400, 120)
      }

      // Multi-venue comparison + category mix
      block t5_chart_venue_compare {
        position: pos(20, 320, 620, 340)
      }
      block t5_chart_category_mix {
        position: pos(660, 320, 600, 340)
      }

      // Top products table
      block t5_table_top_products {
        position: pos(20, 680, 1240, 380)
      }

      // Member RFM
      block t5_table_member {
        position: pos(20, 1080, 1240, 380)
      }
    }
  }
