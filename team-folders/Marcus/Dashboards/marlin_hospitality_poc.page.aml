          font_size: 30
        }
      }
    }
  }
  block t1_kpi_labour_pct_group: VizBlock {
    label: 'Total Labour %'
    viz: MetricKpi {
      dataset: marlin_hospitality_mart
      value: VizFieldFull {
        label: ' '
        ref: r(marlin_hospitality_mart.labour_pct_of_sales_group)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        metric_value {
          font_size: 30
        }
      }
    }
  }
  block t1_kpi_rev_per_hr_group: VizBlock {
    label: 'Total Revenue / Labour Hr'
    viz: MetricKpi {
      dataset: marlin_hospitality_mart
      value: VizFieldFull {
        label: ' '
        ref: r(marlin_hospitality_mart.revenue_per_labour_hour_group)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        metric_value {
          font_size: 30
        }
      }
    }
  }
  block t1_chart_sales_split: VizBlock {
    label: 'Sales Mix (Food / Beverage / Other)'
    viz: PieChart {
      dataset: marlin_hospitality_mart
      legend: VizFieldFull {
        ref: ref('marlin_ref_item_classification', 'revenue_category')
        format {
          type: 'text'
        }
      }
      series {
        field: VizFieldFull {
          ref: 'product_revenue'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      }
    }
  }
  block t1_chart_daily_sales: VizBlock {
    label: 'Daily Net Sales by Venue'
    viz: LineChart {
      dataset: marlin_hospitality_mart
      x_axis: VizFieldFull {
        ref: r(marlin_rpt_daily_venue_sales.shift_date)
        transformation: 'datetrunc day'
        format {
          type: 'date'
          pattern: 'LLL dd'
        }
      }
      legend: VizFieldFull {
        ref: r(marlin_dim_venue.venue_name)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            label: ' '
            ref: r(marlin_hospitality_mart.total_net_sales)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
      settings {
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block t1_chart_labour_hours: VizBlock {
    label: 'Labour Hours by Category × Venue'
    viz: ColumnChart {
      dataset: marlin_hospitality_mart
      x_axis: VizFieldFull {
        ref: ref('marlin_dim_venue', 'venue_name')
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          stack_series_by: 'value'
          show_stack_total: true
        }
        series {
          field: VizFieldFull {
            ref: 'management_hours'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
        series {
          field: VizFieldFull {
            ref: 'foh_hours'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
        series {
          field: VizFieldFull {
            ref: 'kitchen_hours'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
        series {
          field: VizFieldFull {
            ref: 'other_hours'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
    }
  }
  block t1_table_top_food: VizBlock {
    label: 'Top 20 Food Products'
    viz: DataTable {
      dataset: marlin_hospitality_mart
      filter {
        field: ref('marlin_ref_item_classification', 'is_food')
        operator: 'is'
        value: '1'
      }
      fields: [
        VizFieldFull {
          ref: ref('marlin_dim_item', 'product_name')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('marlin_dim_item', 'category_l2')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'product_revenue'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: 'units_sold'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: 'product_gp'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
      ]
      settings {
        row_limit: 20
      }
    }
  }
  block t1_table_top_bev: VizBlock {
    label: 'Top 20 Beverage Products'
    viz: DataTable {
      dataset: marlin_hospitality_mart
      filter {
        field: ref('marlin_ref_item_classification', 'is_beverage')
        operator: 'is'
        value: '1'
      }
      fields: [
        VizFieldFull {
          ref: ref('marlin_dim_item', 'product_name')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('marlin_dim_item', 'category_l2')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'product_revenue'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: 'units_sold'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: 'product_gp'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
      ]
      settings {
        row_limit: 20
      }
    }
  }
  block t1_kpi_members: VizBlock {
    label: 'Transacting Members'
    viz: MetricKpi {
      dataset: marlin_hospitality_mart
      value: VizFieldFull {
