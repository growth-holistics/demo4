  // ═══════════════════════════════════════════════════════════════════════════
  // VIEW — TabLayout with 5 tabs
  // ═══════════════════════════════════════════════════════════════════════════

  view: TabLayout {
    label: 'POC'

    tab group_weekly: CanvasLayout {
      label: 'Group Weekly Performance'
      height: 2280
      width: 1300
      grid_size: 20
      auto_expand_vertically: true
      block t1_header {
        position: pos(20, 20, 1240, 80)
      }
      block t1_filter_date {
        position: pos(20, 100, 400, 60)
      }
      block t1_filter_venue {
        position: pos(440, 100, 400, 60)
      }
      block t1_kpi_sales {
        position: pos(20, 180, 240, 140)
      }
