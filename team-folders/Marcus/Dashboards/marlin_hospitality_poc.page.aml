  }
  block t1_chart_member_spend: VizBlock {
    label: 'Member Spend by Venue'
    viz: BarChart {
      dataset: marlin_hospitality_mart
      x_axis: VizFieldFull {
        ref: r(marlin_dim_venue.venue_name)
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          show_stack_total: true
          stack_series_by: 'value'
        }
        series {
          field: VizFieldFull {
            ref: r(marlin_hospitality_mart.member_gross_revenue)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
        series {
          field: VizFieldFull {
            ref: r(marlin_hospitality_mart.non_member_revenue)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
      settings {
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block t2_header: TextBlock {
    content: @md # Venue Manager Dashboard
Same metrics as the group view, scoped to a single venue selected below. _(RLS will be wired in production; for the POC use the venue dropdown.)_;;
  }
  block t2_filter_venue: FilterBlock {
    label: 'Venue'
    type: 'field'
    source: FieldFilterSource {
      dataset: marlin_hospitality_mart
      field: ref('marlin_dim_venue', 'venue_name')
    }
    settings {
      input_type: 'single'
    }
  }
  block t2_filter_date: FilterBlock {
    label: 'Date'
    type: 'field'
    source: FieldFilterSource {
      dataset: marlin_hospitality_mart
      field: r(marlin_rpt_daily_venue_sales.shift_date)
    }
    default {
      operator: 'matches'
      value: '2026'
    }
  }
  block t2_kpi_sales: VizBlock {
    label: 'Net Sales (Venue)'
    viz: MetricKpi {
      dataset: marlin_hospitality_mart
      value: VizFieldFull {
        label: ' '
        ref: r(marlin_hospitality_mart.total_net_sales)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizPopSettings {
        field: r(marlin_rpt_daily_venue_sales.shift_date)
        value: RelativePopValue {
          duration: 1
          granularity: 'week'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        metric_value {
          font_size: 30
        }
      }
    }
  }
  block t2_kpi_gp: VizBlock {
    label: 'Gross Profit'
    viz: MetricKpi {
      dataset: marlin_hospitality_mart
      value: VizFieldFull {
        label: ' '
