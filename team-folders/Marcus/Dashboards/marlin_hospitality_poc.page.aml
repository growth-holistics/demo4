        position: pos(20, 1040, 1240, 340)
      }

      // Top 20 Food / Beverage
      block t1_table_top_food {
        position: pos(20, 1400, 620, 420)
      }
      block t1_table_top_bev {
        position: pos(660, 1400, 600, 420)
      }

      // Loyalty section
      block t1_kpi_members {
        position: pos(20, 1840, 240, 100)
      }
      block t1_kpi_new_members {
        position: pos(280, 1840, 240, 100)
      }
      block t1_kpi_member_share {
        position: pos(540, 1840, 240, 100)
      }
      block t1_kpi_points_net {
        position: pos(800, 1840, 240, 100)
      }
      block t1_chart_member_spend {
        position: pos(20, 1960, 1240, 300)
      }
    }

    tab venue_manager: CanvasLayout {
      label: 'Venue Manager'
      height: 1480
      width: 1300
      grid_size: 20
      auto_expand_vertically: true
      block t2_header {
        position: pos(20, 20, 1240, 80)
      }
      block t2_filter_venue {
        position: pos(20, 100, 400, 60)
      }
      block t2_filter_date {
        position: pos(440, 100, 400, 60)
      }

      // KPI row
      block t2_kpi_sales {
        position: pos(20, 180, 240, 120)
      }
      block t2_kpi_gp {
        position: pos(280, 180, 240, 120)
      }
      block t2_kpi_labour_cost {
        position: pos(540, 180, 240, 120)
      }
      block t2_kpi_gpal {
        position: pos(800, 180, 240, 120)
      }
      block t2_kpi_labour_pct {
        position: pos(1060, 180, 200, 120)
      }

      // Charts
      block t2_chart_daily {
        position: pos(20, 320, 620, 340)
      }
      block t2_chart_split {
        position: pos(660, 320, 600, 340)
      }

      // Daily detail
      block t2_table_daily {
        position: pos(20, 680, 1240, 380)
      }

      // Staff hours
      block t2_table_staff {
        position: pos(20, 1080, 1240, 380)
      }
    }

    tab loyalty_waterfall: CanvasLayout {
      label: 'Loyalty Waterfall'
      height: 1860
      width: 1300
      grid_size: 20
      auto_expand_vertically: true
      block t3_header {
        position: pos(20, 20, 1240, 80)
      }
      block t3_filter_month {
        position: pos(20, 120, 400, 60)
      }
      block t3_kpi_closing {
        position: pos(20, 200, 240, 140)
      }
      block t3_kpi_new {
        position: pos(280, 200, 240, 140)
      }
      block t3_kpi_reactivated {
        position: pos(540, 200, 240, 140)
      }
      block t3_kpi_lapsed {
        position: pos(800, 200, 240, 120)
      }
      block t3_waterfall {
        position: pos(20, 340, 800, 380)
      }
      block t3_chart_closing_trend {
        position: pos(840, 340, 420, 380)
      }

      // Member movement by venue + per-venue table
      block t3_chart_movement_by_venue {
        position: pos(20, 740, 620, 360)
      }
      block t3_table_venue {
        position: pos(660, 740, 600, 360)
      }

      // Member vs non-member + visit distribution
      block t3_chart_member_vs_non {
        position: pos(20, 1120, 620, 360)
      }
      block t3_chart_visit_dist {
        position: pos(660, 1120, 600, 360)
      }

      // Points
      block t3_chart_points {
