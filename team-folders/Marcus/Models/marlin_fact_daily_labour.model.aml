    definition: @sql {{ #SOURCE.timesheet_cost }} ;;
  }
  dimension roster_cost {
    label: 'Roster Cost'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.roster_cost }} ;;
  }
  dimension time_variance_hours {
    label: 'Time Variance Hours'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.time_variance_hours }} ;;
  }
  dimension cost_variance {
