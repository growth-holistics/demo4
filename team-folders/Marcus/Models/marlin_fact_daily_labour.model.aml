  }
  dimension total_gross_plus_super {
    label: 'Total Gross Plus Super'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.total_gross_plus_super }} ;;
  }
  dimension pay_run_period_start {
    label: 'Pay Run Period Start'
    type: 'date'
    hidden: false
    definition: @sql {{ #SOURCE.pay_run_period_start }}::date ;;
  }
  dimension pay_run_period_end {
    label: 'Pay Run Period End'
