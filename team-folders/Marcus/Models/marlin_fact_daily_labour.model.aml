    hidden: false
    definition: @sql {{ #SOURCE.pay_component_name }} ;;
  }
  dimension cost_category {
    label: 'Cost Category'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.cost_category }} ;;
  }
  dimension cost_type {
    label: 'Cost Type'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.cost_type }} ;;
  }
  dimension location_type {
    label: 'Location Type'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.location_type }} ;;
  }
  dimension labour_source {
