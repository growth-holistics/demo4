Model marlin_fact_daily_labour {
  type: 'table'
  label: 'Daily Labour (Fact)'
  data_source_name: 'demo_marlin_mangrove_sample'

  dimension surrogate_key {
    label: 'Surrogate Key'
    type: 'number'
    hidden: false
    primary_key: true
    definition: @sql {{ #SOURCE.surrogate_key }} ;;
  }
  dimension shift_date {
    label: 'Shift Date'
    type: 'date'
    hidden: false
    definition: @sql {{ #SOURCE.shift_date }}::date ;;
  }
  dimension venue_id {
    label: 'Venue Id'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.venue_id }} ;;
  }
  dimension staff_id {
    label: 'Staff Id'
