Dataset hotel_analytics {
  label: 'Hotel Analytics Dataset'
  description: ''
  data_source_name: if (H.current_user.data_source) {
    H.current_user.data_source
  } else {
    'customer_staging'
  }

  models: [
    public_hotel
  ]

  relationships: []

  metric hotel_revenue {
    label: "Hotel Revenue"
    type: "number"
    description: ""
    definition: @aql sum(public_hotel.hotel_revenue);;
    format: ""
  }
}