Dashboard testing_claude {
  title: 'Testing Claude'

  block v1: VizBlock {
    label: 'Total Users by Age Demographic'
    viz: ColumnChart {
      dataset: demo_ecommerce_version_2
      x_axis: VizFieldFull {
        ref: r(ecommerce_users.age_group)
        label: 'Age Demographic'
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(demo_ecommerce_version_2.total_users)
            label: 'Total Users'
            format {
              type: 'number'
              pattern: '#,###0'
            }
          }
          settings {
            color: '#4F46E5'
          }
        }
      }
      settings {
        row_limit: 100
        sort: LineFamilySort {
          type: 'xaxis'
          direction: 'asc'
        }
      }
    }
  }

  block v2: VizBlock {
    label: 'Total Orders by Country'
    viz: BarChart {
      dataset: demo_ecommerce_version_2
      x_axis: VizFieldFull {
        ref: r(ecommerce_countries.name)
        label: 'Country Name'
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(demo_ecommerce_version_2.total_orders)
            label: 'Total Orders'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#4F46E5'
          }
        }
      }
      settings {
        row_limit: 100
        sort: LineFamilySort {
          type: 'xaxis'
          direction: 'asc'
        }
      }
    }
  }

  view: CanvasLayout {
    label: 'View 1'
    width: 1300
    height: 900
    grid_size: 20
    auto_expand_vertically: true
    block v1 {
      position: pos(20, 20, 620, 400)
    }
    block v2 {
      position: pos(660, 20, 620, 400)
    }
  }
}
