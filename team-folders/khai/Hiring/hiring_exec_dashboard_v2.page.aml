Dashboard hiring_exec_dashboard_v2 {
  title: 'Hiring Executive Dashboard'
  description: '''
Executive hiring dashboard built on @Dataset:hiring_analytics.

Reading flow:
- Top: filters and context
- Middle: hiring output and speed
- Bottom: source effectiveness and stage bottlenecks
'''

  theme: PageTheme {
    canvas {
      background {
        bg_color: '#EEF3F8'
      }
      border {
        border_color: '#D7E3F0'
      }
    }
    block {
      background {
        bg_color: '#FFFFFF'
      }
      border {
        border_color: '#D7E3F0'
      }
      label {
        font_color: '#0F172A'
      }
      text {
        font_color: '#334155'
      }
    }
    custom_css: @css
      body {
        background:
          radial-gradient(circle at top left, rgba(37, 99, 235, 0.12), transparent 28%),
          radial-gradient(circle at top right, rgba(15, 23, 42, 0.10), transparent 24%),
          linear-gradient(180deg, #F8FBFF 0%, #F4F7FB 100%);
      }

      .dac-canvas {
        background: transparent;
      }

      .dac-viz-block,
      .dac-ic-block,
      .dac-text-block {
        border-radius: 22px;
        border: 1px solid rgba(215, 227, 240, 0.95);
        box-shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
        overflow: hidden;
        backdrop-filter: blur(8px);
      }

      .dac-viz-block {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(248, 251, 255, 0.98) 100%);
      }

      .dac-ic-block {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(250, 252, 255, 0.98) 100%);
      }

      .dac-viz-block-label,
      .dac-ic-block-label {
        color: #0F172A;
        font-weight: 800;
        letter-spacing: 0.01em;
      }

      .dac-viz-block-label {
        padding-bottom: 8px;
      }

      .dac-viz-block .text-secondary,
      .dac-viz-block .text-gray-500,
      .dac-viz-block .text-blue-gray-60 {
        color: #64748B !important;
      }

      .dac-text-block {
        background:
          radial-gradient(circle at top right, rgba(255, 255, 255, 0.16), transparent 24%),
          linear-gradient(135deg, #0F172A 0%, #1D4ED8 55%, #2563EB 100%);
        color: #FFFFFF;
        box-shadow: 0 28px 70px rgba(29, 78, 216, 0.24);
      }

      .dac-text-block h1,
      .dac-text-block p,
      .dac-text-block li,
      .dac-text-block strong {
        color: #FFFFFF;
      }

      .dac-text-block h1 {
        font-size: 34px;
        line-height: 1.1;
        margin-bottom: 18px;
      }

      .dac-text-block strong {
        opacity: 0.96;
      }

      .dac-ic-block-label {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #334155;
      }

      .dac-viz-block:hover,
      .dac-ic-block:hover {
        box-shadow: 0 24px 70px rgba(15, 23, 42, 0.10);
        transform: translateY(-1px);
        transition: all 180ms ease;
      }
    ;;
  }
  block t1: TextBlock {
    content: @md
<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:28px;">
  <div style="max-width:820px;">
    <div style="display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border-radius:999px;background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.16);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;opacity:0.88;margin-bottom:16px;">
      <span style="display:inline-block;width:8px;height:8px;border-radius:999px;background:#93C5FD;"></span>
      Talent Intelligence
    </div>
    <h1 style="margin:0 0 14px 0;">Hiring Executive Dashboard</h1>
    <div style="font-size:17px;line-height:1.65;max-width:760px;opacity:0.94;">
      Premium executive view of hiring output, funnel speed, source efficiency, and stage bottlenecks.
    </div>
  </div>
  <div style="min-width:300px;max-width:320px;background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.16);border-radius:20px;padding:18px 20px;backdrop-filter:blur(8px);box-shadow:inset 0 1px 0 rgba(255,255,255,0.08);">
    <div style="font-size:12px;letter-spacing:0.10em;text-transform:uppercase;opacity:0.78;margin-bottom:10px;">Executive focus</div>
    <div style="line-height:1.9;opacity:0.96;">
      • Hiring output<br/>
      • Funnel speed<br/>
      • Source efficiency<br/>
      • Stage bottlenecks
    </div>
  </div>
</div>

<div style="margin-top:24px;display:grid;grid-template-columns:repeat(4, minmax(0, 1fr));gap:14px;">
  <div style="background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.14);border-radius:18px;padding:16px 18px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.06);">
    <div style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;opacity:0.72;">Read 1</div>
    <div style="margin-top:8px;font-size:14px;line-height:1.55;">Start with the monthly trend</div>
  </div>
  <div style="background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.14);border-radius:18px;padding:16px 18px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.06);">
    <div style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;opacity:0.72;">Read 2</div>
    <div style="margin-top:8px;font-size:14px;line-height:1.55;">Check where candidates accumulate</div>
  </div>
  <div style="background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.14);border-radius:18px;padding:16px 18px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.06);">
    <div style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;opacity:0.72;">Read 3</div>
    <div style="margin-top:8px;font-size:14px;line-height:1.55;">Compare source quality vs speed</div>
  </div>
  <div style="background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.14);border-radius:18px;padding:16px 18px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.06);">
    <div style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;opacity:0.72;">Read 4</div>
    <div style="margin-top:8px;font-size:14px;line-height:1.55;">Use bottlenecks to prioritize fixes</div>
  </div>
</div>
    ;;
    theme: BlockTheme {
      border {
        border_color: 'transparent'
      }
      background {
        bg_color: 'transparent'
      }
    }
  }

  block f_date: FilterBlock {
    label: 'Hiring Date'
    type: 'field'
    source: FieldFilterSource {
      dataset: hiring_analytics
      field: r(dim_date_job.date_key)
    }
    default {
      operator: 'matches'
      value: 'last 12 months'
    }
    theme: BlockTheme {
      background {
        bg_color: 'transparent'
      }
      border {
        border_color: 'transparent'
      }
      label {
        font_color: '#0F172A'
      }
    }
  }

  block f_department: VizBlock {
    label: 'Department'
    viz: MarkdownViz {
      dataset: hiring_analytics
      rows: [
        VizFieldFull {
          label: 'Department'
          ref: r(dim_jobs.department)
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
  .dept-selector {
    display: flex;
    gap: 0.75rem;
    padding: 0.65rem 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .dept-card {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 1rem;
    background: #FFFFFF;
    border: 1.5px solid #D7E3F0;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.15s ease;
    min-width: 110px;
    text-align: center;
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.05);
  }

  .dept-card:hover {
    border-color: #3B82F6;
    background: #F8FAFC;
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(59, 130, 246, 0.12);
  }

  .dept-card:active {
    border-color: #1D4ED8;
    background: #EFF6FF;
    transform: translateY(0);
  }

  .h-drill-selected.dept-card {
    border-color: #1D4ED8;
    background: #EFF6FF;
    box-shadow: 0 10px 24px rgba(37, 99, 235, 0.16);
  }

  .dept-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: #0F172A;
    line-height: 1.2;
  }

  .h-drill-selected.dept-card > .dept-label {
    color: #1D4ED8;
  }
</style>

<div class="dept-selector">
{% map(rows) %}
  <h-drill row="0" value="{{ Department.raw }}">
    <div class="dept-card">
      <span class="dept-label">{{ Department.formatted }}</span>
    </div>
  </h-drill>
{% end %}
</div>      ;;
      settings {
        show_row_total: true
        show_column_total: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: BlockTheme {
      background {
        bg_color: 'transparent'
      }
      border {
        border_color: 'transparent'
      }
    }
  }

  block f_recruiter: FilterBlock {
    label: 'Recruiter'
    type: 'field'
    source: FieldFilterSource {
      dataset: hiring_analytics
      field: r(dim_jobs.recruiter)
    }
    theme: BlockTheme {
      background {
        bg_color: 'transparent'
      }
      border {
        border_color: 'transparent'
      }
      label {
        font_color: '#0F172A'
      }
    }
  }

  block f_source: FilterBlock {
    label: 'Source'
    type: 'field'
    source: FieldFilterSource {
      dataset: hiring_analytics
      field: r(dim_sources.source_name)
    }
    theme: BlockTheme {
      background {
        bg_color: 'transparent'
      }
      border {
        border_color: 'transparent'
      }
      label {
        font_color: '#0F172A'
      }
    }
  }

  block t2: VizBlock {
    label: 'Executive KPI Row'
    viz: MarkdownViz {
      dataset: hiring_analytics
      filter {
        field: r(dim_date_job.date_key)
        operator: 'matches'
        value: 'last 12 months'
      }
      rows: [
        VizFieldFull {
          ref: r(dim_date_job.date_key)
          transformation: 'datetrunc month'
          format {
            type: 'date'
            pattern: 'LLL yyyy'
          }
        }
      ]
      values: [
        VizFieldFull {
          label: 'Total Hires'
          ref: r(hiring_analytics.total_hires)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          label: 'Avg Days to Hire'
          ref: r(hiring_analytics.avg_days_to_hire)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          label: 'Avg Days to Close'
          ref: r(hiring_analytics.avg_days_to_close)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          label: 'Active Applications'
          ref: r(fct_applications.application_id)
          aggregation: 'count'
          format {
            type: 'number'
            pattern: '#,###'
          }
        }
      ]
      content: @md
<div style="display:grid;grid-template-columns:repeat(4, minmax(0, 1fr));gap:16px;">
  <div style="background:linear-gradient(180deg,#FFFFFF 0%,#F8FBFF 100%);border:1px solid #D7E3F0;border-radius:20px;padding:18px 20px;box-shadow:0 14px 40px rgba(15,23,42,0.06);position:relative;overflow:hidden;">
    <div style="position:absolute;top:0;left:0;width:100%;height:4px;background:linear-gradient(90deg,#2563EB 0%,#60A5FA 100%);"></div>
    <div style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:#64748B;">KPI</div>
    <div style="margin-top:10px;font-size:30px;font-weight:800;color:#0F172A;line-height:1;">{{ col_totals.`Total Hires`.formatted }}</div>
    <div style="margin-top:8px;font-size:14px;color:#334155;">Total Hires</div>
    <div style="margin-top:10px;font-size:12px;color:#2563EB;font-weight:600;">Last 12 months</div>
    <div style="margin-top:10px;"><h-sparkline column="Total Hires" width="100" height="30" class="size-full" type="column"></h-sparkline></div>
  </div>
  <div style="background:linear-gradient(180deg,#FFFFFF 0%,#F8FBFF 100%);border:1px solid #D7E3F0;border-radius:20px;padding:18px 20px;box-shadow:0 14px 40px rgba(15,23,42,0.06);position:relative;overflow:hidden;">
    <div style="position:absolute;top:0;left:0;width:100%;height:4px;background:linear-gradient(90deg,#F59E0B 0%,#FBBF24 100%);"></div>
    <div style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:#64748B;">KPI</div>
    <div style="margin-top:10px;font-size:30px;font-weight:800;color:#0F172A;line-height:1;">{{ col_totals.`Avg Days to Hire`.formatted }}</div>
    <div style="margin-top:8px;font-size:14px;color:#334155;">Avg Days to Hire</div>
    <div style="margin-top:10px;font-size:12px;color:#B45309;font-weight:600;">Hiring speed</div>
    <div style="margin-top:10px;"><h-sparkline column="Avg Days to Hire" width="100" height="30" class="size-full"></h-sparkline></div>
  </div>
  <div style="background:linear-gradient(180deg,#FFFFFF 0%,#F8FBFF 100%);border:1px solid #D7E3F0;border-radius:20px;padding:18px 20px;box-shadow:0 14px 40px rgba(15,23,42,0.06);position:relative;overflow:hidden;">
    <div style="position:absolute;top:0;left:0;width:100%;height:4px;background:linear-gradient(90deg,#10B981 0%,#34D399 100%);"></div>
    <div style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:#64748B;">KPI</div>
    <div style="margin-top:10px;font-size:30px;font-weight:800;color:#0F172A;line-height:1;">{{ col_totals.`Avg Days to Close`.formatted }}</div>
    <div style="margin-top:8px;font-size:14px;color:#334155;">Avg Days to Close</div>
    <div style="margin-top:10px;font-size:12px;color:#047857;font-weight:600;">Decision cycle</div>
    <div style="margin-top:10px;"><h-sparkline column="Avg Days to Close" width="100" height="30" class="size-full"></h-sparkline></div>
  </div>
  <div style="background:linear-gradient(180deg,#FFFFFF 0%,#F8FBFF 100%);border:1px solid #D7E3F0;border-radius:20px;padding:18px 20px;box-shadow:0 14px 40px rgba(15,23,42,0.06);position:relative;overflow:hidden;">
    <div style="position:absolute;top:0;left:0;width:100%;height:4px;background:linear-gradient(90deg,#7C3AED 0%,#A78BFA 100%);"></div>
    <div style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:#64748B;">KPI</div>
    <div style="margin-top:10px;font-size:30px;font-weight:800;color:#0F172A;line-height:1;">{{ col_totals.`Active Applications`.formatted }}</div>
    <div style="margin-top:8px;font-size:14px;color:#334155;">Active Applications</div>
    <div style="margin-top:10px;font-size:12px;color:#6D28D9;font-weight:600;">Current pipeline</div>
    <div style="margin-top:10px;"><h-sparkline column="Active Applications" width="100" height="30" class="size-full" type="column"></h-sparkline></div>
  </div>
</div>
      ;;
      settings {
        show_row_total: true
        show_column_total: true
      }
    }
    settings {
      hide_label: true
    }
    theme: BlockTheme {
      background {
        bg_color: 'transparent'
      }
      border {
        border_color: 'transparent'
      }
      label {
        font_color: '#0F172A'
      }
    }
  }
  block v1: VizBlock {
    label: 'Monthly Hiring Output and Speed'
    description: 'Executive trend view of hiring volume and cycle speed.'
    viz: CombinationChart {
      dataset: hiring_analytics
      x_axis: VizFieldFull {
        ref: r(dim_date_job.date_key)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        label: 'Hires'
        series {
          mark_type: 'column'
          field: VizFieldFull {
            label: 'Total Hires'
            ref: r(hiring_analytics.total_hires)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#4F46E5'
          }
        }
      }
      y_axis {
        label: 'Days'
        settings {
          alignment: 'right'
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            label: 'Avg Days to Hire'
            ref: r(hiring_analytics.avg_days_to_hire)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#F59E0B'
          }
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            label: 'Avg Days to Close'
            ref: r(hiring_analytics.avg_days_to_close)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#10B981'
          }
        }
      }
      settings {
        show_data_points: true
        row_limit: 100
        sort {
          field_index: 0
          direction: 'asc'
          type: 'xaxis'
        }
        legend_label: 'top'
        x_axis_label: 'Month'
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    theme: BlockTheme {
      background {
        bg_color: 'transparent'
      }
      border {
        border_color: 'transparent'
      }
      label {
        font_color: '#0F172A'
      }
    }
  }

  block v2: VizBlock {
    label: 'Pipeline Concentration by Current Stage'
    description: 'Shows where active demand is currently concentrated in the funnel.'
    theme: BlockTheme {
      background {
        bg_color: 'transparent'
      }
      border {
        border_color: 'transparent'
      }
    }
    viz: BarChart {
      dataset: hiring_analytics
      calculation application_count {
        label: 'Application Count'
        formula: @aql count(fct_applications.application_id) ;;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        ref: r(fct_applications.current_stage)
        label: 'Current Stage'
        format {
          type: 'text'
        }
      }
      y_axis {
        label: 'Applications'
        series {
          field: VizFieldFull {
            ref: 'application_count'
            label: 'Application Count'
            format {
              type: 'number'
              pattern: '#,###'
            }
          }
          settings {
            color: '#6366F1'
          }
        }
      }
      settings {
        legend_label: 'hidden'
        row_limit: 100
      }
    }
  }

  block v3: VizBlock {
    label: 'Source Effectiveness'
    description: 'Compares hiring output against speed by acquisition channel.'
    theme: BlockTheme {
      background {
        bg_color: 'transparent'
      }
      border {
        border_color: 'transparent'
      }
    }
    viz: CombinationChart {
      dataset: hiring_analytics
      x_axis: VizFieldFull {
        ref: r(dim_sources.source_name)
        label: 'Source'
        format {
          type: 'text'
        }
      }
      y_axis {
        label: 'Hires'
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(hiring_analytics.total_hires)
            label: 'Total Hires'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#2563EB'
          }
        }
        settings {
          alignment: 'left'
          axis_min: 0
        }
      }
      y_axis {
        label: 'Avg Days to Hire'
        series {
          mark_type: 'line'
          field: VizFieldFull {
            ref: r(hiring_analytics.avg_days_to_hire)
            label: 'Avg Days to Hire'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#F59E0B'
            line_style: 'solid'
            line_interpolation: 'smooth'
          }
        }
        settings {
          alignment: 'right'
          axis_min: 0
        }
      }
      settings {
        legend_label: 'top'
        row_limit: 100
        show_data_points: true
        sort: LineFamilySort {
          type: 'yaxis'
          field_index: 0
          direction: 'desc'
        }
      }
    }
  }

  block v4: VizBlock {
    label: 'Stage Bottlenecks'
    description: 'Highlights where candidates exit and where stage dwell time is highest.'
    theme: BlockTheme {
      background {
        bg_color: 'transparent'
      }
      border {
        border_color: 'transparent'
      }
    }
    viz: CombinationChart {
      dataset: hiring_analytics
      x_axis: VizFieldFull {
        ref: r(fct_stage_events.stage)
        label: 'Stage'
        format {
          type: 'text'
        }
      }
      y_axis {
        label: 'Exit Count'
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(hiring_analytics.total_advanced_exit)
            label: 'Advanced'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#16A34A'
          }
        }
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(hiring_analytics.total_rejected_exit)
            label: 'Rejected'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#F59E0B'
          }
        }
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(hiring_analytics.total_withdrawn_exit)
            label: 'Withdrawn'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#6B7280'
          }
        }
        settings {
          alignment: 'left'
          stack_series_by: 'value'
          show_stack_total: true
          show_total_in_tooltip: true
        }
      }
      y_axis {
        label: 'Avg Hours in Stage'
        series {
          mark_type: 'line'
          field: VizFieldFull {
            ref: r(hiring_analytics.avg_hours_stage)
            label: 'Avg Hours in Stage'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#EF4444'
            line_style: 'solid'
            line_interpolation: 'linear'
          }
        }
        settings {
          alignment: 'right'
        }
      }
      conditions: [
        "fct_stage_events.exited_at is not null"
      ]
      settings {
        legend_label: 'top'
        row_limit: 100
      }
    }
  }
  block v_stur: VizBlock {
    label: 'Total Applications, Total Hires and 4 more by Week Date Key'
    viz: CombinationChart {
      dataset: hiring_analytics
      calculation total_applications {
        label: 'Total Applications'
        formula: @aql fct_applications | count(fct_applications.application_id);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation hired_applications {
        label: 'Total Hires'
        formula: @aql fct_applications | count(fct_applications.application_id) | where(fct_applications.outcome == 'hired');;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation application_to_hire_conversion {
        label: 'Application-to-Hire Conversion'
        formula: @aql safe_divide(hired_applications, total_applications);;
        calc_type: 'measure'
        data_type: 'number'
      }
      filter {
        field: r(dim_date_job.date_key)
        operator: 'matches'
        value: 'last 12 months'
      }
      x_axis: VizFieldFull {
        ref: r(dim_date_job.date_key)
        transformation: 'datetrunc week'
        format {
          type: 'date'
          pattern: 'wwww'
        }
      }
      y_axis {
        label: 'Applications'
        settings {
          axis_min: 0
        }
        series {
          mark_type: 'column'
          field: VizFieldFull {
            label: 'Total Applications'
            ref: 'total_applications'
            format {
              type: 'number'
              pattern: '#,###0'
            }
          }
          settings {
            color: '#CBD5E1'
          }
        }
        series {
          mark_type: 'column'
          field: VizFieldFull {
            label: 'Total Hires'
            ref: 'hired_applications'
            format {
              type: 'number'
              pattern: '#,###0'
            }
          }
          settings {
            color: '#2563EB'
          }
        }
      }
      y_axis {
        label: 'Conversion Rate'
        settings {
          alignment: 'right'
          axis_min: 0
          show_data_label_by: 'value'
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            label: 'Conversion Rate'
            ref: 'application_to_hire_conversion'
            format {
              type: 'number'
              pattern: '#,###0.0%'
            }
          }
          settings {
            color: '#F59E0B'
            line_interpolation: 'smooth'
          }
        }
      }
      tooltips: [
        VizTooltip {
          field: VizFieldFull {
            label: 'Total Applications'
            ref: 'total_applications'
            format {
              type: 'number'
              pattern: '#,###0'
            }
          }
        },
        VizTooltip {
          field: VizFieldFull {
            label: 'Total Hires'
            ref: 'hired_applications'
            format {
              type: 'number'
              pattern: '#,###0'
            }
          }
        },
        VizTooltip {
          field: VizFieldFull {
            label: 'Conversion Rate'
            ref: 'application_to_hire_conversion'
            format {
              type: 'number'
              pattern: '#,###0.0%'
            }
          }
        }
      ]
      settings {
        show_data_points: true
        row_limit: 100
        sort {
          field_index: 0
          direction: 'asc'
          type: 'xaxis'
        }
        legend_label: 'top'
        x_axis_label: 'Month'
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    theme: BlockTheme {
      background {
        bg_color: 'transparent'
      }
      border {
        border_color: 'transparent'
      }
      label {
        font_color: '#0F172A'
      }
    }
  }

  view: CanvasLayout {
    width: 1420
    height: 1920
    block t1 {
      position: pos(10, 20, 1400, 330)
    }
    block f_date {
      position: pos(10, 360, 340, 80)
    }
    block f_department {
      position: pos(370, 360, 410, 80)
    }
    block f_recruiter {
