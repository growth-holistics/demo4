Dashboard sandbox_dashboard {
  title: 'Sandbox Dashboard'
  owner: 'vincent@holistics.io'
  block title: TextBlock {
    content: @md # This is a playground for everyone to add your dashboards;;
  }
  interactions: []
  view: CanvasLayout {
    label: 'View 1'
    width: 1300
    height: 800
    grid_size: 20
    auto_expand_vertically: true
    block title {
      position: pos(20, 20, 1260, 60)
    }
    mobile {
      mode: 'auto'
    }
  }
  theme: H.themes.vanilla
}