  block v_paq2: VizBlock {
    label: 'What is the resolution time distribution?'
    viz: ColumnChart {
      dataset: pawductive_customer_support_data
      calculation resolution_bucket {
        label: 'Resolution Bucket'
        formula: @aql case(
  when: support_tickets.days_to_resolution > 0, then: case(
    when: support_tickets.days_to_resolution < 8, then: '01-07 days',
    when: support_tickets.days_to_resolution < 15, then: '08-14 days',
    when: support_tickets.days_to_resolution < 22, then: '15-21 days',
    when: support_tickets.days_to_resolution < 29, then: '22-28 days',
    else: '29+ days'
  )
);;
        calc_type: 'dimension'
        data_type: 'text'
        model: support_tickets
      }
      calculation resolution_bucket_order {
        label: 'Resolution Bucket Order'
        formula: @aql case(
  when: support_tickets.days_to_resolution > 0, then: case(
    when: support_tickets.days_to_resolution < 8, then: 1,
    when: support_tickets.days_to_resolution < 15, then: 2,
    when: support_tickets.days_to_resolution < 22, then: 3,
    when: support_tickets.days_to_resolution < 29, then: 4,
    else: 5
  )
);;
        calc_type: 'dimension'
        data_type: 'number'
        model: support_tickets
      }
      calculation ticket_ratio_over_all {
        label: 'Ticket Ratio Over All'
        formula: @aql total_tickets * 1.0 / (total_tickets | exclude_grains(support_tickets.resolution_bucket, support_tickets.resolution_bucket_order));;
        calc_type: 'measure'
        data_type: 'number'
      }
      conditions: [
        'support_tickets.days_to_resolution > 0'
      ]
      x_axis: VizFieldFull {
        label: 'Resolution time'
        ref: ref('support_tickets', 'resolution_bucket')
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          axis_min: 0
        }
        series {
          field: VizFieldFull {
            label: '% of ticket'
            ref: 'ticket_ratio_over_all'
            format {
              type: 'number'
              pattern: '#,###%'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            color: '#8A79ABFF'
          }
        }
      }
      settings {
        row_limit: 100
        sort {
          field_index: 0
          direction: 'asc'
          type: 'xaxis'
        }
        legend_label: 'hidden'
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
