  block v_ghgo: VizBlock {
    theme: viz_transparent
    label: "What are the tickets' priority?"
    viz: ColumnChart {
      dataset: pawductive_customer_support_data
      x_axis: VizFieldFull {
        ref: r(support_tickets.priority)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            label: ' '
            ref: r(pawductive_customer_support_data.total_tickets)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#E6A5B8FF'
            color_palette: 40809
            point {
              value: 'critical'
              color: '#8A79ABFF'
            }
            point {
              value: 'high'
              color: '#E6A5B8FF'
            }
            point {
              value: 'low'
              color: '#80E4D1FF'
            }
            point {
              value: 'medium'
              color: '#FDCF8BFF'
            }
            point {
              value: 'open'
              color: '#B497F5FF'
            }
            point {
              value: 'pending'
              color: '#8A79ABFF'
            }
            point {
              value: 'resolved'
              color: '#E6A5B8FF'
            }
            point {
              value: 'Free'
              color: '#80E4D1FF'
            }
            point {
              value: 'Pro'
              color: '#FDCF8BFF'
            }
            point {
              value: 'Standard'
              color: '#B497F5FF'
            }
          }
        }
      }
      settings {
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
  }
