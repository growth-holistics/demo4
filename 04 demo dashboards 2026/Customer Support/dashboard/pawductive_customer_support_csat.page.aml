    }
    theme: kpi_accent
  }
  block v_snu2: VizBlock {
    label: 'Solved & closed tickets'
    viz: MetricKpi {
      dataset: pawductive_customer_support_data
      filter {
        field: r(support_tickets.status)
        operator: 'is'
        value: [
          'closed',
          'resolved'
        ]
      }
      value: VizFieldFull {
        label: 'Solved & closed tickets'
        ref: r(pawductive_customer_support_data.total_tickets)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_size: 18
          font_color: '#8A8AAAFF'
        }
        alignment: 'left'
        metric_value {
          font_size: 64
          font_color: '#E6A5B8FF'
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: kpi_accent
  }
  block f_time_range: FilterBlock {
    label: 'View by Time range'
    type: 'field'
    source: FieldFilterSource {
      dataset: pawductive_customer_support_data
      field: r(support_tickets.created_at)
    }
    default {
      operator: 'matches'
