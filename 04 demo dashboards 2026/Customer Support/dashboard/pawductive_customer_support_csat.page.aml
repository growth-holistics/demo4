      }
      settings {
        row_limit: 10000
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: viz_transparent
  }
  block v_igh9: VizBlock {
    label: 'Open tickets'
    viz: MetricKpi {
      dataset: pawductive_customer_support_data
      filter {
        field: r(support_tickets.status)
        operator: 'is'
        value: 'open'
      }
      value: VizFieldFull {
        label: 'Open tickets'
        ref: r(pawductive_customer_support_data.total_tickets)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
