              type: 'number'
              pattern: '#,###%'
            }
          }
          settings {
            color: '#B497F5FF'
            line_interpolation: 'smooth'
          }
        }
        series {
          field: ConstantVizField {
            label: 'Target: 80%'
            value: 0.8
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#80E4D1FF'
            line_style: 'dashed'
          }
