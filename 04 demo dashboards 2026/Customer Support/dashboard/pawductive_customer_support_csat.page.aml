@tag('Endorsed')
Dashboard pawductive_customer_support {
  title: 'Customer support & CSAT [Pawductive]'
  description: 'Customer support dashboard for tracking support ticket metrics & CSAT data'
  owner: 'my.nguyen@holistics.io'
  theme: pawductive_purple
  block v_1xop: VizBlock {
    label: 'What is CSAT score distribution?'
    viz: ColumnChart {
      dataset: pawductive_customer_support_data
      x_axis: VizFieldFull {
        ref: r(support_surveys.csat_score)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      y_axis {
        settings {
          alignment: 'right'
        }
        series {
          field: VizFieldFull {
            ref: r(pawductive_customer_support_data.total_csat_response)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#E6A5B8FF'
          }
        }
      }
      settings {
        row_limit: 10000
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: viz_transparent
  }
  block v_i0lt: VizBlock {
    label: 'What is the CSAT by channel?'
    viz: ColumnChart {
      dataset: pawductive_customer_support_data
      x_axis: VizFieldFull {
        ref: r(support_tickets.channel)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(pawductive_customer_support_data.csat)
            format {
              type: 'number'
              pattern: '#,###%'
            }
          }
          settings {
            color: '#8A79ABFF'
          }
        }
        series {
          field: ConstantVizField {
            label: 'Target: 80%'
            value: 0.8
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#80E4D1FF'
            line_style: 'dashed'
          }
        }
      }
      settings {
        row_limit: 10000
        sort {
          field_index: 0
          direction: 'asc'
          type: 'yaxis'
        }
        legend_label: 'top'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block t_kj4u: TextBlock {
    content: @md ## 1. Monthly ticket snapshot;;
    theme: text_transparent
  }
  block v_pluq: VizBlock {
    label: 'CSAT compared with CSAT Target'
    viz: MetricKpi {
      dataset: pawductive_customer_support_data
      value: VizFieldFull {
        ref: r(pawductive_customer_support_data.csat)
        format {
          type: 'number'
          pattern: '#,###%'
        }
      }
      compare_value: VizFieldFull {
        ref: r(pawductive_customer_support_data.csat_target)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        display_mode: 'compare_by_number'
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_size: 18
          font_color: '#8A8AAAFF'
        }
        alignment: 'left'
        metric_value {
          font_size: 64
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: kpi_primary
  }
  block v_siky: VizBlock {
    label: 'Total survey answers compared with surveys sent'
    viz: MetricKpi {
      dataset: pawductive_customer_support_data
      filter {
        field: r(support_tickets.status)
        operator: 'is'
        value: [
          'closed',
          'resolved'
        ]
      }
      value: VizFieldFull {
        ref: r(pawductive_customer_support_data.total_csat_answers)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizFieldFull {
        label: 'surveys sent'
        ref: r(pawductive_customer_support_data.total_tickets)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        display_mode: 'progress'
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_size: 18
          font_color: '#8A8AAAFF'
        }
        alignment: 'center'
        metric_value {
          font_size: 64
        }
        progress {
          bar {
            color: '#B497F5FF'
          }
          text {
            font_color: '#8A8AAAFF'
          }
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: kpi_primary
  }
  block v_sxbu: VizBlock {
    label: 'What is the CSAT by ticket category?'
    viz: CombinationChart {
      dataset: pawductive_customer_support_data
      x_axis: VizFieldFull {
        ref: r(support_categories.name)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(pawductive_customer_support_data.csat)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#8A79ABFF'
          }
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            label: 'Target: 80%'
            ref: r(pawductive_customer_support_data.csat_target)
            format {
              type: 'number'
              pattern: '#,###%'
            }
          }
          settings {
            color: '#80E4D1FF'
            line_style: 'dashed'
          }
        }
      }
      settings {
        sort {
          field_index: 0
          direction: 'asc'
          type: 'yaxis'
        }
        legend_label: 'top'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_sue1: VizBlock {
    label: 'Avg CSAT score'
    viz: MetricKpi {
      dataset: pawductive_customer_support_data
      value: VizFieldFull {
        label: 'Avg CSAT score'
        ref: r(pawductive_customer_support_data.avg_csat_score)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_size: 18
          font_color: '#8A8AAAFF'
        }
        alignment: 'left'
        metric_value {
          font_size: 64
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: kpi_accent
  }
  block v_y98t: VizBlock {
    label: 'What are the lowest CSAT feedbacks?'
    viz: DataTable {
      dataset: pawductive_customer_support_data
      filter {
        field: r(support_surveys.feedback_text)
        operator: 'is_not'
        value: ''
      }
      filter {
        field: r(support_surveys.csat_score)
        operator: 'less_than'
        value: '4'
      }
      theme {
        table {
          general {
            borders {
              vertical: true
              header: true
            }
          }
        }
      }
      fields: [
        VizFieldFull {
          ref: r(support_users.full_name)
          format {
            type: 'text'
          }
          uname: 'support_users_full_name'
        },
        VizFieldFull {
          label: 'CSAT'
          ref: r(support_surveys.csat_score)
          format {
            type: 'number'
            pattern: 'inherited'
          }
          uname: 'support_surveys_csat_score'
        },
        VizFieldFull {
          ref: r(support_surveys.feedback_text)
          format {
            type: 'text'
          }
          uname: 'support_surveys_feedback_text'
        },
        VizFieldFull {
          label: 'Category'
          ref: r(support_categories.name)
          format {
            type: 'text'
          }
          uname: 'support_categories_name'
        },
        VizFieldFull {
          ref: r(support_surveys.created_at)
          format {
            type: 'date'
          }
          uname: 'support_surveys_created_at_1'
        },
        VizFieldFull {
          ref: r(support_agents.agent_name)
          format {
            type: 'text'
          }
          uname: 'support_agents_agent_name'
        }
      ]
      settings {
        sorts: [
          SortSetting {
            key: 'support_surveys_csat_score'
            direction: 'asc'
          },
          SortSetting {
            key: 'support_categories_name'
            direction: 'asc'
          },
          SortSetting {
            key: 'support_surveys_created_at_1'
            direction: 'desc'
          }
        ]
        row_limit: 10000
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        frozen_columns: 0
        column_styles: [
          ColumnStyle {
            key: 'support_categories_name'
            width: 193
          },
          ColumnStyle {
            key: 'support_users_full_name'
            width: 144
          },
          ColumnStyle {
            key: 'support_agents_agent_name'
            width: 151
          },
          ColumnStyle {
            key: 'support_surveys_csat_score'
            width: 75.3046875
          },
          ColumnStyle {
            key: 'support_surveys_created_at_1'
            width: 110.828125
          },
          ColumnStyle {
            key: 'support_surveys_feedback_text'
            width: 228.4765625
          }
        ]
      }
    }
    settings {
      hide_label: true
    }
    theme: viz_transparent
  }
  block v_2iwp: VizBlock {
    label: 'CSAT distribution by resolution time'
    theme: kpi_accent
    viz: CombinationChart {
      dataset: pawductive_customer_support_data
      x_axis: VizFieldFull {
        ref: r(pawductive_customer_support_data, support_tickets.rounded_week_to_resolution)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      y_axis {
        settings {
          hidden: true
        }
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(pawductive_customer_support_data.csat)
            format {
              type: 'number'
              pattern: '#,###%'
            }
          }
          settings {
            color: '#E6A5B8FF'
            color_palette: 0
          }
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            label: 'Target: 80%'
            ref: r(pawductive_customer_support_data.csat_target)
            format {
              type: 'number'
              pattern: '#,###%'
            }
          }
          settings {
            color: '#80E4D1FF'
            line_style: 'dashed'
          }
        }
      }
      settings {
        row_limit: 10000
        legend_label: 'top'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_vntb: VizBlock {
    label: 'Total tickets per month'
    viz: AreaChart {
      dataset: pawductive_customer_support_data
      x_axis: VizFieldFull {
        ref: r(support_tickets.created_at)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(pawductive_customer_support_data.total_tickets)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#8A79ABFF'
            line_interpolation: 'smooth'
            color_palette: 0
          }
        }
      }
      settings {
        row_limit: 10000
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_bqgn: VizBlock {
    label: 'Ticket status by month'
    viz: ColumnChart {
      dataset: pawductive_customer_support_data
      x_axis: VizFieldFull {
        ref: r(support_tickets.created_at)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      legend: VizFieldFull {
        ref: r(support_tickets.status)
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          stack_series_by: 'value'
        }
        series {
          field: VizFieldFull {
            label: ' '
            ref: r(pawductive_customer_support_data.total_tickets)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            point {
              value: 'open'
              color: '#80E4D1FF'
            }
            point {
              value: 'pending'
              color: '#E6A5B8FF'
            }
            point {
              value: 'resolved'
              color: '#8A79ABFF'
            }
            point {
              value: 'Free'
              color: '#FDCF8BFF'
            }
            point {
              value: 'Pro'
              color: '#B497F5FF'
            }
            point {
              value: 'Standard'
              color: '#8A79ABFF'
            }
          }
        }
      }
      settings {
        legend_label: 'top'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_vimo: VizBlock {
    label: 'Average days to first response'
    viz: MetricKpi {
      dataset: pawductive_customer_support_data
      calculation response_target {
        label: 'Response Target'
        formula: @aql 0.5;;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        label: 'Avg day to 1st response'
        ref: r(pawductive_customer_support_data.avg_day_to_first_response)
        format {
          type: 'number'
          pattern: '#,###0.00'
        }
      }
      compare_value: VizFieldFull {
        ref: 'response_target'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        reverse_color: true
        display_mode: 'compare_by_number'
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_size: 16
          font_color: '#8A8AAAFF'
        }
        alignment: 'left'
        metric_value {
          font_size: 60
        }
        compare_value {
          reverse_color: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: kpi_accent
  }
  block v_vhjx: VizBlock {
    label: 'Avg Resolution Day'
    viz: MetricKpi {
      dataset: pawductive_customer_support_data
      calculation resolution_target {
        label: 'Resolution Target'
        formula: @aql 2;;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        label: 'Avg day to resolution'
        ref: r(pawductive_customer_support_data.avg_day_to_resolution)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizFieldFull {
        ref: 'resolution_target'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        reverse_color: true
        display_mode: 'compare_by_number'
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_size: 16
          font_color: '#8A8AAAFF'
        }
        alignment: 'left'
        metric_value {
          font_size: 60
        }
        compare_value {
          reverse_color: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: kpi_green
  }
  block v_k9t8: VizBlock {
    label: 'Total tickets by Plan tier'
    viz: ColumnChart {
      dataset: pawductive_customer_support_data
      x_axis: VizFieldFull {
        ref: r(support_users.plan_type)
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          show_data_label_by: 'percentage'
        }
        series {
          field: VizFieldFull {
            ref: r(pawductive_customer_support_data.total_tickets)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#8A79ABFF'
            point {
              value: 'Free'
              color: '#A8BEEE'
            }
            point {
              value: 'Pro'
              color: '#F2B602'
            }
            point {
              value: 'Standard'
              color: '#18A59E'
            }
          }
        }
      }
      settings {
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_12z0: VizBlock {
    label: 'Total tickets compared with Total tickets (Prev. 1m)'
    viz: MetricKpi {
      dataset: pawductive_customer_support_data
      value: VizFieldFull {
        label: 'Total tickets'
        ref: r(pawductive_customer_support_data.total_tickets)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizPopSettings {
        field: r(support_tickets.created_at)
        value: RelativePopValue {
          duration: 1
          granularity: 'month'
        }
      }
      settings {
        reverse_color: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_size: 18
          font_color: '#8A8AAAFF'
        }
        alignment: 'left'
        metric_value {
          font_size: 64
          font_color: '#8A79ABFF'
        }
        compare_value {
          reverse_color: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: kpi_primary
  }
  block v_lu2i: VizBlock {
    label: 'What are the main causes of tickets per month?'
    viz: ColumnChart {
      dataset: pawductive_customer_support_data
      x_axis: VizFieldFull {
        ref: r(support_tickets.created_at)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      legend: VizFieldFull {
        ref: r(support_categories.name)
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          show_total_in_tooltip: true
          stack_series_by: 'value'
        }
        series {
          field: VizFieldFull {
            label: ' '
            ref: r(pawductive_customer_support_data.total_tickets)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color_palette: 40809
            point {
              value: 'Account management'
              color: '#8A79ABFF'
            }
            point {
              value: 'Calendar & task'
              color: '#E6A5B8FF'
            }
            point {
              value: 'Others'
              color: '#80E4D1FF'
            }
            point {
              value: 'Subscription & cancellation'
              color: '#FDCF8BFF'
            }
          }
        }
      }
      settings {
        row_limit: 10000
        sort {
          field_index: 0
          direction: 'asc'
          type: 'xaxis'
        }
        legend_label: 'top'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_wnt8: VizBlock {
    label: 'CSAT by week'
    viz: AreaChart {
      dataset: pawductive_customer_support_data
      x_axis: VizFieldFull {
        ref: r(support_surveys.created_at)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        settings {
