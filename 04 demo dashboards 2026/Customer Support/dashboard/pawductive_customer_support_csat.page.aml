  }
  block v_yld9: VizBlock {
    label: 'Pending tickets'
    viz: MetricKpi {
      dataset: pawductive_customer_support_data
      filter {
        field: r(support_tickets.status)
        operator: 'is'
        value: 'pending'
      }
      value: VizFieldFull {
        label: 'Pending tickets'
        ref: r(pawductive_customer_support_data.total_tickets)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_size: 18
          font_color: '#8A8AAAFF'
        }
        alignment: 'left'
        metric_value {
