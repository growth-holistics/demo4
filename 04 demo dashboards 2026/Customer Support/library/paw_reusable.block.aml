// ─────────────────────────────────────────────────────────────────────────────
// header_block.aml — Reusable Dashboard Header & Logo Blocks
//
// Includes:
//   - pawductive_header(title) — Dark purple header with branding
//   - paw_logomark(fill_color) — Paw icon logomark
//   - paw_trail(fill_color) — Paw trail pattern
//   - pawductive_logo(fill_color) — Full Pawductive wordmark
// ─────────────────────────────────────────────────────────────────────────────


// ─────────────────────────────────────────────────────────────────────────────
// Paw Logomark — Square paw icon
// Usage: block logo: paw_logomark(fill_color: '#ffffff')
// ─────────────────────────────────────────────────────────────────────────────

@template(
  title = "Paw Logomark",
  description = "Pawductive paw icon with customizable fill color",
  metadata = {
    group: 'Pawductive',
    block_width: 100,
    block_height: 100,
    func: TemplateFuncMetadata {
      param fill_color: StringParamMetadata {
        description: 'SVG fill color (hex code)',
        input_type: 'color-picker'
      }
    }
  }
)
Func paw_logomark(
  fill_color: String = '#8A79AB'
) {
  TextBlock {
    theme: text_transparent
    content: @md
<svg width="100%" height="100%" viewBox="0 0 187 166" preserveAspectRatio="xMidYMid meet" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M41.626 41.5621L41.5723 82.9928L62.3564 83.0141C62.3771 76.1112 62.3311 69.082 62.4314 62.191C83.0902 62.275 104.078 61.9956 124.69 62.282L124.721 82.9867C131.627 82.9564 138.53 82.9766 145.436 83.0434C145.001 70.0068 145.4 54.7432 145.419 41.5591L186.964 41.5712L187 83.0333L145.437 83.0454C145.373 89.9267 145.391 96.8051 145.495 103.686L166.183 103.726C166.153 117.398 166.001 131.517 166.226 145.159C159.295 145.119 152.362 145.116 145.431 145.146L145.419 165.84C131.813 166.125 117.668 165.752 103.926 165.922L103.831 145.277C97.9224 144.84 89.24 145.122 83.1557 145.153C83.0252 151.907 83.1511 159.031 83.1131 165.834C69.787 166.244 55.1926 165.743 41.625 165.925L41.5733 145.277C35.6541 144.849 26.993 145.14 20.8389 145.213C20.7489 131.374 20.7684 117.535 20.8967 103.696L41.5713 103.699L41.6524 83.0899C28.6188 82.656 13.2781 82.9958 0.145086 83.0444C-0.123741 69.5667 0.0432088 55.0428 0.151168 41.5247L41.626 41.5621ZM145.431 0.135418C145.416 13.6985 145.163 28.0612 145.419 41.5591C131.661 41.5463 117.659 41.4165 103.916 41.6025C103.78 28.3323 103.579 13.248 103.968 0.0545044L145.431 0.135418ZM41.6686 0.0575387C55.2733 0.099411 69.5728 -0.159192 83.103 0.168795C83.4658 12.845 83.2371 28.7526 83.109 41.5641L41.626 41.5621C41.5637 28.1602 41.307 13.3888 41.6686 0.0575387Z" fill="${fill_color}"/>
</svg>
;;
  }
}


// ─────────────────────────────────────────────────────────────────────────────
// Paw Trail — Vertical trail of paw prints
// Usage: block trail: paw_trail(fill_color: '#ffffff')
// ─────────────────────────────────────────────────────────────────────────────

@template(
  title = "Paw Trail",
  description = "Vertical trail of paw prints with customizable fill color",
  metadata = {
    group: 'Pawductive',
    block_width: 80,
    block_height: 400,
    func: TemplateFuncMetadata {
      param fill_color: StringParamMetadata {
        description: 'SVG fill color (hex code)',
        input_type: 'color-picker'
      }
    }
  }
)
Func paw_trail(
  fill_color: String = '#8A79AB'
) {
  TextBlock {
    theme: text_transparent
    content: @md
