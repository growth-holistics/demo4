// ─────────────────────────────────────────────────────────────────────────────
// Dashboard Header
// ─────────────────────────────────────────────────────────────────────────────

@template(
  title = "Pawductive Header",
  description = "Dark purple header with customizable title and Pawductive logo branding",
  metadata = {
    group: 'Pawductive',
    block_width: 1200,
    block_height: 80,
    func: TemplateFuncMetadata {
      param title: GeneralParamMetadata {
        description: 'The header title to display'
      }
    }
  }
)
