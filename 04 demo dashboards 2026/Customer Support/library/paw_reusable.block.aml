// ─────────────────────────────────────────────────────────────────────────────
// Pawductive Logo — Full wordmark with paw icon
// Usage: block logo: pawductive_logo(fill_color: '#ffffff')
// ─────────────────────────────────────────────────────────────────────────────

@template(
  title = "Pawductive Logo",
  description = "Full Pawductive wordmark with customizable fill color",
  metadata = {
    group: 'Pawductive',
    block_width: 200,
    block_height: 40,
    func: TemplateFuncMetadata {
      param fill_color: StringParamMetadata {
        description: 'SVG fill color (hex code)',
        input_type: 'color-picker'
      }
    }
  }
)
