BlockTheme kpi_default {
  background {
    bg_color: '#ffffff'
  }
  label {
    font_color: '#6b6880'
    font_size: 12
    font_weight: 'semibold'
  }
  text {
    font_color: '#3d3c4f'
  }
  border {
    border_radius: 8
    border_width: 1
    border_color: '#cec9d9'
    border_style: 'solid'
  }
  padding: 20
  shadow: 'sm'
}

// Primary KPI card — soft purple tint
// Usage: block my_kpi: VizBlock { theme: kpi_primary ... }
BlockTheme kpi_primary {
  background {
    bg_color: '#f1eff5'
  }
  label {
    font_color: '#8a79ab'
    font_size: 12
    font_weight: 'semibold'
  }
  text {
    font_color: '#3d3c4f'
  }
  border {
    border_radius: 8
    border_width: 1
    border_color: '#8a79ab'
    border_style: 'solid'
  }
  padding: 20
  shadow: 'none'
}

// Accent KPI card — soft pink tint
