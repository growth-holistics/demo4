// ─────────────────────────────────────────────────────────────────────────────
// VizBlock Themes
// ─────────────────────────────────────────────────────────────────────────────

// Standard viz card — white with border
// Usage: block my_chart: VizBlock { theme: viz_card ... }
BlockTheme viz_card {
  background {
    bg_color: '#ffffff'
  }
  border {
    border_radius: 8
    border_width: 1
    border_color: '#cec9d9'
    border_style: 'solid'
  }
  padding: 20
  shadow: 'sm'
}

// Transparent viz — no card styling
// Usage: block my_chart: VizBlock { theme: viz_transparent ... }
BlockTheme viz_transparent {
  background {
    bg_color: 'transparent'
  }
  border {
    border_style: 'none'
    border_width: 0
  }
  padding: 16
  shadow: 'none'
}


// ─────────────────────────────────────────────────────────────────────────────
// Header Theme
// ─────────────────────────────────────────────────────────────────────────────

// Dark purple header — for dashboard header blocks
// Usage: block header: TextBlock { theme: header_dark_purple ... }
BlockTheme header_dark_purple {
  background {
    bg_color: '#1d1336'
  }
  label {
    font_color: '#ffffff'
  }
  text {
    font_color: '#ffffff'
  }
  border {
    border_radius: 8
    border_width: 0
    border_style: 'none'
  }
  padding: 20
  shadow: 'md'
}
