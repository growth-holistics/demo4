    definition: @sql {{ #SOURCE.started_at }};;
  }
  dimension completed_at {
    label: 'Completed at'
    description: ''
    type: 'date'
    hidden: false
    definition: @sql {{ #SOURCE.completed_at }};;
  }
  dimension cycle_time_hours {
    label: 'Cycle time hours'
    description: ''
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.cycle_time_hours }};;
  }

