Model public_unit_items {
  type: 'table'
  label: 'Unit Items'
  description: ''
  data_source_name: 'heo_sao_mai_tft'
  dimension unit_id {
    label: 'Unit Id'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.unit_id }};;
  }
  dimension item_name {
    label: 'Item Name'
    type: 'text'
    hidden: true
    definition: @sql {{ #SOURCE.item_name }};;
  }
  dimension id {
    label: 'Id'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.id }};;
    primary_key: true
  }

  owner: 'hung.dd@holistics.io'
  table_name: '"public"."unit_items"'
}
