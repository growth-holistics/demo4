Dashboard heosaomai_tft_2 {
  theme: hextech
  title: 'TFT Set 16 Analytics'
  description: ''
  owner: 'hung.dd@holistics.io'
  block title: TextBlock {
    content: @md <div class="hex-border-top"></div><div class="hex-cluster"><svg class="hc-1" viewBox="0 0 100 115"><polygon points="50,0 100,28 100,87 50,115 0,87 0,28" fill="none" stroke="#0AC8B9" stroke-width="3"/></svg><svg class="hc-2" viewBox="0 0 100 115"><polygon points="50,0 100,28 100,87 50,115 0,87 0,28" fill="none" stroke="#0A7A72" stroke-width="3"/></svg><svg class="hc-3" viewBox="0 0 100 115"><polygon points="50,0 100,28 100,87 50,115 0,87 0,28" fill="none" stroke="#0A7A72" stroke-width="4"/></svg><svg class="hc-4" viewBox="0 0 100 115"><polygon points="50,0 100,28 100,87 50,115 0,87 0,28" fill="none" stroke="#0AC8B9" stroke-width="3"/></svg><svg class="hc-5" viewBox="0 0 100 115"><polygon points="50,0 100,28 100,87 50,115 0,87 0,28" fill="none" stroke="#0A7A72" stroke-width="3"/></svg><svg class="hc-6" viewBox="0 0 100 115"><polygon points="50,0 100,28 100,87 50,115 0,87 0,28" fill="none" stroke="#0A7A72" stroke-width="4"/></svg></div><div style="padding:8px 0 4px 0"><span class="hex-hero">TFT Set 16 Analytics</span></div><div class="hex-subtitle"><span class="hex-pulse-dot"></span> Heo Sao Mai <span class="hex-icon"><svg viewBox="0 0 100 115"><polygon points="50,0 100,28 100,87 50,115 0,87 0,28" fill="rgba(10,200,185,0.15)" stroke="#0AC8B9" stroke-width="5"/></svg></span> Powered by Riot API + Data Dragon <span class="hex-pulse-dot"></span></div><div class="hex-divider"></div>;;
    theme: BlockTheme {
      background {
        bg_color: "transparent"
      }
      border {
        border_width: 0
      }
      padding: 0
    }
  }
  block nav: TextBlock {
    content: @md <div class="hex-nav"><a href="#block-sec_champions">Champions</a><a href="#block-sec_items">Items</a><a href="#block-sec_traits">Traits</a><a href="#block-sec_players">Players</a></div>;;
    theme: BlockTheme {
      background {
        bg_color: "transparent"
      }
      border {
        border_width: 0
      }
      padding: 0
    }
  }
  block sec_champions: TextBlock {
    content: @md <div class="hex-divider"></div><div class="hex-section-row"><span class="hex-icon"><svg viewBox="0 0 100 115"><polygon points="50,0 100,28 100,87 50,115 0,87 0,28" fill="rgba(10,200,185,0.2)" stroke="#0AC8B9" stroke-width="5"/></svg></span><span class="hex-section">Champions</span></div><div class="hex-body" style="margin-top:4px">Pick rates, win rates, and placements for every champion</div>;;
    theme: BlockTheme {
      background {
        bg_color: "transparent"
      }
      border {
        border_width: 0
      }
      padding: 0
    }
  }
  block sec_items: TextBlock {
    content: @md <div class="hex-divider"></div><div class="hex-section-row"><span class="hex-icon"><svg viewBox="0 0 100 115"><polygon points="50,0 100,28 100,87 50,115 0,87 0,28" fill="rgba(200,170,110,0.2)" stroke="#C8AA6E" stroke-width="5"/></svg></span><span class="hex-section">Items</span></div><div class="hex-body" style="margin-top:4px">Item performance across all champions</div>;;
    theme: BlockTheme {
      background {
        bg_color: "transparent"
      }
      border {
        border_width: 0
      }
      padding: 0
    }
  }
  block sec_traits: TextBlock {
    content: @md <div class="hex-divider"></div><div class="hex-section-row"><span class="hex-icon"><svg viewBox="0 0 100 115"><polygon points="50,0 100,28 100,87 50,115 0,87 0,28" fill="rgba(10,200,185,0.2)" stroke="#0AC8B9" stroke-width="5"/></svg></span><span class="hex-section">Traits</span></div><div class="hex-body" style="margin-top:4px">Trait synergies and tier breakdowns</div>;;
    theme: BlockTheme {
      background {
        bg_color: "transparent"
      }
      border {
        border_width: 0
      }
      padding: 0
    }
  }
  block sec_players: TextBlock {
    content: @md <div class="hex-divider"></div><div class="hex-section-row"><span class="hex-icon"><svg viewBox="0 0 100 115"><polygon points="50,0 100,28 100,87 50,115 0,87 0,28" fill="rgba(200,170,110,0.2)" stroke="#C8AA6E" stroke-width="5"/></svg></span><span class="hex-section">Players</span></div><div class="hex-body" style="margin-top:4px">Top player performance leaderboard</div>;;
    theme: BlockTheme {
      background {
        bg_color: "transparent"
      }
      border {
        border_width: 0
      }
      padding: 0
    }
  }
  block sec_explorer: TextBlock {
    content: @md <div class="hex-border-top"></div><div style="padding:12px 0 0 0" class="hex-section-row"><span class="hex-crystal"><svg viewBox="0 0 100 115"><polygon points="50,0 100,28 100,87 50,115 0,87 0,28" fill="rgba(10,200,185,0.1)" stroke="#0AC8B9" stroke-width="4"/><polygon points="50,20 80,38 80,77 50,95 20,77 20,38" fill="none" stroke="#0A7A72" stroke-width="2"/></svg></span><span class="hex-section">Data Explorer</span></div><div class="hex-body" style="margin-top:4px">Select a champion to see item and star level impact on placement</div>;;
    theme: BlockTheme {
      background {
        bg_color: "transparent"
      }
      border {
        border_width: 0
      }
      padding: 0
    }
  }
  block f_tft_set: FilterBlock {
    label: 'TFT Set'
    type: 'field'
    source: FieldFilterSource {
      dataset: heosaomai_tft
      field: r(public_matches.tft_set_core_name)
    }
    default {
      operator: 'is'
      value: 'TFTSet16'
    }
    settings {
      input_type: 'multiple'
    }
  }
  block f_server: FilterBlock {
    label: 'Server'
    type: 'field'
    source: FieldFilterSource {
      dataset: heosaomai_tft
      field: r(public_matches.platform)
    }
    default {
      operator: 'is'
      value: [
        'BR1',
        'EUN1',
        'KR',
        'JP1',
        'EUW1',
        'LA1'
      ]
    }
    settings {
      input_type: 'multiple'
    }
  }
  block f_game_mode: FilterBlock {
    label: 'Game Mode'
    type: 'field'
    source: FieldFilterSource {
      dataset: heosaomai_tft
      field: r(public_matches.tft_game_type)
    }
    default {
      operator: 'is'
      value: 'standard'
    }
    settings {
      input_type: 'single'
    }
  }
  block v_99of: VizBlock {
    label: 'Total Matches'
    viz: MetricKpi {
      dataset: heosaomai_tft
      value: VizFieldFull {
        ref: r(public_matches.total_matches)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        display_mode: 'single'
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'center'
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_5bv8: VizBlock {
    label: 'Unique Players'
    viz: MetricKpi {
      dataset: heosaomai_tft
      value: VizFieldFull {
        ref: r(public_match_participants.unique_players)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        display_mode: 'single'
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'center'
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_v85l: VizBlock {
    label: 'Avg of Game Length (Min)'
    viz: MetricKpi {
      dataset: heosaomai_tft
      value: VizFieldFull {
        ref: r(public_matches.game_length_minutes)
        aggregation: 'avg'
        format {
          type: 'number'
          pattern: '#,###0.00'
        }
      }
      settings {
        display_mode: 'single'
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'center'
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_sldm: VizBlock {
    label: 'Champion Pick Rate'
    viz: ScatterChart {
      dataset: heosaomai_tft
      filter {
        field: r(public_ddragon_champions.cost)
        operator: 'not_null'
        value: []
      }
      x_col: VizFieldFull {
        ref: r(heosaomai_tft.champion_pick_rate)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      y_col: VizFieldFull {
        ref: r(heosaomai_tft.champion_win_rate)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      group_col: VizFieldFull {
        ref: r(public_ddragon_champions.cost)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      label_col: VizFieldFull {
        ref: r(public_ddragon_champions.name)
        format {
          type: 'text'
        }
      }
      tooltips: [
        VizTooltip {
          field: VizFieldFull {
            label: 'Champion Icon'
            ref: r(public_ddragon_champions.image_html)
            aggregation: 'min'
            format {
              type: 'html'
            }
          }
        }
      ]
      settings {
        row_limit: 10000
      }
    }
  }
  block v_bkeb: VizBlock {
    label: 'Champion Play Count by Name'
    viz: BarChart {
      dataset: heosaomai_tft
      filter {
        field: r(heosaomai_tft.champion_play_count)
        operator: 'greater_than'
        value: '1000'
      }
      filter {
        field: r(public_ddragon_champions.name)
        operator: 'not_null'
        value: []
      }
      x_axis: VizFieldFull {
        ref: r(public_ddragon_champions.name)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(heosaomai_tft.champion_play_count)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
      settings {
        row_limit: 10000
        sort {
          field_index: 0
          direction: 'desc'
          type: 'series'
        }
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_gri4: VizBlock {
    label: 'Champion Overview'
    viz: DataTable {
      dataset: heosaomai_tft
      theme {
        table {
          general {
            font_size: 11
            cell_padding {
              top: 3
              left: 2
              bottom: 3
              right: 2
            }
          }
        }
      }
      fields: [
        VizFieldFull {
          label: 'Avatar'
          ref: r(public_ddragon_champions.image_html)
          format {
            type: 'html'
          }
          uname: 'public_ddragon_champions_image_html'
        },
        VizFieldFull {
          label: 'Champion'
          ref: r(public_ddragon_champions.name)
          format {
            type: 'text'
          }
          uname: 'public_ddragon_champions_name'
        },
        VizFieldFull {
          ref: r(public_ddragon_champions.cost)
          format {
            type: 'number'
            pattern: 'inherited'
          }
          uname: 'public_ddragon_champions_cost'
        },
        VizFieldFull {
          label: 'Avg Placement'
          ref: r(heosaomai_tft.champion_avg_placement)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
          uname: 'custom_champion_avg_placement_1'
        },
        VizFieldFull {
          label: 'Pick Rate'
          ref: r(heosaomai_tft.champion_pick_rate)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
          uname: 'custom_champion_pick_rate'
        },
        VizFieldFull {
          label: 'Win Rate'
          ref: r(heosaomai_tft.champion_win_rate)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
          uname: 'custom_champion_win_rate'
        },
        VizFieldFull {
          label: 'Top 4 Rate'
          ref: r(heosaomai_tft.champion_top_4_rate)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
          uname: 'custom_champion_top_4_rate'
        },
        VizFieldFull {
          label: 'Play Count'
          ref: r(heosaomai_tft.champion_play_count)
          format {
            type: 'number'
            pattern: 'inherited'
          }
          uname: 'custom_champion_play_count'
        }
      ]
      settings {
        sorts: [
          SortSetting {
            key: 'custom_champion_avg_placement_1'
            direction: 'asc'
          }
        ]
        row_limit: 10000
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        column_styles: [
          ColumnStyle {
            key: 'custom_champion_avg_placement_1'
            width: 188
          },
          ColumnStyle {
            key: 'public_ddragon_champions_image_html'
            width: 153
          },
          ColumnStyle {
            key: 'public_ddragon_champions_name'
            width: 152
          },
          ColumnStyle {
            key: 'public_ddragon_champions_cost'
            width: 146
          },
          ColumnStyle {
            key: 'custom_champion_pick_rate'
            width: 146
          },
          ColumnStyle {
            key: 'custom_champion_win_rate'
            width: 146
          },
          ColumnStyle {
            key: 'custom_champion_top_4_rate'
            width: 152
          },
          ColumnStyle {
            key: 'custom_champion_play_count'
            width: 155
          }
        ]
      }
    }
  }
