  block v_ih7c: VizBlock {
    label: 'Stars, Champion Avg Placement and 3 more'
    viz: DataTable {
      dataset: heosaomai_tft
      fields: [
        VizFieldFull {
          ref: r(public_participant_units.star_display)
          format {
            type: 'text'
          }
          uname: 'public_participant_units_star_display'
        },
        VizFieldFull {
          ref: r(heosaomai_tft.champion_avg_placement)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
          uname: 'custom_champion_avg_placement'
        },
        VizFieldFull {
          ref: r(heosaomai_tft.star_placement_delta)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
          uname: 'custom_star_placement_delta'
        },
        VizFieldFull {
          ref: r(heosaomai_tft.star_top4_delta)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
          uname: 'custom_star_top4_delta'
        },
        VizFieldFull {
          ref: r(heosaomai_tft.champion_play_count)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
          uname: 'custom_champion_play_count'
        }
      ]
      settings {
        show_row_number: true
        row_limit: 10000
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        column_styles: [
          ColumnStyle {
            key: 'public_participant_units_star_display'
            width: 150
          },
          ColumnStyle {
            key: 'custom_champion_avg_placement'
            width: 302
          },
          ColumnStyle {
            key: 'custom_star_placement_delta'
            width: 261
          },
          ColumnStyle {
            key: 'custom_star_top4_delta'
            width: 216
          },
          ColumnStyle {
            key: 'custom_champion_play_count'
            width: 265
          }
        ]
      }
    }
  }
