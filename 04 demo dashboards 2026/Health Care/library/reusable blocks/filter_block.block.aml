BlockTheme filter_block {
    background {
      bg_color: C_PAGE_BG
    }
    border {
      border_style: "none"
      border_width: 0
      border_radius: 12
    }
    shadow: "none"
    label {
      font_color: C_TXT_SECONDARY
      font_weight: "medium"
    }
    text {
      font_color: C_BLUE_DARK
    }
    
  }