        }
      }
    }
  }
  block v_f7no: VizBlock {
    label: 'Total ED Visits, PoP Comparison of Total ED Visits and 3 more copy copy copy copy copy'
    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation metric_8eb4f63 {
        label: 'PoP Comparison of Total ED Visits'
        formula: @aql safe_divide(total_ed_visits, total_ed_visits | relative_period(ed_visits.arrival_time, interval(-1 year), strict: true)) - 1;;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_22053a3 {
        label: 'Text'
        formula: @aql case(
  when: metric_8eb4f63 < 0,
  then: "#1A8A52",
  else: "#C41A1A"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_b5da4bb {
        label: 'Icon'
        formula: @aql case(
  when: metric_8eb4f63 < 0,
  then: "▼",
  else: "▲"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_4cf891e {
        label: 'Classification of PoP Comparison of Total ED Visits'
        formula: @aql case(
  when: metric_8eb4f63 < 0,
  then: "#d8f7e8",
  else: "#fff1f1"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      values: [
        VizFieldFull {
          ref: r(healthcare_overview.total_ed_visits)
          format {
            type: 'number'
            pattern: '#,###0.00,"K"'
          }
        },
        VizFieldFull {
          ref: 'metric_8eb4f63'
          format {
            type: 'number'
            pattern: '#,###0.00%'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: 'metric_22053a3'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'metric_b5da4bb'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
