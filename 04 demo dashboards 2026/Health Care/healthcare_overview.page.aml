            type: 'text'
          }
        }
      ]
      content: @md <style>
.kpi-card-ed {
  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  background: transparent;
  border-radius: 8px;
  padding-top: 16px;
  color: #1A1A2E;
  width: 100%;
  height: 72px;
}

.kpi-title { font-size: 14px; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.9; }

.kpi-value {
  font-size: 64px;
  font-weight: 700;
  margin-top: 26px;
}

.kpi-change-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 44px;
}

.kpi-pill-or {
  background: #1A1A2E;
  padding: 4px 12px;
  border-radius: 999px;
  color: white;
  font-size: 12px;
  font-weight: 500;
  display: inline-flex;
  gap: 12px;
}

.kpi-vs {
  opacity: 0.6;
  font-size: 14px;
}

.kpi-note-ed {
  margin-top: 12px;
  opacity: 0.8;
  font-size: 14px;
}
</style>

<div class="kpi-card-ed">

<div class="kpi-title">
Total ED Visits
</div>

<div class="kpi-value">
{{ rows[0].values.`Total ED Visits`.formatted }}
</div>





</div>                                   ;;
      settings {
        show_row_total: true
        show_column_total: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: no_bg
  }
  block v_j6lr: VizBlock {
    label: 'LWBS Rate KPI - Dynamic copy copy'
    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation metric_pop_lwbs {
        label: 'PoP LWBS Rate'
        formula: @aql safe_divide(lwbs_rate, lwbs_rate | relative_period(ed_visits.arrival_time, interval(-1 year), strict: true)) - 1;;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_lwbs_icon {
        label: 'Icon'
        formula: @aql case(when: metric_pop_lwbs < 0, then: "▼", else: "▲");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_lwbs_text {
        label: 'Text Color'
        formula: @aql case(when: metric_pop_lwbs < 0, then: "#1A8A52", else: "#C41A1A");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_lwbs_bg {
        label: 'BG'
        formula: @aql case(when: metric_pop_lwbs < 0, then: "#B6F5C8", else: "#ffe6e6");;
        calc_type: 'measure'
        data_type: 'text'
      }
      values: [
        VizFieldFull {
          ref: r(healthcare_overview.lwbs_rate)
          format {
            type: 'number'
            pattern: '#,###0.00\\%'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: 'metric_pop_lwbs'
          format {
            type: 'number'
            pattern: '#,###0.00%'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: 'metric_lwbs_icon'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'metric_lwbs_text'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          label: 'BG'
          ref: 'metric_lwbs_bg'
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
.kpi-ed-lwbs {
  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  border-radius: 8px;
  padding: 8px;
  padding-top: 16px;
  color: #4a4a6a;
  width: 100%;
  height: 100%;
  background: #CEF65F;
}
.kpi-title { font-size: 14px; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.9; }
.kpi-value-row { display: flex; align-items: flex-end; gap: 10px; margin-top: 280px; }
.kpi-value-lwbs { font-size: 56px; font-weight: 700; line-height: 1; }
.kpi-pill {
  background: {{ rows[0].values.`BG` }};
  padding: 4px 12px;
  border-radius: 999px;
  color: {{ rows[0].values.`Text Color` }};
  font-size: 12px;
  font-weight: 500;
  display: inline-flex;
  gap: 12px;
  margin-bottom: 8px;
}
.kpi-note { margin-top: 12px; opacity: 0.8; font-size: 14px; }
</style>

<div class="kpi-ed-lwbs">
  <div class="kpi-title">LWBS Rate</div>
  <div class="kpi-value-row">
    <div class="kpi-value-lwbs">{{ rows[0].values.`LWBS Rate (%)`.formatted }}</div>
    <div class="kpi-pill">{{ rows[0].values.`Icon`.formatted }} {{ rows[0].values.`PoP LWBS Rate`.formatted }}</div>
  </div>
  <div class="kpi-note">Significant increase compared to 2024, <br> especially in June and September. <br> A trend of high rate in March.</div>
</div>  ;;
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: neon_bg
  }
  block v_j5ob: VizBlock {
    label: 'Total ED Visits, PoP Comparison of Total ED Visits and 3 more copy copy copy copy copy copy copy copy copy copy'
    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation metric_8eb4f63 {
        label: 'PoP Comparison of Total Transfers'
        formula: @aql safe_divide(total_transfers, total_transfers | relative_period(transfers.transfer_datetime, interval(-1 year), strict: true)) - 1;;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_22053a3 {
        label: 'Text'
        formula: @aql case(
  when: metric_8eb4f63 < 0,
  then: "#1A8A52",
  else: "#C41A1A"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_b5da4bb {
        label: 'Icon'
        formula: @aql case(
  when: metric_8eb4f63 < 0,
  then: "▼",
  else: "▲"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_4cf891e {
        label: 'Classification of PoP Comparison of Total ED Visits'
        formula: @aql case(
  when: metric_8eb4f63 < 0,
  then: "#B6F5C8",
  else: "#ffe6e6"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      filter {
        field: r(transfers.transfer_datetime)
