  block v_99cq: VizBlock {
    label: 'Avg Satisfaction Score'
    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation metric_7dc183b {
        label: 'PoP Comparison of Avg Satisfaction Score'
        formula: @aql safe_divide(avg_satisfaction_score, avg_satisfaction_score | relative_period(satisfaction_surveys.survey_date, interval(-1 year), strict: true)) - 1;;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_b9a9776 {
        label: 'Up Down'
        formula: @aql case(
  when: metric_7dc183b > 0,
  then: "▲",
  else: "▼"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_845dd07 {
        label: 'Texxt Color'
        formula: @aql case(
  when: metric_7dc183b > 0,
  then: "#1A8A52",
  else: "#C41A1A"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_fe7d383 {
        label: 'BG Color'
        formula: @aql case(
  when: metric_7dc183b > 0,
  then: "#d8f7e8",
  else: "#ffe6e6"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      filter {
        field: r(satisfaction_surveys.survey_date)
        operator: 'matches'
        value: '2025'
      }
      values: [
        VizFieldFull {
          ref: r(healthcare_overview.avg_satisfaction_score)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
        },
        VizFieldFull {
          ref: 'metric_7dc183b'
          format {
            type: 'number'
            pattern: '#,###0.00%'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: 'metric_b9a9776'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'metric_845dd07'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'metric_fe7d383'
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
.kpi-card-reverse {
  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  border-radius: 8px;
  padding: 8px;
  padding-top: 16px;
