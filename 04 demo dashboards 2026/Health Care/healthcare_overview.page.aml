      ]
      content: @md <style>
.admission-card {
  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  background: #F1F1F3;
  border-radius: 20px;
  padding: 16px;
  color: #222;
  width: 100%;
}

.admission-title {
  font-size: 36px;
  font-weight: 700;
  line-height: 1.4;

  background: linear-gradient(270deg, #1f2937, #1f2937, #9ca3af);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

