Dashboard healthcare_overview_2 {
  title: 'Healthcare Overview'
  description: ''
  owner: 'giang.nv@holistics.io'
  block f_admissions_admission_date: FilterBlock {
    label: 'Admission date'
    type: 'field'
    source: FieldFilterSource {
      dataset: healthcare_overview
      field: r(admissions.admission_date)
    }
    default {
      operator: 'matches'
      value: '2025'
    }
    settings {
      hide_label: true
      hide_controls: true
    }
    theme: filter_block
  }
  block v_lmsg: VizBlock {
    label: 'Readmission Rate (%) compared with Readmission Rate (%) (Prev. 1y)'
    viz: MetricKpi {
      dataset: healthcare_overview
      value: VizFieldFull {
        ref: r(healthcare_overview.readmission_rate)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizPopSettings {
        field: r(admissions.admission_date)
        value: RelativePopValue {
          duration: 1
          granularity: 'year'
        }
      }
      settings {
        reverse_color: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        compare_value {
          reverse_color: true
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_jnaf: VizBlock {
    label: 'Avg Door-to-Doctor (min) compared with Avg Door-to-Doctor (min) (Prev. 1y) copy'
    viz: MetricKpi {
      dataset: healthcare_overview
      value: VizFieldFull {
        ref: r(healthcare_overview.avg_door_to_doctor)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizPopSettings {
        field: r(ed_visits.arrival_time)
        value: RelativePopValue {
          duration: 1
          granularity: 'year'
        }
      }
      settings {
        reverse_color: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        compare_value {
          reverse_color: true
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block f_ed_visits_arrival_time: FilterBlock {
    label: 'Ed visits Arrival time'
    type: 'field'
    source: FieldFilterSource {
      dataset: healthcare_overview
      field: r(ed_visits.arrival_time)
    }
    default {
      operator: 'matches'
      value: '2025'
    }
    settings {
      hide_label: true
    }
    theme: filter_block
  }
  block v_j1lh: VizBlock {
    label: 'Avg Door-to-Doctor (min) compared with Avg Door-to-Doctor (min) (Prev. 1y) copy copy'
    viz: MetricKpi {
      dataset: healthcare_overview
      value: VizFieldFull {
        ref: r(healthcare_overview.total_ed_visits)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizPopSettings {
        field: r(ed_visits.arrival_time)
        value: RelativePopValue {
          duration: 1
          granularity: 'year'
        }
      }
      settings {
        reverse_color: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        compare_value {
          reverse_color: true
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_ir83: VizBlock {
    label: 'Avg Door-to-Doctor (min) compared with Avg Door-to-Doctor (min) (Prev. 1y) copy copy'
    viz: MetricKpi {
      dataset: healthcare_overview
      value: VizFieldFull {
        ref: r(healthcare_overview.lwbs_rate)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizPopSettings {
        field: r(ed_visits.arrival_time)
        value: RelativePopValue {
          duration: 1
          granularity: 'year'
        }
      }
      settings {
        reverse_color: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        compare_value {
          reverse_color: true
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_xt3o: VizBlock {
    label: 'Avg Door-to-Doctor (min) compared with Avg Door-to-Doctor (min) (Prev. 1y) copy copy copy'
    viz: MetricKpi {
      dataset: healthcare_overview
      value: VizFieldFull {
        ref: r(healthcare_overview.avg_ed_los)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizPopSettings {
        field: r(ed_visits.arrival_time)
        value: RelativePopValue {
          duration: 1
          granularity: 'year'
        }
      }
      settings {
        reverse_color: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        compare_value {
          reverse_color: true
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_eqr1: VizBlock {
    label: 'Avg Door-to-Doctor (min) compared with Avg Door-to-Doctor (min) (Prev. 1y) copy copy copy copy'
    viz: MetricKpi {
      dataset: healthcare_overview
      value: VizFieldFull {
        ref: r(healthcare_overview.avg_door_to_triage)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizPopSettings {
        field: r(ed_visits.arrival_time)
        value: RelativePopValue {
          duration: 1
          granularity: 'year'
        }
      }
      settings {
        reverse_color: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        compare_value {
          reverse_color: true
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_s55p: VizBlock {
    label: 'Total ED Visits by Hour of Day and Day of Week Arrival time'
    viz: MarkdownViz {
      dataset: healthcare_overview
      rows: [
        VizFieldFull {
          ref: r(ed_visits.arrival_time)
          transformation: 'date_part hour'
          format {
            type: 'number'
            pattern: 'none'
          }
        }
      ]
      columns: [
        VizFieldFull {
          ref: r(ed_visits.arrival_time)
          transformation: 'date_part dow'
          format {
            type: 'number'
            pattern: 'dddd'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(healthcare_overview.total_ed_visits)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      content: @md <style>
* { box-sizing: border-box; }
.hm-wrapper {
  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  background: #262635;
  border-radius: 12px;
  padding: 16px;
}
.hm-topbar {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-top: 10px;
}
.hm-legend {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 600;
  color: rgba(255,255,255,0.6);
}
.hm-legend-strip { display: flex; gap: 4px; }
.hm-legend-swatch { width: 26px; height: 12px; border-radius: 3px; }
.hm-grid {
  display: grid;
  grid-template-columns: 28px repeat(7, 1fr);
  gap: 5px;
}
.hm-header {
  font-weight: 600;
  color: rgba(255,255,255,0.6);
  text-align: center;
  font-size: 11px;
  padding: 0 0 4px 0;
  letter-spacing: 0.02em;
  border: none;
  background: transparent;
}
.hm-row-label {
  font-weight: 600;
  color: rgba(255,255,255,0.65);
  font-size: 11px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 12px;
  background: transparent;
  border: none;
}
.hm-cell {
  --pct: 50;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 11px;
  color: #ffffff;
  background: color-mix(in oklab, #3760D6 calc(100% - var(--pct) * 1%), #FF8C42 calc(var(--pct) * 1%));
  transition: transform 0.12s, box-shadow 0.12s;
  cursor: default;
  border: none;
  outline: none;
}
.hm-cell:hover {
  transform: scale(1.08);
  box-shadow: 0 3px 10px rgba(0,0,0,0.5);
  z-index: 2;
  position: relative;
}
</style>

<div class="hm-wrapper">

<div class="hm-grid">

<div></div>
{% map(columns) %}
<div class="hm-header">{{ `Day of Week Arrival time` }}</div>
{% end %}

{% map(rows) %}
<div class="hm-row-label">{{ `Hour of Day Arrival time` }}</div>
{% map(values) %}
<div class="hm-cell" style="--pct: {{ value.`Total ED Visits`.raw }};">
{{ value.`Total ED Visits` }}
</div>
{% end %}
{% end %}

</div>

<div class="hm-topbar">
  <div class="hm-legend">
    <span>Low</span>
    <div class="hm-legend-strip">
      <div class="hm-legend-swatch" style="background:#3760D6;"></div>
      <div class="hm-legend-swatch" style="background:color-mix(in oklab,#3760D6 66%,#FF8C42 34%);"></div>
      <div class="hm-legend-swatch" style="background:color-mix(in oklab,#3760D6 33%,#FF8C42 67%);"></div>
      <div class="hm-legend-swatch" style="background:#FF8C42;"></div>
    </div>
    <span>High</span>
  </div>
</div>

</div>     ;;
      settings {
        show_row_total: true
        show_column_total: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    theme: dark_bg
  }
  block f_census_date: FilterBlock {
    label: 'Census date'
    type: 'field'
    source: FieldFilterSource {
      dataset: healthcare_overview
      field: r(bed_census.census_date)
    }
    default {
      operator: 'matches'
      value: '2025'
    }
    theme: filter_block
    settings {
      hide_label: true
    }
  }
  block v_1g2c: VizBlock {
    label: 'Bed Occupancy Rate (%) compared with Bed Occupancy Rate (%) (Prev. 1y)'
    viz: MetricKpi {
      dataset: healthcare_overview
      value: VizFieldFull {
        ref: r(healthcare_overview.bed_occupancy_rate)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizPopSettings {
        field: r(bed_census.census_date)
        value: RelativePopValue {
          duration: 1
          granularity: 'year'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_8akm: VizBlock {
    label: 'Bed Occupancy Rate (%) compared with Bed Occupancy Rate (%) (Prev. 1y) copy'
    viz: MetricKpi {
      dataset: healthcare_overview
      value: VizFieldFull {
        ref: r(healthcare_overview.total_beds)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizPopSettings {
        field: r(bed_census.census_date)
        value: RelativePopValue {
          duration: 1
          granularity: 'year'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_7obp: VizBlock {
    label: 'Bed Occupancy Rate (%) by Department'
    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation metric_5caf8d5 {
        label: 'Bar Color'
        formula: @aql case(when: bed_occupancy_rate < 85, then: "#C5D4F7", else: "#FF8C42");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_a40d0ef {
        label: 'Label Color'
        formula: @aql case(
  when: bed_occupancy_rate < 85,
  then: "#4a4a6a",
  else: "#C45A10"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      rows: [
        VizFieldFull {
          ref: r(bed_census.department)
          format {
            type: 'text'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(healthcare_overview.bed_occupancy_rate)
          format {
            type: 'number'
            pattern: '#,###'
          }
          uname: 'custom_bed_occupancy_rate_1'
        },
        VizFieldFull {
          ref: 'metric_5caf8d5'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'metric_a40d0ef'
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
.dc-chart-bed { font-family: system-ui, sans-serif; background: white; border-radius: 12px; margin-top:12px; }
.dc-row-bed { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
.dc-label-bed { width: 120px; font-size: 13px; font-weight: 500; text-align: right; }
.dc-bars-bed { flex: 1; position: relative; height: 40px; }
.dc-bar-bed { height: 100%; }
.dc-tline-bed { position: absolute; top: 0; bottom: 0; border-left: 1.5px dashed rgba(180,180,180,0.5); pointer-events: none; left: calc(85 / 100 * 100%); }
.dc-val-bed { font-size: 12px; color: black; margin-left: 6px; white-space: nowrap; min-width: 60px; }
.dc-xaxis-short-bed { display: flex; margin-left: 44px; margin-right: 66px; justify-content: space-between; font-size: 11px; color: black; padding-top: 4px; border-top: 0.5px solid rgba(0,0,0,0.1); }
</style>

<div class="dc-chart-bed">
<div style="margin-left: 132px; margin-right: 72px; position: relative; height: 18px;">
  <span style="position: absolute; left: calc(85 / 100 * 100%); transform: translateX(-50%); font-size: 11px; color: #8A8AAA; white-space: nowrap;">Target 85%</span>
</div>
<div style="position: relative;">
  <div style="position: absolute; left: calc(132px + (100% - 132px - 72px) * 85 / 100); top: 0; bottom: 0; border-left: 1.5px dashed #8A8AAA; pointer-events: none; z-index: 2;"></div>
  {% map(rows) %}
  <div class="dc-row-bed">
    <div class="dc-label-bed" style="color: {{ values.`Label Color` }};">
      {{ `Department` }}
    </div>
    <div class="dc-bars-bed">
      <div class="dc-bar-bed" style="width: calc({{ values.`Bed Occupancy Rate (%)`.raw }} / 100 * 100%); background: {{ values.`Bar Color` }};"></div>
    </div>
    <div class="dc-val-bed">{{ values.`Bed Occupancy Rate (%)` }}<span style="opacity: 0.4; font-size: 11px;">%</span></div>
  </div>
  {% end %}
</div>
<div class="dc-xaxis-short-bed" style="margin-left: 132px; margin-right: 72px;">
  <span>0</span><span>20</span><span>40</span><span>60</span><span>80</span><span>100</span>
</div>
</div>     ;;
      settings {
        show_row_total: true
        show_column_total: true
        sorts: [
          SortSetting {
            key: 'custom_bed_occupancy_rate_1'
            direction: 'desc'
          }
        ]
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_51qa: VizBlock {
    label: 'Readmission Rate (%) and PoP Comparison of Readmission Rate (%) by Month Admission date and Department copy'
    viz: LineChart {
      dataset: healthcare_overview
      calculation metric_80ff59a {
        label: 'PoP Comparison of Readmission Rate (%)'
        formula: @aql safe_divide(readmission_rate, readmission_rate | relative_period(admissions.admission_date, interval(-1 month), strict: true)) - 1;;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_d3d49df {
        label: 'PoP Comparison of Readmission Rate (%)'
        formula: @aql readmission_rate | relative_period(admissions.admission_date, interval(-1 year), strict: true);;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        ref: r(admissions.admission_date)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(healthcare_overview.readmission_rate)
            format {
              type: 'number'
              pattern: '#,###0.00\\%'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            line_interpolation: 'smooth'
            point {
              value: 'Cardiology'
              color: '#E2E1DD'
            }
            point {
              value: 'General_Surgery'
              color: '#E2E1DD'
            }
            point {
              value: 'ICU'
              color: '#E2E1DD'
            }
            point {
              value: 'Internal_Medicine'
              color: '#3760D6FF'
            }
            point {
              value: 'Maternity'
              color: '#E2E1DD'
            }
            point {
              value: 'Neurology'
              color: '#E2E1DD'
            }
            point {
              value: 'Oncology'
              color: '#3760D6FF'
            }
            point {
              value: 'Orthopedics'
              color: '#3760D6FF'
            }
            point {
              value: 'Pediatrics'
              color: '#E2E1DD'
            }
          }
        }
        series {
          field: ConstantVizField {
            label: 'Reference line of Readmission Rate'
            value: 15
            format {
              type: 'number'
              pattern: '#,###0.00\\%'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            color: '#4A4A6AFF'
            line_style: 'dashed'
          }
        }
      }
      settings {
        row_limit: 10000
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_1982: VizBlock {
    label: 'Readmission Rate (%) compared with Readmission Rate (%) (Prev. 1y) copy'
    viz: MetricKpi {
      dataset: healthcare_overview
      filter {
        field: r(admissions.is_readmission)
        operator: 'is'
        value: '1'
      }
      value: VizFieldFull {
        ref: r(healthcare_overview.avg_length_of_stay)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizPopSettings {
        field: r(admissions.admission_date)
        value: RelativePopValue {
          duration: 1
          granularity: 'year'
        }
      }
      settings {
        reverse_color: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        compare_value {
          reverse_color: true
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_qds7: VizBlock {
    label: 'Readmission Rate (%) compared with Readmission Rate (%) (Prev. 1y) copy copy'
    viz: MetricKpi {
      dataset: healthcare_overview
      filter {
        field: r(admissions.is_readmission)
        operator: 'is'
        value: '1'
      }
      value: VizFieldFull {
        ref: r(healthcare_overview.unique_patients)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizPopSettings {
        field: r(admissions.admission_date)
        value: RelativePopValue {
          duration: 1
          granularity: 'year'
        }
      }
      settings {
        reverse_color: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        compare_value {
          reverse_color: true
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_6xeu: VizBlock {
    label: 'Admission composition'
    viz: PieChart {
      dataset: healthcare_overview
      calculation metric_38d1148 {
        label: 'PoP Comparison of Total Admissions'
        formula: @aql safe_divide(total_admissions, total_admissions | relative_period(admissions.admission_date, interval(-1 year), strict: true)) - 1;;
        calc_type: 'measure'
        data_type: 'number'
      }
      legend: VizFieldFull {
        ref: r(admissions.admission_type)
        format {
          type: 'text'
        }
      }
      series {
        field: VizFieldFull {
          ref: r(healthcare_overview.total_admissions)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
        settings {
          point {
            value: 'Emergency'
            color: '#FF8C42FF'
          }
          point {
            value: 'Planned'
            color: '#3760D6FF'
          }
          point {
            value: 'Transfer_In'
            color: '#262635FF'
          }
        }
      }
      tooltips: [
        VizTooltip {
          field: VizFieldFull {
            ref: 'metric_38d1148'
            format {
              type: 'number'
              pattern: '#,###%'
            }
          }
        }
      ]
      settings {
        display_as_donut: true
        row_limit: 10000
        legend_label: 'hidden'
        show_percentage: true
        data_label_position: 'outside'
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_c9eu: VizBlock {
    label: 'Admission flow'
    viz: CustomChart {
      dataset: healthcare_overview
      custom_chart_id: 34892
      field source: VizFieldFull {
        ref: r(admissions.admission_type)
        format {
          type: 'text'
        }
      }
      field target: VizFieldFull {
        ref: r(admissions.department)
        format {
          type: 'text'
        }
      }
      field volume: VizFieldFull {
        ref: r(healthcare_overview.total_admissions)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      setting node_align: 'justify'
      setting node_width: 22
      setting node_padding: 7
      setting margin_top: 10
      setting margin_left: 10
      setting margin_right: 10
      setting margin_bottom: 10
      settings {
        row_limit: 10000
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_u1gk: VizBlock {
    label: 'Monthly admissions'
    viz: LineChart {
      dataset: healthcare_overview
      calculation metric_38d1148 {
        label: 'PoP Comparison of Total Admissions'
        formula: @aql safe_divide(total_admissions, total_admissions | relative_period(admissions.admission_date, interval(-1 year), strict: true)) - 1;;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        ref: r(admissions.admission_date)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      legend: VizFieldFull {
        ref: r(admissions.department)
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          axis_max: 73
          hidden: true
        }
        series {
          field: VizFieldFull {
            ref: r(healthcare_overview.total_admissions)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            line_interpolation: 'smooth'
            point {
              value: 'Cardiology'
              color: '#CEF65FFF'
              line_interpolation: 'smooth'
            }
            point {
              value: 'General_Surgery'
              color: '#718734FF'
              line_interpolation: 'smooth'
            }
            point {
              value: 'ICU'
              color: '#E2E1DD'
              line_interpolation: 'smooth'
            }
            point {
              value: 'Internal_Medicine'
              color: '#AFD151FF'
              line_interpolation: 'smooth'
            }
            point {
              value: 'Maternity'
              color: '#E2E1DD'
              line_interpolation: 'smooth'
            }
            point {
              value: 'Neurology'
              color: '#E2E1DD'
              line_interpolation: 'smooth'
            }
            point {
              value: 'Oncology'
              color: '#E2E1DD'
              line_interpolation: 'smooth'
            }
            point {
              value: 'Orthopedics'
              color: '#E2E1DD'
              line_interpolation: 'smooth'
            }
            point {
              value: 'Pediatrics'
              color: '#E2E1DD'
              line_interpolation: 'smooth'
            }
          }
        }
      }
      settings {
        row_limit: 10000
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_fos0: VizBlock {
    label: 'Readmission Rate (%) compared with Readmission Rate (%) (Prev. 1y) copy'
    viz: MetricKpi {
      dataset: healthcare_overview
      filter {
        field: r(admissions.department)
        operator: 'is'
        value: 'Oncology'
      }
      value: VizFieldFull {
        ref: r(healthcare_overview.readmission_rate)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_v4dl: VizBlock {
    label: 'readmission rate by department'
    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation metric_69e979c {
        label: 'Bar Color'
        formula: @aql case(when: readmission_rate < 15, then: "#C5D4F7", else: "#FF8C42");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_b1ee346 {
        label: 'Label Color'
        formula: @aql case(
  when: readmission_rate < 15,
  then: "#4a4a6a",
  else: "#C45A10"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      rows: [
        VizFieldFull {
          ref: r(admissions.department)
          format {
            type: 'text'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(healthcare_overview.readmission_rate)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
          uname: 'custom_readmission_rate_1'
        },
        VizFieldFull {
          ref: 'metric_69e979c'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'metric_b1ee346'
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
.dc-chart-readm { font-family: system-ui, sans-serif; background: white; border-radius: 12px; margin-top:12px; }
.dc-row-readm { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
.dc-label-readm { width: 120px; font-size: 13px; font-weight: 500; text-align: right; }
.dc-bars-readm { flex: 1; position: relative; height: 40px; }
.dc-bar-readm { height: 100%; }
.dc-val-readm { font-size: 12px; color: black; margin-left: 6px; white-space: nowrap; min-width: 60px; }
.dc-xaxis-short-readm { display: flex; margin-left: 132px; margin-right: 72px; justify-content: space-between; font-size: 11px; color: black; padding-top: 4px; border-top: 0.5px solid rgba(0,0,0,0.1); }
</style>

<div class="dc-chart-readm">
<div style="margin-left: 132px; margin-right: 84px; position: relative; height: 18px;">
  <span style="position: absolute; left: calc(15 / 25 * 100%); transform: translateX(-50%); font-size: 11px; color: #8A8AAA; white-space: nowrap;">Target 15%</span>
</div>
<div style="position: relative;">
  <div style="position: absolute; left: calc(132px + (100% - 132px - 84px) * 15 / 25); top: 0; bottom: 0; border-left: 1.5px dashed #8A8AAA; pointer-events: none; z-index: 2;"></div>
  {% map(rows) %}
  <div class="dc-row-readm">
    <div class="dc-label-readm" style="color: {{ values.`Label Color` }};">
      {{ `Department` }}
    </div>
    <div class="dc-bars-readm">
      <div class="dc-bar-readm" style="width: calc({{ values.`Readmission Rate (%)`.raw }} / 25 * 100%); background: {{ values.`Bar Color` }};"></div>
    </div>
    <div class="dc-val-readm">{{ values.`Readmission Rate (%)` }}<span style="opacity: 0.4; font-size: 11px;">%</span></div>
  </div>
  {% end %}
</div>
<div class="dc-xaxis-short-readm">
  <span>0</span><span>5</span><span>10</span><span>15</span><span>20</span><span>25</span>
</div>
</div>   ;;
      settings {
        show_row_total: true
        show_column_total: true
        sorts: [
          SortSetting {
            key: 'custom_readmission_rate_1'
            direction: 'desc'
          }
        ]
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
