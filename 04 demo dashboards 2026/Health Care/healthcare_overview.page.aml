            ref: r(healthcare_overview.lwbs_rate)
            format {
              type: 'number'
              pattern: '#,###0.00'
            }
          }
          settings {
            color: '#718734FF'
            line_interpolation: 'smooth'
          }
        }
        series {
          field: VizFieldFull {
            label: '2024 LWBS Rate (%)'
            ref: 'metric_58480a1'
            format {
              type: 'number'
              pattern: '#,###0.00'
            }
          }
          settings {
            color: '#AFD151FF'
            line_style: 'dashed'
            line_interpolation: 'smooth'
          }
        }
        series {
          field: VizFieldFull {
            label: '2025 LWBS Rate (%)'
            ref: 'metric_e053b4e'
            format {
              type: 'number'
              pattern: '#,###0.00'
            }
          }
          settings {
            color: '#CEF65FFF'
            line_style: 'dashed'
            line_interpolation: 'smooth'
          }
        }
      }
      settings {
        row_limit: 10000
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_vxb1: VizBlock {
    label: 'Avg Door-to-Doctor (min) by Hour of Day Arrival time'
    viz: LineChart {
      dataset: healthcare_overview
      x_axis: VizFieldFull {
        ref: r(ed_visits.arrival_time)
        transformation: 'date_part hour'
        format {
          type: 'number'
          pattern: 'none'
        }
      }
      y_axis {
        series {
