    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation metric_abd0944 {
        label: 'PoP Comparison of Total Beds'
        formula: @aql total_beds - (total_beds | relative_period(bed_census.census_date, interval(-1 year), strict: true));;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_204477f {
        label: 'PoP Comparison of Bed Occupancy Rate (%)'
        formula: @aql bed_occupancy_rate - (bed_occupancy_rate | relative_period(bed_census.census_date, interval(-1 year), strict: true));;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_74def4f {
        label: 'Arc X'
        formula: @aql 160 + 135 * cos(radians(180 - bed_occupancy_rate / 85.0 * 180));;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_438afe4 {
        label: 'Arc Y'
        formula: @aql 175 + 135 * sin(radians(180 - bed_occupancy_rate / 85.0 * 180));;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_0f095fd {
        label: 'Large Arc'
        formula: @aql case(when: bed_occupancy_rate > 42.5, then: "1", else: "0");;
