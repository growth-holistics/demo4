      content: @md <style>
.tab-header {
  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  background: #F1F1F3;
  border-radius: 20px;
  padding: 16px 20px;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.tab-header-title {
  font-size: 32px;
  font-weight: 700;
  background: linear-gradient(270deg, #1f2937, #1f2937, #9ca3af);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1.2;
}
.tab-header-badge {
  background: #262635;
  color: white;
  font-size: 12px;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 999px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
</style>
<div class="tab-header">
  <div class="tab-header-title">Readmission Analysis</div>
</div> ;;
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: no_bg
  }
  block v_j4e3: VizBlock {
    label: 'Percent of total of Total ED Visits by Classification of Triage level'
    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation dimension_f077c53 {
        label: 'Classification of Triage level'
        formula: @aql case(
  when: ed_visits.triage_level in ["Level_1_Resuscitation", "Level_2_Emergent"],
  then: "Critical",
  when: ed_visits.triage_level == "Level_3_Urgent",
  then: "Urgent",
  else: "Non-urgent"
);;
        calc_type: 'dimension'
        data_type: 'text'
        model: ed_visits
      }
      calculation metric_d3edeed {
        label: 'Percent of total of Total ED Visits'
        formula: @aql total_ed_visits | percent_of_total('column_total');;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_f0e8c08 {
        label: 'PoP Comparison of Percent of total of Total ED Visits'
        formula: @aql metric_d3edeed - (metric_d3edeed | relative_period(ed_visits.arrival_time, interval(-1 year), strict: true));;
        calc_type: 'measure'
        data_type: 'number'
      }
      filter {
        field: r(ed_visits.arrival_time)
        operator: 'matches'
        value: '2025'
      }
      rows: [
        VizFieldFull {
          ref: ref('ed_visits', 'dimension_f077c53')
          format {
            type: 'text'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: 'metric_d3edeed'
          format {
            type: 'number'
            pattern: '#,###%'
          }
        }
      ]
      content: @md <style>
.wrapper {
  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  background: transparent;
  margin-top: 16px;
}
.top {
  display: flex;
  margin-bottom: 4px;
}
.top-label {
  font-weight: 300;
  font-size: 28px;
  text-align: left;
}
.bar {
  display: flex;
  width: 100%;
  height: 56px;
}
.segment {
  display: flex;
  align-items: center;
  padding: 0 12px;
  white-space: nowrap;
  overflow: hidden;
}
.seg-label { font-weight: 700; font-size: 12px; margin-right: 6px; margin-top:20px; }
.seg-sub   { font-weight: 400; font-size: 12px; margin-right: 6px; margin-top:20px; opacity: 60%;}

.critical  { background: #0d1117; color: #FF8C42; }
.urgent    { background: #FF8C42; color: #5a3010; }
.nonurgent { background: #ffaf7b; color: #5a3010; }
</style>

<div class="wrapper">

  <!-- % LABELS ABOVE BAR -->
  <div class="top">
    <div class="top-label" style="width:15%; color:#0d1117;">{{ rows[0].values.`Percent of total of Total ED Visits` }}</div>
    <div class="top-label" style="width:34%; color:#FF8C42;">{{ rows[2].values.`Percent of total of Total ED Visits` }}</div>
    <div class="top-label" style="width:51%; color:#ffaf7b;">{{ rows[1].values.`Percent of total of Total ED Visits` }}</div>
  </div>

  <!-- BAR -->
  <div class="bar">
    <div class="segment critical" style="width:15%;">
      <span class="seg-label">{{ rows[0].`Classification of Triage level` }}</span>
      <span class="seg-sub">L1 &amp; L2</span>
    </div>
    <div class="segment urgent" style="width:34%;">
      <span class="seg-label">{{ rows[2].`Classification of Triage level` }}</span>
      <span class="seg-sub">L3</span>
    </div>
    <div class="segment nonurgent" style="width:51%;">
      <span class="seg-label">{{ rows[1].`Classification of Triage level` }}</span>
      <span class="seg-sub">L4 &amp; L5</span>
    </div>
  </div>

</div>      ;;
      settings {
        show_row_total: true
        show_column_total: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: no_bg
  }
  block v_lot3: VizBlock {
    label: 'Avg Door-to-Doctor (min), Bar Color, and Label Color by Triage level and Triage Level copy'
    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation dimension_557f2cb {
        label: 'Triage Level'
        formula: @aql case(
  when: ed_visits.triage_level == "Level_1_Resuscitation", then: "L1",
  when: ed_visits.triage_level == "Level_2_Emergent", then: "L2",
  when: ed_visits.triage_level == "Level_3_Urgent", then: "L3",
  when: ed_visits.triage_level == "Level_4_Less_Urgent", then: "L4",
  when: ed_visits.triage_level == "Level_5_Non_Urgent", then: "L5"
);;
        calc_type: 'dimension'
        data_type: 'text'
        model: ed_visits
      }
      calculation metric_a75b3cd {
        label: 'Bar Color'
        formula: @aql case(when: avg_door_to_triage <= 10, then: "#C5D4F7", else: "#FF8C42");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_191bd37 {
        label: 'Label Color'
        formula: @aql case(
  when: avg_door_to_triage <= 10,
  then: "#4a4a6a",
  else: "#C45A10"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      rows: [
        VizFieldFull {
          ref: r(ed_visits.triage_level)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('ed_visits', 'dimension_557f2cb')
          format {
            type: 'text'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(healthcare_overview.avg_door_to_doctor)
          format {
            type: 'number'
            pattern: '#,###'
          }
        },
        VizFieldFull {
          ref: 'metric_191bd37'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'metric_a75b3cd'
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
.dc-chart { font-family: system-ui, sans-serif; background: white; border-radius: 12px; }
.dc-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
.dc-label-short { width: 32px; font-size: 13px; font-weight: 500; text-align: right; }
.dc-bars { flex: 1; position: relative; height: 36px; }
.dc-bar { height: 100%; }
.dc-tline { position: absolute; top: 0; bottom: 0; border-left: 1.5px dashed rgba(180,180,180,0.5); pointer-events: none; left: calc(30 / 130 * 100%); }
.dc-val { font-size: 12px; color: black; margin-left: 6px; white-space: nowrap; min-width: 60px; }
.dc-xaxis-short { display: flex; margin-left: 44px; margin-right: 66px; justify-content: space-between; font-size: 11px; color: black; padding-top: 4px; border-top: 0.5px solid rgba(0,0,0,0.1); }
</style>

<div class="dc-chart">
  <div style="margin-left: 44px; margin-right: 66px; position: relative; height: 18px;">
  <span style="position: absolute; left: calc(30 / 120 * 100%); transform: translateX(-50%); font-size: 11px; color: #8A8AAA; white-space: nowrap;">Target</span>
</div>
<div style="position: relative;">
  <div style="position: absolute; left: calc(44px + (100% - 44px - 66px) * 30 / 120); top: 0; bottom: 0; border-left: 1.5px dashed #8A8AAA; pointer-events: none; z-index: 2;"></div>
  {% map(rows) %}
  <div class="dc-row">
    <div class="dc-label-short" style="color: {{ values.`Label Color` }};">
      {{ `Triage Level` }}
    </div>
    <div class="dc-bars">
      <div class="dc-bar" style="width: calc({{ values.`Avg Door-to-Doctor (min)`.raw }} / 120 * 100%); background: {{ values.`Bar Color` }};"></div>
    </div>
    <div class="dc-val">{{ values.`Avg Door-to-Doctor (min)` }} <span style="opacity: 0.4; font-size: 11px;">min</span></div>
  </div>
  {% end %}
  </div>
  <div class="dc-xaxis-short">
    <span>0</span><span>20</span><span>40</span><span>60</span><span>80</span><span>100</span><span>120</span>
  </div>
</div>      ;;
      settings {
