    theme: no_bg
  }
  block v_readmission_rate_kpi: VizBlock {
    label: 'Readmission Rate KPI - Dynamic'
    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation metric_pop_readm {
        label: 'PoP Readmission Rate'
        formula: @aql safe_divide(readmission_rate, readmission_rate | relative_period(admissions.admission_date, interval(-1 year), strict: true)) - 1;;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_readm_icon {
        label: 'Icon'
        formula: @aql case(when: metric_pop_readm < 0, then: "▼", else: "▲");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_readm_text {
        label: 'Text Color'
        formula: @aql case(when: metric_pop_readm < 0, then: "#1A8A52", else: "#C41A1A");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_readm_bg {
        label: 'BG'
        formula: @aql case(when: metric_pop_readm < 0, then: "#B6F5C8", else: "#ffe6e6");;
        calc_type: 'measure'
        data_type: 'text'
      }
      values: [
        VizFieldFull {
          ref: r(healthcare_overview.readmission_rate)
          format {
            type: 'number'
            pattern: '#,###0.00\\%'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: 'metric_pop_readm'
          format {
            type: 'number'
            pattern: '#,###0.00%'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: 'metric_readm_icon'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'metric_readm_text'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          label: 'BG'
          ref: 'metric_readm_bg'
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
.kpi-readm-primary {
  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  background: #3760D6;
  border-radius: 8px;
  padding: 8px;
  padding-top: 16px;
  color: white;
  width: 100%;
  height: 100%;
}
.kpi-readm-primary .kpi-title { font-size: 14px; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.9; }
.kpi-readm-primary .kpi-value {font-size: 56px;
  font-weight: 700;
  margin-top: 24px;}
.kpi-readm-primary .kpi-change-row { display: flex; align-items: center; gap: 10px; margin-top: 64px; }
.kpi-readm-primary .kpi-pill {
  background: white;
  padding: 4px 12px;
  border-radius: 999px;
  color: #3760D6;
  font-size: 12px;
  font-weight: 600;
}
.kpi-readm-primary .kpi-note { margin-top: 12px; opacity: 0.8; font-size: 14px; }
</style>
<div class="kpi-readm-primary">
  <div class="kpi-title">Readmission Rate</div>
  <div class="kpi-value">{{ rows[0].values.`Readmission Rate (%)`.formatted }}</div>
  <div class="kpi-change-row">
    <div class="kpi-pill">{{ rows[0].values.`Icon`.formatted }} {{ rows[0].values.`PoP Readmission Rate`.formatted }}</div>
  </div>
  <div class="kpi-note">Approaching CMS 15% benchmark</div>
</div>   ;;
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: primary_bg
  }
  block v_oncology_readmission_kpi: VizBlock {
    label: 'Oncology Readmission Rate KPI - Dynamic'
    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation metric_pop_onco {
        label: 'PoP Oncology Readmission Rate'
        formula: @aql safe_divide(readmission_rate, readmission_rate | relative_period(admissions.admission_date, interval(-1 year), strict: true)) - 1;;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_onco_icon {
        label: 'Icon'
        formula: @aql case(when: metric_pop_onco < 0, then: "▼", else: "▲");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_onco_text {
        label: 'Text Color'
        formula: @aql case(when: metric_pop_onco < 0, then: "#1A8A52", else: "#C41A1A");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_onco_bg {
        label: 'BG'
        formula: @aql case(when: metric_pop_onco < 0, then: "#B6F5C8", else: "#ffe6e6");;
        calc_type: 'measure'
        data_type: 'text'
      }
      filter {
        field: r(admissions.department)
        operator: 'top'
        value: 1
        options {
          rank_by {
            field: 'readmission_rate'
            aggregation: 'custom'
            logic: 'standard'
          }
        }
      }
      values: [
        VizFieldFull {
          ref: r(healthcare_overview.readmission_rate)
          format {
            type: 'number'
            pattern: '#,###0.00\\%'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: 'metric_pop_onco'
          format {
            type: 'number'
            pattern: '#,###0.00%'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: 'metric_onco_icon'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'metric_onco_text'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          label: 'BG'
          ref: 'metric_onco_bg'
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
.kpi-readm-secondary {
  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  background: white;
  border-radius: 8px;
  padding: 8px;
  padding-top: 16px;
  color: #4a4a6a;
  width: 100%;
  height: 100%;
}
.kpi-readm-secondary .kpi-label-row { display: flex; align-items: center; gap: 10px;}
.kpi-readm-secondary .kpi-title { font-size: 14px; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.9; }
.kpi-readm-secondary .kpi-dept-tag {
  display: inline-block;
  background: #EEF2FF;
  color: #3760D6;
  font-size: 11px;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 99px;
}
.kpi-readm-secondary .kpi-value-oncology {font-size: 56px;
  font-weight: 700;
  margin-top: 24px;}
.kpi-readm-secondary .kpi-change-row { display: flex; align-items: center; gap: 10px; margin-top: 64px; }
.kpi-readm-secondary .kpi-pill {
  background: {{ rows[0].values.`BG` }};
  padding: 4px 12px;
  border-radius: 999px;
  color: {{ rows[0].values.`Text Color` }};
  font-size: 12px;
  font-weight: 600;
}
.kpi-readm-secondary .kpi-note-oncology { margin-top: 100px; opacity: 0.8; font-size: 14px; }
</style>
<div class="kpi-readm-secondary">
<div class="kpi-label-row">
  <div class="kpi-title">Readmission Rate</div>
  <div class="kpi-dept-tag">Oncology</div>
</div>
  <div class="kpi-value-oncology">{{ rows[0].values.`Readmission Rate (%)`.formatted }}</div>
  <div class="kpi-note-oncology">Highest risk department</div>
</div>     ;;
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: white_bg
  }
  block v_readm_unique_patients_kpi: VizBlock {
    label: 'Unique Readmitted Patients KPI - Dynamic'
    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation metric_pop_readm_pts {
        label: 'PoP Unique Readmitted Patients'
        formula: @aql safe_divide(unique_patients, unique_patients | relative_period(admissions.admission_date, interval(-1 year), strict: true)) - 1;;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_readm_pts_icon {
        label: 'Icon'
        formula: @aql case(when: metric_pop_readm_pts < 0, then: "▼", else: "▲");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_readm_pts_text {
        label: 'Text Color'
        formula: @aql case(when: metric_pop_readm_pts < 0, then: "#1A8A52", else: "#C41A1A");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_readm_pts_bg {
        label: 'BG'
        formula: @aql case(when: metric_pop_readm_pts < 0, then: "#B6F5C8", else: "#ffe6e6");;
        calc_type: 'measure'
        data_type: 'text'
      }
      filter {
        field: r(admissions.is_readmission)
        operator: 'is'
        value: '1'
      }
      values: [
        VizFieldFull {
          ref: r(healthcare_overview.unique_patients)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: 'metric_pop_readm_pts'
          format {
            type: 'number'
            pattern: '#,###0.00%'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: 'metric_readm_pts_icon'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'metric_readm_pts_text'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          label: 'BG'
          ref: 'metric_readm_pts_bg'
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
.kpi-readm-secondary-one {
  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  background: #FF8C42;
  border-radius: 8px;
  padding: 8px;
  padding-top: 16px;
  color: #1a1a2e;
  width: 100%;
  height: 100%;
}
.kpi-readm-secondary-one .kpi-title { font-size: 14px; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.9; }
.kpi-readm-secondary-one .kpi-value {font-size: 56px;
  font-weight: 700;
  margin-top: 24px;}
.kpi-readm-secondary-one .kpi-change-row { display: flex; align-items: center; gap: 10px; margin-top: 64px; }
.kpi-readm-secondary-one .kpi-pill-one {
  background: #1a1a2e;
  padding: 4px 12px;
  border-radius: 999px;
  color: white;
  font-size: 12px;
  font-weight: 600;
}
.kpi-readm-secondary-one .kpi-note { margin-top: 12px; opacity: 0.8; font-size: 14px; }
</style>
<div class="kpi-readm-secondary-one">
  <div class="kpi-title">Unique Readmitted Patients</div>
  <div class="kpi-value">{{ rows[0].values.`Unique Patients`.formatted }}</div>
  <div class="kpi-change-row">
    <div class="kpi-pill-one">{{ rows[0].values.`Icon`.formatted }} {{ rows[0].values.`PoP Unique Readmitted Patients`.formatted }}</div>
  </div>
  <div class="kpi-note">Readmitted patients only</div>
</div>   ;;
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: orange_bg
  }
  block v_ed_header: VizBlock {
    label: 'ED Header Banner'
    viz: MarkdownViz {
      dataset: healthcare_overview
      values: [
        VizFieldFull {
          ref: r(healthcare_overview.total_ed_visits)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      content: @md <style>
.tab-header {
  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  background: #F1F1F3;
  border-radius: 20px;
  padding: 16px 16px;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.tab-header-title {
  font-size: 36px;
  font-weight: 700;
  background: linear-gradient(270deg, #1f2937, #1f2937, #9ca3af);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1.2;
}
.tab-header-badge {
  background: #FF8C42;
  color: white;
  font-size: 12px;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 999px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
</style>
<div class="tab-header">
  <div class="tab-header-title">Emergency Department</div>
</div>  ;;
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: no_bg
  }
