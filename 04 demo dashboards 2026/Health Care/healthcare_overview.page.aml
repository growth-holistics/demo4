        label: 'Icon'
        formula: @aql case(when: metric_pop_readm_alos < 0, then: "▼", else: "▲");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_readm_alos_text {
        label: 'Text Color'
        formula: @aql case(when: metric_pop_readm_alos < 0, then: "#1A8A52", else: "#C41A1A");;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_readm_alos_bg {
        label: 'BG'
        formula: @aql case(when: metric_pop_readm_alos < 0, then: "#B6F5C8", else: "#ffe6e6");;
        calc_type: 'measure'
        data_type: 'text'
      }
      filter {
        field: r(admissions.is_readmission)
        operator: 'is'
        value: '1'
      }
      values: [
        VizFieldFull {
          ref: r(healthcare_overview.avg_length_of_stay)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
        },
        VizFieldFull {
          ref: 'metric_pop_readm_alos'
          format {
            type: 'number'
            pattern: '#,###0.00%'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: 'metric_readm_alos_icon'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'metric_readm_alos_text'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          label: 'BG'
          ref: 'metric_readm_alos_bg'
          format {
            type: 'text'
          }
        }
      ]
