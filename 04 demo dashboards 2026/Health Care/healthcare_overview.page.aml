          }
          settings {
            point {
              value: 'Level_1_Resuscitation'
              color: '#262635FF'
            }
            point {
              value: 'Level_2_Emergent'
              color: '#8A8AAAFF'
            }
            point {
              value: 'Level_3_Urgent'
              color: '#CEF65FFF'
            }
            point {
              value: 'Level_4_Less_Urgent'
              color: '#AFD151FF'
            }
            point {
              value: 'Level_5_Non_Urgent'
              color: '#718734FF'
            }
          }
        }
      }
      settings {
        row_limit: 10000
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
