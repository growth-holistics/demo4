  block v_0h58: VizBlock {
    label: 'L5 has the highest LWBS rate'
    viz: MarkdownViz {
      dataset: healthcare_overview
      calculation metric_8eb4f63 {
        label: 'PoP Comparison of Total ED Visits'
        formula: @aql safe_divide(total_ed_visits, total_ed_visits | relative_period(ed_visits.arrival_time, interval(-1 year), strict: true)) - 1;;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_22053a3 {
        label: 'Text'
        formula: @aql case(
  when: metric_8eb4f63 < 0,
  then: "#1A8A52",
  else: "#C41A1A"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_b5da4bb {
        label: 'Icon'
        formula: @aql case(
  when: metric_8eb4f63 < 0,
  then: "▼",
  else: "▲"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      calculation metric_4cf891e {
        label: 'Classification of PoP Comparison of Total ED Visits'
        formula: @aql case(
  when: metric_8eb4f63 < 0,
  then: "#d8f7e8",
  else: "#fff1f1"
);;
        calc_type: 'measure'
        data_type: 'text'
      }
      filter {
        field: r(ed_visits.triage_level)
        operator: 'top'
        value: 1
        options {
          rank_by {
            field: 'lwbs_rate'
            aggregation: 'custom'
            logic: 'standard'
          }
        }
