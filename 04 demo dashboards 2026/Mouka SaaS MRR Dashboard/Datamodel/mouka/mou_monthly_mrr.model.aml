  dimension exp_spark_y {
    label: 'Exp Spark Y'
    description: 'SVG y-coordinate for Expansion MRR sparkline.'
    type: 'number'
    definition: @sql {{ #SOURCE.exp_spark_y }};;
  }
  dimension churn_spark_y {
    label: 'Churn Spark Y'
    description: 'SVG y-coordinate for Churn MRR sparkline (uses absolute value).'
    type: 'number'
    definition: @sql {{ #SOURCE.churn_spark_y }};;
  }
  dimension net_new_spark_y {
    label: 'Net New Spark Y'
    description: 'SVG y-coordinate for Net New MRR sparkline.'
    type: 'number'
    definition: @sql {{ #SOURCE.net_new_spark_y }};;
  }
  dimension new_logo_delta {
    label: 'New Logo Delta'
    description: 'MoM change in New Logo MRR ($). Example: +$2,000'
    type: 'number'
    definition: @sql {{ #SOURCE.new_logo_delta }};;
  }
  dimension exp_delta {
    label: 'Exp Delta'
    description: 'MoM change in Expansion MRR ($). Example: -$500'
    type: 'number'
    definition: @sql {{ #SOURCE.exp_delta }};;
  }
  dimension churn_delta {
    label: 'Churn Delta'
    description: 'MoM change in absolute Churn MRR ($). Positive = more churn. Example: +$1,200'
    type: 'number'
    definition: @sql {{ #SOURCE.churn_delta }};;
  }
  dimension contr_spark_y {
    label: 'Contr Spark Y'
    description: 'SVG y-coordinate for Contraction MRR sparkline (uses absolute value).'
    type: 'number'
    definition: @sql {{ #SOURCE.contr_spark_y }};;
  }
  dimension contr_delta {
    label: 'Contr Delta'
    description: 'MoM change in absolute Contraction MRR ($). Positive = more contraction. Example: +$800'
    type: 'number'
    definition: @sql {{ #SOURCE.contr_delta }};;
  }
  dimension net_new_delta {
    label: 'Net New Delta'
    description: 'MoM change in Net New MRR ($). Example: +$3,000'
    type: 'number'
    definition: @sql {{ #SOURCE.net_new_delta }};;
  }

  // ── Tab 2: MoM percentage, sign, color, abs deltas ────────────────────────
  dimension new_logo_pct {
