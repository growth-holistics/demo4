    type: 'number'
    definition: @sql {{ #SOURCE.nrr_delta }};;
  }
  dimension cust_churn_delta {
    label: 'Cust Churn Delta (pp)'
    description: 'MoM change in Customer Churn Rate (percentage points). Example: -0.2 pp'
    type: 'number'
    definition: @sql {{ #SOURCE.cust_churn_delta }};;
  }
  dimension gross_churn_badge_color {
    label: 'Gross Churn Badge Color'
