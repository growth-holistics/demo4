    label: 'Exp YoY Color'
    type: 'text'
    definition: @sql {{ #SOURCE.exp_yoy_color }};;
  }
  dimension gross_churn_yoy_pct {
    label: 'Gross Churn YoY %'
    type: 'number'
    definition: @sql {{ #SOURCE.gross_churn_yoy_pct }};;
  }
  dimension gross_churn_yoy_sign {
    label: 'Gross Churn YoY Sign'
    type: 'text'
    definition: @sql {{ #SOURCE.gross_churn_yoy_sign }};;
  }
  dimension gross_churn_yoy_color {
    label: 'Gross Churn YoY Color'
    type: 'text'
    definition: @sql {{ #SOURCE.gross_churn_yoy_color }};;
  }
  dimension churn_yoy_pct {
    label: 'Churn YoY %'
    type: 'number'
    definition: @sql {{ #SOURCE.churn_yoy_pct }};;
  }
  dimension churn_yoy_sign {
    label: 'Churn YoY Sign'
    type: 'text'
    definition: @sql {{ #SOURCE.churn_yoy_sign }};;
  }
  dimension churn_yoy_color {
    label: 'Churn YoY Color'
    type: 'text'
    definition: @sql {{ #SOURCE.churn_yoy_color }};;
  }
  dimension contr_yoy_pct {
    label: 'Contr YoY %'
    type: 'number'
    definition: @sql {{ #SOURCE.contr_yoy_pct }};;
  }
  dimension contr_yoy_sign {
    label: 'Contr YoY Sign'
    type: 'text'
    definition: @sql {{ #SOURCE.contr_yoy_sign }};;
  }
  dimension contr_yoy_color {
    label: 'Contr YoY Color'
    type: 'text'
    definition: @sql {{ #SOURCE.contr_yoy_color }};;
  }
  dimension qr_yoy_pct {
    label: 'QR YoY %'
    type: 'number'
    definition: @sql {{ #SOURCE.qr_yoy_pct }};;
  }
  dimension qr_yoy_sign {
    label: 'QR YoY Sign'
    type: 'text'
    definition: @sql {{ #SOURCE.qr_yoy_sign }};;
  }
  dimension qr_yoy_color {
    label: 'QR YoY Color'
    type: 'text'
    definition: @sql {{ #SOURCE.qr_yoy_color }};;
  }
  dimension mrr_yoy_pct {
    label: 'MRR YoY %'
    type: 'number'
    definition: @sql {{ #SOURCE.mrr_yoy_pct }};;
  }
  dimension mrr_yoy_sign {
    label: 'MRR YoY Sign'
    type: 'text'
    definition: @sql {{ #SOURCE.mrr_yoy_sign }};;
  }
  dimension mrr_yoy_color {
    label: 'MRR YoY Color'
    type: 'text'
    definition: @sql {{ #SOURCE.mrr_yoy_color }};;
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // MEASURES — AQL aggregations for use in charts and KPI cards
  // Two groups:
  //   1. Aggregation measures (sum/avg) — for time-series charts
  //   2. Latest-month measures (max_by) — for KPI cards showing current value
  //   3. Sparkline/badge measures — for MarkdownViz KPI rendering
  // ═══════════════════════════════════════════════════════════════════════════

  // ── 1. Aggregation Measures (for time-series charts) ────────────────────────

  // Formula: SUM(total_mrr) — Total MRR across selected months
  measure sum_total_mrr {
    label: 'Total MRR'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.total_mrr);;
  }
  // Formula: SUM(net_new_mrr) — Cumulative net new MRR
  measure sum_net_new_mrr {
    label: 'Net New MRR'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.net_new_mrr);;
  }
  measure abs_net_new_mrr {
    label: 'Net New MRR Abs'
    type: 'number'
    definition: @aql abs(sum(mou_monthly_mrr.net_new_mrr));;
  }
  // Formula: SUM(new_logo_mrr) — Total new customer MRR
  measure sum_new_logo {
    label: 'New Logo MRR'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.new_logo_mrr);;
  }
  // Formula: SUM(expansion_mrr) — Total upgrade MRR
  measure sum_expansion {
    label: 'Expansion MRR'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.expansion_mrr);;
  }
  // Formula: SUM(contraction_mrr) — Total downgrade MRR (negative)
  measure sum_contraction {
    label: 'Contraction MRR'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.contraction_mrr);;
  }
  // Formula: SUM(churn_mrr) — Total churned MRR (negative)
  measure sum_churn {
    label: 'Churn MRR'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.churn_mrr);;
  }
  dimension abs_churn_mrr {
    label: 'Churn MRR Abs'
    type: 'number'
    definition: @sql ABS({{ #SOURCE.churn_mrr }});;
  }
  measure abs_sum_churn {
    label: 'Churn MRR Abs'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.abs_churn_mrr);;
  }
  measure sum_net_expansion_pos {
    label: 'Net Expansion (+)'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.net_expansion_pos);;
  }
  measure sum_net_expansion_neg {
    label: 'Net Expansion (-)'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.net_expansion_neg);;
  }
  measure abs_contraction {
    label: 'Contraction Abs'
    type: 'number'
    definition: @aql abs(sum(mou_monthly_mrr.contraction_mrr));;
  }
  measure abs_churn {
    label: 'Churn Abs'
    type: 'number'
    definition: @aql abs(sum(mou_monthly_mrr.churn_mrr));;
  }
  // Formula: SUM(paid_customers) — Total customers across months
  measure sum_paid_customers {
    label: 'Paid Customers'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.paid_customers);;
  }
  // Formula: SUM(high_value_customers) — Total high-value customers
  measure sum_high_value_customers {
    label: 'Customers >= $1K MRR'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.high_value_customers);;
  }
  // Formula: SUM(arpa) — Sum of ARPA values
  measure sum_arpa {
    label: 'ARPA'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.arpa);;
  }
  // Formula: SUM(arr) — Sum of ARR values
  measure sum_arr {
    label: 'ARR'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.arr);;
  }
  // Formula: AVG(gross_churn_rate) — Average gross churn rate
  measure avg_gross_churn_rate {
    label: 'Gross Churn Rate %'
    type: 'number'
    definition: @aql avg(mou_monthly_mrr.gross_churn_rate);;
  }
  // Formula: AVG(net_churn_rate) — Average net churn rate
  measure avg_net_churn_rate {
    label: 'Net Churn Rate %'
    type: 'number'
    definition: @aql avg(mou_monthly_mrr.net_churn_rate);;
  }
  // Formula: AVG(nrr) — Average NRR
  measure avg_nrr {
    label: 'NRR %'
    type: 'number'
    definition: @aql avg(mou_monthly_mrr.nrr);;
  }
  // Formula: AVG(customer_churn_rate) — Average logo churn
  measure avg_customer_churn_rate {
    label: 'Customer Churn Rate %'
    type: 'number'
    definition: @aql avg(mou_monthly_mrr.customer_churn_rate);;
  }
  // Formula: AVG(quick_ratio) — Average Quick Ratio
  measure avg_quick_ratio {
    label: 'Quick Ratio'
    type: 'number'
    definition: @aql avg(mou_monthly_mrr.quick_ratio);;
  }
  // Formula: AVG(paid_customer_growth_rate) — Average customer growth
  measure avg_paid_customer_growth {
    label: 'Paid Customer Growth %'
    type: 'number'
    definition: @aql avg(mou_monthly_mrr.paid_customer_growth_rate);;
  }

  // ── 2. Latest-Month Measures (for KPI cards) ───────────────────────────────
  // max_by(model, value_field, date_field) returns the value from the most recent month

  // Gets Total MRR of the latest month
  measure latest_total_mrr {
    label: 'Latest Total MRR'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.total_mrr, mou_monthly_mrr.month);;
  }
  // Gets ARR of the latest month
  measure latest_arr {
    label: 'Latest ARR'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.arr, mou_monthly_mrr.month);;
  }
  // Gets Paid Customers of the latest month
  measure latest_paid_customers {
    label: 'Latest Paid Customers'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.paid_customers, mou_monthly_mrr.month);;
  }
  // Gets Net New MRR of the latest month
  measure latest_net_new_mrr {
    label: 'Latest Net New MRR'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.net_new_mrr, mou_monthly_mrr.month);;
  }
  // Gets New Logo MRR of the latest month
  measure latest_new_logo_mrr {
    label: 'Latest New Logo MRR'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.new_logo_mrr, mou_monthly_mrr.month);;
  }
  // Gets Expansion MRR of the latest month
  measure latest_expansion_mrr {
    label: 'Latest Expansion MRR'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.expansion_mrr, mou_monthly_mrr.month);;
  }
  // Gets Churn MRR of the latest month (negative value)
  measure latest_churn_mrr {
    label: 'Latest Churn MRR'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.churn_mrr, mou_monthly_mrr.month);;
  }
  // Gets Gross Churn Rate of the latest month
  measure latest_gross_churn_rate {
    label: 'Latest Gross Churn Rate %'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.gross_churn_rate, mou_monthly_mrr.month);;
  }
  // Gets Net Churn Rate of the latest month
  measure latest_net_churn_rate {
    label: 'Latest Net Churn Rate %'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.net_churn_rate, mou_monthly_mrr.month);;
  }
  // Gets NRR of the latest month
  measure latest_nrr {
    label: 'Latest NRR %'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.nrr, mou_monthly_mrr.month);;
  }
  // Gets Customer Churn Rate of the latest month
  measure latest_customer_churn_rate {
    label: 'Latest Customer Churn Rate %'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.customer_churn_rate, mou_monthly_mrr.month);;
  }
  // Gets ARPA of the latest month
  measure latest_arpa {
    label: 'Latest ARPA'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.arpa, mou_monthly_mrr.month);;
  }
  // Gets Quick Ratio of the latest month
  measure latest_quick_ratio {
    label: 'Latest Quick Ratio'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.quick_ratio, mou_monthly_mrr.month);;
  }
  // Gets High Value Customers of the latest month
  measure latest_high_value_customers {
    label: 'Latest Customers >= $1K MRR'
    type: 'number'
    definition: @aql max_by(mou_monthly_mrr, mou_monthly_mrr.high_value_customers, mou_monthly_mrr.month);;
  }

  // ── 3. MarkdownViz KPI Sparkline Measures ──────────────────────────────────
  // These power the inline SVG sparklines rendered in MarkdownViz KPI cards.
  // Each measure surfaces a per-row rendering value (y-coordinate, color, delta)
  // for the MarkdownViz template to consume.

  // Tab 1: MRR sparkline values
  measure val_mrr_delta_mom {
    label: 'MRR Delta MoM'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.net_new_mrr);;
  }
  measure val_mrr_growth_pct {
    label: 'MRR Growth %'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.mrr_growth_rate);;
  }
  measure abs_mrr_growth_pct {
    label: 'MRR Growth % Abs'
    type: 'number'
    definition: @aql abs(sum(mou_monthly_mrr.mrr_growth_rate));;
  }
  measure val_mrr_color {
    label: 'MRR Color'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.mrr_color);;
  }
  measure val_mrr_amount_sign {
    label: 'MRR Amount Sign'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.mrr_amount_sign);;
  }
  measure val_mrr_sign {
    label: 'MRR Sign'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.mrr_sign);;
  }
  measure val_mrr_spark_x {
    label: 'MRR Spark X'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.mrr_spark_x);;
  }
  measure val_mrr_spark_y {
    label: 'MRR Spark Y'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.mrr_spark_y);;
  }
  measure val_mrr_bar_height {
    label: 'MRR Bar Height'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.mrr_bar_height);;
  }

  // Tab 1: Paid Customers sparkline values
  measure val_cust_spark_y {
    label: 'Cust Spark Y'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.cust_spark_y);;
  }
  measure val_cust_delta_12mo {
    label: 'Cust Delta 12mo'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.cust_delta_12mo);;
  }
  measure abs_cust_delta_12mo {
    label: 'Cust Delta 12mo Abs'
    type: 'number'
    definition: @aql abs(sum(mou_monthly_mrr.cust_delta_12mo));;
  }
  measure val_cust_color {
    label: 'Cust Color'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.cust_color);;
  }
  measure val_cust_sign {
    label: 'Cust Sign'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.cust_sign);;
  }

  // Tab 2: Movement sparkline values
  measure val_new_logo_spark_y {
    label: 'New Logo Spark Y'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.new_logo_spark_y);;
  }
  measure val_exp_spark_y {
    label: 'Exp Spark Y'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.exp_spark_y);;
  }
  measure val_churn_spark_y {
    label: 'Churn Spark Y'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.churn_spark_y);;
  }
  measure val_net_new_spark_y {
    label: 'Net New Spark Y'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.net_new_spark_y);;
  }
  measure val_new_logo_delta {
    label: 'New Logo Delta'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.new_logo_delta);;
  }
  measure val_exp_delta {
    label: 'Exp Delta'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.exp_delta);;
  }
  measure val_churn_delta {
    label: 'Churn Delta'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.churn_delta);;
  }
  measure val_contr_spark_y {
    label: 'Contr Spark Y'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.contr_spark_y);;
  }
  measure val_contr_delta {
    label: 'Contr Delta'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.contr_delta);;
  }
  measure val_net_new_delta {
    label: 'Net New Delta'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.net_new_delta);;
  }

  // Tab 2: MoM percentage, sign, color, abs measures
  measure val_new_logo_sign {
    label: 'New Logo Sign'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.new_logo_sign);;
  }
  measure val_new_logo_badge_color {
    label: 'New Logo Badge Color'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.new_logo_badge_color);;
  }
  measure val_abs_new_logo_delta {
    label: 'New Logo Delta Abs'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.abs_new_logo_delta);;
  }
  measure val_abs_new_logo_pct {
    label: 'New Logo Pct Abs'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.abs_new_logo_pct);;
  }
  measure val_exp_sign {
    label: 'Exp Sign'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.exp_sign);;
  }
  measure val_exp_badge_color {
    label: 'Exp Badge Color'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.exp_badge_color);;
  }
  measure val_abs_exp_delta {
    label: 'Exp Delta Abs'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.abs_exp_delta);;
  }
  measure val_abs_exp_pct {
    label: 'Exp Pct Abs'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.abs_exp_pct);;
  }
  measure val_churn_sign {
    label: 'Churn Sign'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.churn_sign);;
  }
  measure val_churn_badge_color {
    label: 'Churn Badge Color'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.churn_badge_color);;
  }
  measure val_abs_churn_delta {
    label: 'Churn Delta Abs'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.abs_churn_delta);;
  }
  measure val_abs_churn_pct {
    label: 'Churn Pct Abs'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.abs_churn_pct);;
  }
  measure val_contr_sign {
    label: 'Contr Sign'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.contr_sign);;
  }
  measure val_contr_badge_color {
    label: 'Contr Badge Color'
    type: 'text'
    definition: @aql max(mou_monthly_mrr.contr_badge_color);;
  }
  measure val_abs_contr_delta {
    label: 'Contr Delta Abs'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.abs_contr_delta);;
  }
  measure val_abs_contr_pct {
    label: 'Contr Pct Abs'
    type: 'number'
    definition: @aql sum(mou_monthly_mrr.abs_contr_pct);;
  }
  measure val_new_logo_badge_bg {
    label: 'New Logo Badge Bg'
    type: 'text'
