  block t2_movement: VizBlock {
    label: 'MRR Movement by Month'
    viz: CombinationChart {
      dataset: mouka_mrr
      calculation metric_42bea21 {
        label: 'Net New MRR'
        formula: @aql avg(mou_monthly_mrr.net_new_mrr);;
        calc_type: 'measure'
        data_type: 'number'
      }
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: 13
        modifier: 'month'
      }
      x_axis: VizFieldFull {
        ref: r(mou_monthly_mrr.month)
        format {
          type: 'date'
          pattern: 'MMM yy'
        }
      }
      y_axis {
        settings {
          stack_series_by: 'value'
        }
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.sum_new_logo)
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#9999FF'
          }
        }
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.sum_expansion)
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#7FE1D8'
          }
        }
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.sum_churn)
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#E1643F'
          }
        }
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.sum_contraction)
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#FAC666'
          }
        }
      }
      y_axis {
        settings {
          alignment: 'right'
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            ref: 'metric_42bea21'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#d5f5cc'
          }
        }
      }
      settings {
        row_limit: 5000
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    theme: spacer_block_theme
  }
  block t2_new_vs_churn: VizBlock {
    label: 'New Logo vs Churned MRR'
    viz: CombinationChart {
      dataset: mouka_mrr
      calculation abs_churned {
        label: 'Churned MRR (abs)'
        formula: @aql -1 * sum(mou_monthly_mrr.churn_mrr);;
        calc_type: 'measure'
        data_type: 'number'
      }
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: 13
        modifier: 'month'
      }
      x_axis: VizFieldFull {
        ref: r(mou_monthly_mrr.month)
        format {
          type: 'date'
          pattern: 'MMM yy'
        }
      }
      y_axis {
        series {
          mark_type: 'area'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.sum_new_logo)
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#BAB4F9FF'
            line_interpolation: 'smooth'
          }
        }
        series {
          mark_type: 'area'
          field: VizFieldFull {
            ref: 'abs_churned'
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#F3A59BFF'
            line_interpolation: 'smooth'
          }
        }
      }
      settings {
        row_limit: 5000
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    theme: viz_card_theme
  }
