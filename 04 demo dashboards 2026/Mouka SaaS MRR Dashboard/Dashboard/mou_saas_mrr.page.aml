          mark_type: 'line'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.avg_net_churn_rate)
            format {
              type: 'number'
              pattern: "#,##0.0#'%'"
            }
          }
          settings {
            color: '#FAC666'
          }
        }
      }
      settings {
        row_limit: 5000
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    theme: viz_card_theme
  }
  block t3_cust_churn_trend: VizBlock {
    label: 'Customer Churn Rate'
