  block t4_plan_cards: VizBlock {
    label: 'MRR by Plan Tier'
    viz: MarkdownViz {
      dataset: mouka_mrr
      filter {
        field: r(mou_mrr_by_plan.plan_name)
        operator: 'is_not'
        value: 'trial'
      }
      rows: [
        VizFieldFull {
          ref: r(mou_mrr_by_plan.plan_name)
          format {
            type: 'text'
          }
        }
      ]
      values: [
        VizFieldFull {
          label: 'MRR'
          ref: r(mou_mrr_by_plan.sum_mrr)
          format {
            type: 'number'
            pattern: '[$$]#,###0'
          }
        },
        VizFieldFull {
          label: 'MRR %'
          ref: r(mou_mrr_by_plan.avg_mrr_pct)
          format {
            type: 'number'
            pattern: '#,##0.0'
          }
          uname: 'custom_avg_mrr_pct_1'
        }
      ]
      content: @md <style>
  .plan-cards { display: flex; flex-direction: column; gap: 36px; padding: 48px 16px; font-family: 'Outfit', sans-serif; }
  .plan-card { width: 100%; }
  .plan-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .plan-swatch { width: 18px; height: 18px; border-radius: 4px; flex-shrink: 0; }
  .plan-name { font-size: 20px; font-weight: 550; color: #848484; flex: 1; }
  .plan-mrr { font-size: 24px; font-weight: 600; color: #423935; font-family: 'inter'; }
  .plan-pct { font-size: 24px; font-weight: 550; font-family: 'inter'e; margin-left: 16px; }
  .plan-bar-track { width: 100%; height: 14px; background: #F5F5F5; border-radius: 7px; overflow: hidden; }
  .plan-bar-fill { height: 100%; border-radius: 7px; transition: width 0.8s ease; }
</style>

<div class="plan-cards">
  <!-- Business (row 0 — highest MRR %) -->
  <div class="plan-card">
    <div class="plan-header">
      <div class="plan-swatch" style="background:#95D2FF"></div>
      <span class="plan-name">Business</span>
      <span class="plan-mrr">{{ rows[0].values.`MRR` }}</span>
      <span class="plan-pct" style="color:#67BEFF">{{ rows[0].values.`MRR %` }}%</span>
    </div>
    <div class="plan-bar-track">
      <div class="plan-bar-fill" style="background:#95D2FF; width:{{ rows[0].values.`MRR %` }}%"></div>
    </div>
  </div>

  <!-- Enterprise (row 1) -->
  <div class="plan-card">
    <div class="plan-header">
      <div class="plan-swatch" style="background:#FF82A7"></div>
      <span class="plan-name">Enterprise</span>
      <span class="plan-mrr">{{ rows[1].values.`MRR` }}</span>
      <span class="plan-pct" style="color:#F45F8B">{{ rows[1].values.`MRR %` }}%</span>
    </div>
    <div class="plan-bar-track">
      <div class="plan-bar-fill" style="background:#FF82A7; width:{{ rows[1].values.`MRR %` }}%"></div>
    </div>
  </div>

  <!-- Standard (row 2 — lowest MRR %) -->
  <div class="plan-card">
    <div class="plan-header">
      <div class="plan-swatch" style="background:#7FE1D8"></div>
      <span class="plan-name">Standard</span>
      <span class="plan-mrr">{{ rows[2].values.`MRR` }}</span>
      <span class="plan-pct" style="color:#38CBBD">{{ rows[2].values.`MRR %` }}%</span>
    </div>
    <div class="plan-bar-track">
      <div class="plan-bar-fill" style="background:#7FE1D8; width:{{ rows[2].values.`MRR %` }}%"></div>
    </div>
  </div>
</div>
 ;;
      settings {
        sorts: [
          SortSetting {
            key: 'custom_avg_mrr_pct_1'
            direction: 'desc'
          }
        ]
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    theme: viz_card_theme
  }
