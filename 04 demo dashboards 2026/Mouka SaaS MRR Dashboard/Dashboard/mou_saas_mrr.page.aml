Dashboard mou_saas_mrr {
  title: 'Mouka — MRR Dashboard'
  description: 'Track MRR health, revenue movements, churn risk, and customer diversification'
  theme: mouka_theme
  block t1_kpi_mrr: VizBlock {
    label: 'Total MRR KPI'
    viz: MarkdownViz {
      dataset: mouka_mrr
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: '1'
        modifier: 'month'
      }
      rows: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.month)
          format {
            type: 'date'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.sum_net_new_mrr)
          format {
            type: 'number'
            pattern: '#,###0.##'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_growth_pct)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.sum_total_mrr)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_color)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_amount_sign)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_sign)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_spark_x)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_spark_y)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_bar_height)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.abs_net_new_mrr)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.abs_mrr_growth_pct)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
        }
      ]
      content: @md <style>
  

  }
</style>

<div>
  <p class="mrr-title">Total MRR</p>

  
  <div class="mrr-value"><span style="font-size:20px;font-weight:600;color:#978A81;margin-right:6px;">$</span>{{ rows[-1].values.`Total MRR` }}</div>
  <div class="mrr-footer">
    <span class="mrr-badge" style="
      background: #FFF6F4;
      color: #CE5531;
    ">
      {{ rows[-1].values.`MRR Sign` }} {{ rows[-1].values.`Net New MRR Abs` }}
      ({{ rows[-1].values.`MRR Growth % Abs` }}%)
    </span>
    vs last month
  </div>


</div>                       ;;
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: viz_card_theme
  }
  block t1_kpi_cust: VizBlock {
    label: 'Paid Customers KPI'
    viz: MarkdownViz {
      dataset: mouka_mrr
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: '1'
        modifier: 'month'
      }
      rows: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.month)
          format {
            type: 'date'
            pattern: 'MMM yyyy'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.sum_paid_customers)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_cust_delta_mom)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_cust_mom_color)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_cust_mom_sign)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_spark_x)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_cust_spark_y)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      content: @md <style>
  .mrr-title {
    margin: 0;
    color: #978A81;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    

  }
  .mrr-value {
    font-size: 36px;
    font-weight: 700;
    color: #423935;
    margin-top: 8px;
    line-height: 1;
  }
  .mrr-footer {
    margin-top: 10px;
    font-size: 14px;
    color: #525866;
  }
  .mrr-compare {
    font-weight: 500;
  }
  .mrr-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 500;
    background: #EBF6E8;
    color: #58A53C;
  }
  .mrr-badge.negative {
    background: rgba(248, 113, 113, 0.15);
    color: #f87171;
  }
</style>

<div>
  <p class="mrr-title">Paid Customers</p>
  <div class="mrr-value">{{ rows[-1].values.`Paid Customers` }}</div>
  <div class="mrr-footer">
    <span class="mrr-badge" style="
      background: #F2FAF0;
      color: #589442;
    ">
      {{ rows[-1].values.`Cust MoM Sign` }}{{ rows[-1].values.`Cust Delta MoM` }}
    </span>
    vs last month
  </div>



</div>                        ;;
      settings {
        show_row_total: true
        show_column_total: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: viz_card_theme
  }
  block t1_kpi_net: VizBlock {
    label: 'Net New MRR KPI'
    viz: MarkdownViz {
      dataset: mouka_mrr
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: '1'
        modifier: 'month'
      }
      rows: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.month)
          format {
            type: 'date'
            pattern: 'MMM yyyy'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.abs_net_new_mrr)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_net_new_color)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_spark_x)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_net_new_spark_y)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_net_new_delta_sign)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_net_new_badge_color)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_net_new_badge_bg)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_abs_net_new_delta)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_abs_net_new_pct)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
        }
      ]
      content: @md <style>
  .mrr-title {
    margin: 0;
    color: #978A81;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .mrr-value {
    font-size: 36px;
    font-weight: 700;
    margin-top: 8px;
    line-height: 1;
    color: #E1643F;
  }
  .mrr-footer {
    margin-top: 10px;
    font-size: 14px;
    color: #525866;
  }
  .mrr-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
  }
</style>
<div>
  <p class="mrr-title">Net New MRR</p>
  <div style="color:#E1643F;font-size:36px;font-weight:600;font-family:Merriweather;margin-top:24px"><span style="font-size:20px;font-weight:600;color:#F4815F;margin-right:6px">&#36;</span>{{ rows[-1].values.`Net New MRR Abs` }}<span style="font-size:36px;font-weight:600;color:#E1643F;margin-right:6px;margin-left:8px">{{ rows[-1].values.`Net New Delta Sign` }}</span></div>
  <div class="mrr-footer">
    <span class="mrr-badge" style="background:{{ rows[-1].values.`Net New Badge Bg` }}; color:{{ rows[-1].values.`Net New Badge Color` }};">
      {{ rows[-1].values.`Net New Delta Sign` }} {{ rows[-1].values.`Net New Delta Abs` }}
      ({{ rows[-1].values.`Net New Pct Abs` }}%)
    </span>
    vs last month
  </div>
</div>                        ;;
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: viz_card_theme
  }
  block v_bm80: VizBlock {
    label: 'Net New MRR KPI copy'
    viz: MarkdownViz {
      dataset: mouka_mrr
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: '1'
        modifier: 'month'
      }
      rows: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.month)
          format {
            type: 'date'
            pattern: 'MMM yyyy'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.sum_new_logo)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.sum_expansion)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.abs_contraction)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.abs_churn)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        }
      ]
      content: @md <style>
  .bd-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 0;
  }
  .bd-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .bd-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .bd-label {
    font-size: 16px;
    font-weight: 400;
    color: #4B4340;
  }
  .bd-right {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .bd-amount {
    font-size: 19px;
    font-weight: 500;
  }
  .bd-sign { font-size: 19px; font-weight: 600; }
  .bd-pos { color: #58A53C; }
  .bd-neg { color: #E1643F; }
</style>
<div>
  <div class="bd-row">
    <div class="bd-left"><span class="bd-dot" style="background:#8B7FD4"></span><span class="bd-label">New logo</span></div>
    <div class="bd-right bd-pos"><span class="bd-sign">+</span><span class="bd-amount">&#36;{{ rows[-1].values.`New Logo MRR` }}</span></div>
  </div>
  <div class="bd-row">
    <div class="bd-left"><span class="bd-dot" style="background:#7DD4C0"></span><span class="bd-label">Expansion</span></div>
    <div class="bd-right bd-pos"><span class="bd-sign">+</span><span class="bd-amount">&#36;{{ rows[-1].values.`Expansion MRR` }}</span></div>
  </div>
  <div class="bd-row">
    <div class="bd-left"><span class="bd-dot" style="background:#F5B946"></span><span class="bd-label">Contraction</span></div>
    <div class="bd-right bd-neg"><span class="bd-sign">-</span><span class="bd-amount">&#36;{{ rows[-1].values.`Contraction Abs` }}</span></div>
  </div>
  <div class="bd-row">
    <div class="bd-left"><span class="bd-dot" style="background:#E16541"></span><span class="bd-label">Churn</span></div>
    <div class="bd-right bd-neg"><span class="bd-sign">-</span><span class="bd-amount">&#36;{{ rows[-1].values.`Churn Abs` }}</span></div>
  </div>
</div>                     ;;
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
      hide_controls: true
    }
    theme: spacer_block_theme
  }
  block t1_mrr_time: VizBlock {
    label: 'MRR Over Time'
    viz: CombinationChart {
      dataset: mouka_mrr
      calculation growth_pct {
        label: 'Growth Rate %'
        formula: @aql avg(mou_monthly_mrr.mrr_growth_rate);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation avg_mrr {
        label: 'Avg MRR'
        formula: @aql avg(mou_monthly_mrr.total_mrr) | of_all(mou_monthly_mrr.month);;
        calc_type: 'measure'
        data_type: 'number'
      }
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: '13'
        modifier: 'month'
      }
      x_axis: VizFieldFull {
        ref: r(mou_monthly_mrr.month)
        format {
          type: 'date'
          pattern: 'MMM yy'
        }
      }
      y_axis {
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.sum_total_mrr)
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#E9DBCCFF'
          }
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            ref: 'avg_mrr'
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#B3A092'
            line_style: 'dashed'
          }
        }
      }
      y_axis {
        settings {
          alignment: 'right'
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            ref: 'growth_pct'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#E16541'
          }
        }
      }
      settings {
        row_limit: 5000
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    theme: viz_card_theme
  }
  block t1_date_filter: FilterBlock {
    label: 'Time Range'
    type: 'field'
    source: FieldFilterSource {
      dataset: mouka_mrr
      field: r(mou_monthly_mrr.month)
    }
    default {
      operator: 'matches'
      value: 'last 13 months'
    }
  }
  block t1_waterfall: VizBlock {
    label: 'Net New MRR Breakdown'
    viz: CombinationChart {
      dataset: mouka_mrr
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: 1
        modifier: 'month'
      }
      y_axis {
        settings {
          reverse_stack: true
          stack_series_by: 'value'
        }
        series {
          mark_type: 'bar'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.sum_contraction)
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#FAC666'
          }
        }
        series {
          mark_type: 'bar'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.sum_churn)
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#E1653F'
          }
        }
        series {
          mark_type: 'bar'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.sum_new_logo)
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#7FE1D8'
          }
        }
        series {
          mark_type: 'bar'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.sum_expansion)
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#9998FF'
          }
        }
      }
      settings {
        row_limit: 5000
        legend_label: 'hidden'
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: transparent_viz_theme
  }
  block t2_kpi_new: VizBlock {
    label: 'New Logo MRR KPI'
    viz: MarkdownViz {
      dataset: mouka_mrr
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: '1'
        modifier: 'month'
      }
      rows: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.month)
          format {
            type: 'date'
            pattern: 'MMM yyyy'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.sum_new_logo)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_new_logo_delta)
          format {
            type: 'number'
            pattern: '+[$$]#,###0;-[$$]#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_spark_x)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_new_logo_spark_y)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_new_logo_sign)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_new_logo_badge_color)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_abs_new_logo_delta)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_abs_new_logo_pct)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_new_logo_badge_bg)
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
  .kpi-wrap { display:flex; gap:12px; }
  .kpi-line { width:4px; border-radius:2px; flex-shrink:0; }
  .kpi-body { flex:1; }
  .mrr-title { margin:0; color:#978A81; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; }
  .mrr-value { font-size:36px; font-weight:700; color:#423935; margin-top:8px; line-height:1; }
  .mrr-footer { margin-top:10px; font-size:14px; color:#525866; }
  .mrr-badge { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:6px; font-size:13px; font-weight:600; }
</style>
<div class="kpi-wrap">
  <div class="kpi-line" style="background:#9999FF"></div>
  <div class="kpi-body">
    <p class="mrr-title">New Logo MRR</p>
    <div class="mrr-value"><span style="font-size:20px;font-weight:600;color:#978A81;margin-right:6px;">$</span>{{ rows[-1].values.`New Logo MRR` }}</div>
    <div class="mrr-footer">
      <span class="mrr-badge" style="background:{{ rows[-1].values.`New Logo Badge Bg` }}; color:{{ rows[-1].values.`New Logo Badge Color` }};">
        {{ rows[-1].values.`New Logo Sign` }} {{ rows[-1].values.`New Logo Delta Abs` }} ({{ rows[-1].values.`New Logo Pct Abs` }}%)
      </span> vs last month
    </div>
  </div>
</div>                    ;;
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: spacer_block_theme
  }
  block t2_kpi_exp: VizBlock {
    label: 'Expansion MRR KPI'
    viz: MarkdownViz {
      dataset: mouka_mrr
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: '1'
        modifier: 'month'
      }
      rows: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.month)
          format {
            type: 'date'
            pattern: 'MMM yyyy'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.sum_expansion)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_exp_delta)
          format {
            type: 'number'
            pattern: '+[$$]#,###0;-[$$]#,###0'
          }
