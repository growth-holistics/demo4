  block v_jnb9: VizBlock {
    label: 'ARPA KPI'
    viz: MarkdownViz {
      dataset: mouka_mrr
      rows: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.month)
          format {
            type: 'date'
            pattern: 'MMM yyyy'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.sum_arpa)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_arpa_delta_mom)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_spark_x)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_arpa_spark_y)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_arpa_sign)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.abs_arpa_delta_mom)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_arpa_growth_pct)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
        }
      ]
      content: @md <style>
  .mrr-title {
    margin: 0;
    color: #978A81;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .mrr-value {
    font-size: 36px;
    font-weight: 700;
    color: #423935;
    margin-top: 8px;
    line-height: 1;
  }
  .mrr-footer {
    margin-top: 10px;
    font-size: 14px;
    color: #525866;
  }
  .mrr-compare {
    font-weight: 600;
  }
  .mrr-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    background: #F2FAF0;
    color: #589442;
  }
</style>

<div>
  <p class="mrr-title">ARPA</p>
  <div class="mrr-value"><span style="font-size:20px;font-weight:600;color:#978A81;margin-right:6px">&#36;</span>{{ rows[-1].values.`ARPA` }}</div>
  <div class="mrr-footer">
    <span class="mrr-badge">
      {{ rows[-1].values.`ARPA Sign` }} {{ rows[-1].values.`ARPA Delta Abs` }}
      ({{ rows[-1].values.`ARPA Growth %` }}%)
    </span>
    vs last month
  </div>


</div>                       ;;
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: viz_card_theme
  }
