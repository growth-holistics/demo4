  block v_emg2: VizBlock {
    label: 'Total MRR KPI copy'
    viz: MarkdownViz {
      dataset: mouka_mrr
      rows: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.month)
          transformation: 'datetrunc month'
          format {
            type: 'date'
            pattern: 'LLL yyyy'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.sum_net_new_mrr)
          format {
            type: 'number'
            pattern: '#,###0.##'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_growth_pct)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.sum_total_mrr)
          format {
            type: 'number'
            pattern: '#,###0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_color)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_amount_sign)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_sign)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_spark_x)
