  block t_cfjz: TextBlock {
    content: @md ## MRR movers;;
    theme {
      border {
        border_style: 'none'
      }
      background {
        bg_color: 'transparent'
      }
      shadow: 'none'
    }
  }
  block f_movers_date: FilterBlock {
    label: 'Month'
    type: 'field'
    source: FieldFilterSource {
      dataset: mouka_mrr
      field: r(mou_subscription_events.occurred_at)
    }
    default {
      operator: 'matches'
      value: 'last 1 month'
    }
  }

  block t_f0y6: TextBlock {
    content: @md <svg width="8" height="69" viewBox="0 0 8 69" fill="none" xmlns="http://www.w3.org/2000/svg">
<rect width="8" height="69" rx="2" fill="#E1643F"/>
</svg>
;;
    theme {
      border {
        border_style: 'none'
      }
      background {
        bg_color: 'transparent'
      }
      shadow: 'none'
    }
  }
  block v_e2y6: VizBlock {
    label: 'ARPA & Paid Customers'
    viz: CombinationChart {
      dataset: mouka_mrr
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: 13
        modifier: 'month'
      }
      x_axis: VizFieldFull {
        ref: r(mou_monthly_mrr.month)
        format {
          type: 'date'
          pattern: 'MMM yy'
        }
      }
      y_axis {
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.sum_paid_customers)
            format {
              type: 'number'
              pattern: '#,###0'
            }
          }
          settings {
            color: '#D2ECFF'
          }
        }
      }
      y_axis {
        settings {
          alignment: 'right'
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            ref: r(mou_monthly_mrr.sum_arpa)
            format {
              type: 'number'
              pattern: '[$$]#,###0'
            }
          }
          settings {
            color: '#FF82A7FF'
          }
        }
      }
      settings {
        row_limit: 5000
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    theme: viz_card_theme
  }
  block f_time_range_copy: FilterBlock {
    label: 'Time Range'
    type: 'field'
    source: FieldFilterSource {
      dataset: mouka_mrr
      field: r(mou_monthly_mrr.month)
    }
    default {
      operator: 'matches'
      value: 'last 13 months'
    }
  }
  block t_f8gh: TextBlock {
    content: @md ### .mouka;;
    theme {
      border {
        border_width: 0
        border_style: 'none'
      }
      background {
        bg_color: 'transparent'
      }
      padding: 0
      shadow: 'none'
    }
  }
