  block t3_cohort: VizBlock {
    label: 'Cohort Retention (MRR %)'
    viz: PivotTable {
      dataset: mouka_mrr
      theme {
        table {
          general {
            borders {
              outer: true
            }
          }
        }
      }
      rows: [
        VizFieldFull {
          label: 'Cohort'
          ref: r(mou_cohort_retention.cohort_month)
          transformation: 'datetrunc month'
          format {
            type: 'date'
            pattern: 'LLL yyyy'
          }
          uname: 'datetrunc_month_cohort_month'
        }
      ]
      columns: [
        VizFieldFull {
          ref: r(mou_cohort_retention.months_since)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      values: [
        VizFieldFull {
          label: ' '
          ref: r(mou_cohort_retention.avg_retention)
          format {
            type: 'number'
            pattern: '#,###%'
            group_separator: ','
            decimal_separator: '.'
          }
          uname: 'custom_avg_retention'
        }
      ]
      settings {
        wrap_header_text: true
        show_row_with_no_data: true
        conditional_formats: [
          ConditionalFormat {
            key: 'custom_avg_retention'
            format: ScaleFormat {
              min {
                value: 0.3
                color: '#FFF4D2FF'
              }
              mid {
                value: 0.8
                color: '#D6FFE5FF'
              }
              max {
                value: 1
                color: '#C6F5F9FF'
              }
            }
          }
        ]
        sorts: [
          SortSetting {
            key: 'datetrunc_month_cohort_month'
            direction: 'asc'
          }
        ]
        row_limit: 5000
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        column_styles: [
          ColumnStyle {
            key: 'custom_avg_retention'
            width: 80.59375
          },
          ColumnStyle {
            key: 'datetrunc_month_cohort_month'
            width: 207.5625
          }
        ]
      }
    }
    settings {
      hide_label: true
    }
    theme: spacer_block_theme
  }
