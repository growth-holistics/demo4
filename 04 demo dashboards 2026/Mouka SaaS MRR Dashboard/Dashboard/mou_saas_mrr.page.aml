<div>
 

  <svg width="100%" height="40" viewBox="0 0 600 40" preserveAspectRatio="none" style="margin-top:12px; display:block;">
<defs><linearGradient id="t4ag" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#58A53C" stop-opacity="0.3"/><stop offset="100%" stop-color="#58A53C" stop-opacity="0.05"/></linearGradient></defs>
<polygon fill="url(#t4ag)" points="0,40 {% map(rows) %}{{ values.`MRR Spark X`.raw }},{{ values.`ARPA Spark Y`.raw }} {% end %}600,{{ rows[-1].values.`ARPA Spark Y`.raw }} 600,40"/>
<polyline fill="none" stroke="#71AB5B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="{% map(rows) %}{{ values.`MRR Spark X`.raw }},{{ values.`ARPA Spark Y`.raw }} {% end %}600,{{ rows[-1].values.`ARPA Spark Y`.raw }}"/>
</svg>

</div>                      ;;
