          }
        }
      }
      fields: [
        VizFieldFull {
          ref: r(mou_customer_concentration.rank)
          format {
            type: 'number'
            pattern: 'inherited'
          }
          hidden: true
        },
        VizFieldFull {
          ref: r(mou_customer_concentration.company_name_formatted)
          format {
            type: 'html'
          }
          uname: 'mou_customer_concentration_company_name_formatted'
        },
        VizFieldFull {
          ref: r(mou_customer_concentration.plan_name_formatted)
          format {
            type: 'html'
          }
        },
        VizFieldFull {
          ref: r(mou_customer_concentration.tenure_months)
          format {
            type: 'html'
          }
          uname: 'mou_customer_concentration_tenure_months'
        },
        VizFieldFull {
          ref: r(mou_customer_concentration.mrr_bar)
          format {
            type: 'html'
          }
          uname: 'mou_customer_concentration_mrr_bar'
        },
        VizFieldFull {
          label: 'MRR (%)'
          ref: r(mou_customer_concentration.pct_of_total)
