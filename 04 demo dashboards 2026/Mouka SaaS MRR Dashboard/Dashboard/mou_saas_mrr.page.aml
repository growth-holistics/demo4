        VizFieldFull {
          ref: r(mou_monthly_mrr.val_mrr_spark_y)
          format {
            type: 'number';
            pattern: 'inherited'
          }
        }
      ]
      content: @md <div>
  <svg width="100%" height="40" viewBox="0 0 600 40" preserveAspectRatio="none" style="display:block;">
<defs><linearGradient id="t6mrrg" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#A6907D" stop-opacity="0.3"/><stop offset="100%" stop-color="#A6907D" stop-opacity="0.05"/></linearGradient></defs>
<polygon fill="url(#t6mrrg)" points="0,40 {% map(rows) %}{{ values.`MRR Spark X`.raw }},{{ values.`MRR Spark Y`.raw }} {% end %}600,{{ rows[-1].values.`MRR Spark Y`.raw }} 600,40"/>
<polyline fill="none" stroke="#A6907D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="{% map(rows) %}{{ values.`MRR Spark X`.raw }},{{ values.`MRR Spark Y`.raw }} {% end %}600,{{ rows[-1].values.`MRR Spark Y`.raw }}"/>
