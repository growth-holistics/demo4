  // ═══════════════════════════════════════════════════════════════════════════
  // Metric Tree — Combo KPI Cards
  // ═══════════════════════════════════════════════════════════════════════════

  // ── Total MRR ──────────────────────────────────────────────────────────
  block t6_mrr_kpi: VizBlock {
    label: 'Total MRR KPI'
    viz: MarkdownViz {
      dataset: mouka_mrr
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: '1'
        modifier: 'month'
      }
      rows: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.month)
          format {
            type: 'date';
            pattern: 'MMM yyyy'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.sum_total_mrr)
          format {
            type: 'number';
            pattern: '[$$]#,###0'
          }
        }
      ]
      content: @md <style>
  .kpi-wrap { display:flex; flex-direction:column; align-items:center; gap:4px; }
  .kpi-header { align-items:center; gap:8px; }
  .kpi-header svg { width:24px; height:24px; }
  .kpi-title { font-family:'Inter',sans-serif; font-size:18px; font-weight:500; color:#29221E; }
  .kpi-number { font-family:'Merriweather Sans','Merriweather',Georgia,serif; font-size:40px; font-weight:600; color:#29221E; line-height:1.5; text-align:center; margin-bottom:-10px; }
  .kpi-unit { font-family:'Inter',sans-serif; font-size:16px; font-weight:400; color:#A29186; text-align:center; }
</style>
<div class="kpi-wrap">
  <div class="kpi-header">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#A6907D" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
    <span class="kpi-title">Total MRR</span>
  </div>
  <div class="kpi-number">{{ rows[-1].values.`Total MRR` }}</div>
  <div class="kpi-unit">USD</div>
</div>             ;;
      settings {
        aggregate_awareness {
          enabled: true;
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: cust_card_theme
  }
  block t6_mrr_spark: VizBlock {
