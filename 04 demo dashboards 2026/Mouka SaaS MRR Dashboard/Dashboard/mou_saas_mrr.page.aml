  block t4_nrr_gauge: VizBlock {
    label: 'NRR Gauge'
    viz: MarkdownViz {
      dataset: mouka_mrr
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: '1'
        modifier: 'month'
      }
      rows: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.month)
          format {
            type: 'date';
            pattern: 'MMM yyyy'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.avg_nrr)
          format {
            type: 'number';
            pattern: '#0.0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_abs_nrr_delta)
          format {
            type: 'number';
            pattern: '#0.0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_nrr_sign)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_nrr_badge_color)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_nrr_badge_bg)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_nrr_yoy_pct)
          format {
            type: 'number';
            pattern: '#0.0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_nrr_yoy_sign)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_nrr_yoy_color)
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
  .nrr-gauge{display:flex;flex-direction:column;align-items:center;padding:24px 0 16px}
  .nrr-title{font-family:'Inter',sans-serif;font-size:24px;font-weight:500;color:#29221E;margin-bottom:12px}
  .nrr-svg{width:360px;height:200px;margin-top:12px}
  .needle-g{transform-box:view-box;transform-origin:100px 110px}
  .nrr-value{font-family:'Merriweather Sans','Merriweather',Georgia,serif;font-size:40px;font-weight:600;color:#29221E;line-height:1.2;margin-bottom:8px;margin-top:12px}
  .nrr-sub{font-family:'Inter',sans-serif;font-size:14px;font-weight:400;color:#A29186;margin-top:2px;margin-bottom:4px}
  .nrr-badges{display:flex;align-items:center;gap:8px;margin-top:4px}
  .nrr-badge{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:20px;font-family:'Inter',sans-serif;font-size:14px;font-weight:500}
</style>
<div class="nrr-gauge" style="--nrr:{{ rows[-1].values.`NRR %` }}">
  <svg class="nrr-svg" viewBox="0 0 200 130">
    <path d="M 15 110 A 85 85 0 0 1 67.5 31.5" fill="none" stroke="#F4815F" stroke-width="14" stroke-linecap="round"/>
    <path d="M 67.5 31.5 A 85 85 0 0 1 100 25" fill="none" stroke="#FFE16B" stroke-width="14"/>
    <path d="M 100 25 A 85 85 0 0 1 160 50" fill="none" stroke="#C2EE25" stroke-width="14"/>
    <path d="M 160 50 A 85 85 0 0 1 185 110" fill="none" stroke="#59D25D" stroke-width="14" stroke-linecap="round"/>
    <g class="needle-g" style="transform:rotate(calc((var(--nrr) - 100) / 40 * 90deg))">
      <line x1="100" y1="110" x2="100" y2="40" stroke="#E0D3C3" stroke-width="4" stroke-linecap="round"/>
    </g>
    <circle cx="100" cy="110" r="8" fill="#E0D3C3"/>
    <text x="8" y="130" font-family="Inter,sans-serif" font-size="12" fill="#897669">60%</text>
    <text x="100" y="12" font-family="Inter,sans-serif" font-size="12" fill="#897669" text-anchor="middle">100%</text>
    <text x="192" y="130" font-family="Inter,sans-serif" font-size="12" fill="#897669" text-anchor="end">140%</text>
  </svg>
  <div class="nrr-value">{{ rows[-1].values.`NRR %` }}%</div>
  <div class="nrr-sub">of revenue retained</div>
  <div class="nrr-badges">
    <span class="nrr-badge" style="color:{{ rows[-1].values.`NRR Badge Color` }};background:{{ rows[-1].values.`NRR Badge Bg` }}">
      {{ rows[-1].values.`NRR Sign` }} {{ rows[-1].values.`NRR Delta Abs` }}% MoM
    </span>
    <span class="nrr-badge" style="color:{{ rows[-1].values.`NRR YoY Color` }};background:{{ rows[-1].values.`NRR YoY Color` }}18">
      {{ rows[-1].values.`NRR YoY Sign` }} {{ rows[-1].values.`NRR YoY %` }}% YoY
    </span>
  </div>
</div>;;
      settings {
        aggregate_awareness {
          enabled: true;
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: spacer_block_theme
  }
  block t4_nrr_insight: VizBlock {
    label: 'NRR Insight'
    viz: MarkdownViz {
      dataset: mouka_mrr
      filter {
        field: r(mou_monthly_mrr.month);
        operator: 'last';
        value: '1';
        modifier: 'month'
      }
      rows: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.month);
          format {
            type: 'date';
            pattern: 'MMM yyyy'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: r(mou_monthly_mrr.avg_nrr);
          format {
            type: 'number';
            pattern: '#0.0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_nrr_health_label);
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_nrr_health_color);
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_nrr_insight_text);
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_nrr_yoy_pct);
          format {
            type: 'number';
            pattern: '#0.0'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_nrr_yoy_sign);
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(mou_monthly_mrr.val_nrr_yoy_color);
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
  .nrr-ins{font-family:'Inter',sans-serif;padding:4px 0 0}
  .nrr-ins-divider{border:0;height:1px;background:#E0D8D1;margin:0 0 10px}
  .nrr-ins-body{font-size:16px;color:#5C4F46;line-height:1.8}
  .nrr-ins-badge{display:inline-flex;align-items:center;padding:2px 10px;border-radius:12px;font-weight:600;font-size:12px;letter-spacing:0.3px;vertical-align:middle;margin-left:2px}
</style>
<div class="nrr-ins">
  <hr class="nrr-ins-divider"/>
  <div class="nrr-ins-body">
    At <b style="color:#29221E">{{ rows[-1].values.`NRR %` }}%</b> NRR <span class="nrr-ins-badge" style="color:{{ rows[-1].values.`NRR Health Color` }};background:{{ rows[-1].values.`NRR Health Color` }}18">{{ rows[-1].values.`NRR Health Label` }}</span> — {{ rows[-1].values.`NRR Insight` }}
  </div>
</div>;;
      settings {
        aggregate_awareness {
          enabled: true;
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
    theme: spacer_block_theme
  }
