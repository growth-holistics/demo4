      dataset: mouka_mrr
      filter {
        field: r(mou_monthly_mrr.month)
        operator: 'last'
        value: '13'
        modifier: 'month'
      }
      custom_chart_id: 34897
      field x_axis: VizFieldFull {
        ref: r(mou_monthly_mrr.month)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      field y_axis: VizFieldFull {
        ref: r(mou_monthly_mrr.customer_churn_rate)
        aggregation: 'sum'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
