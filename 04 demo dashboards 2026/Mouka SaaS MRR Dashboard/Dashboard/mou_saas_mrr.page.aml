  // ── Info icon (small clickable icon) ──
  block t_90y4: TextBlock {
    content: @md <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#C2B8AA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>;;
    theme: BlockTheme {
      background {
        bg_color: 'transparent'
      }
      border {
        border_style: 'none'
      }
      shadow: 'none'
      padding: 3
    }
  }
  // ── Info popover (hover zone overlaps icon, popup appears below) ──
  // POSITION: Change class on .info-hover-zone to control popup direction:
  //   info-pos-bottom (default), info-pos-top, info-pos-left, info-pos-right
  // SIZE: Adjust .info-popup width + block pos() dimensions to match
  block t_90y4_popup: TextBlock {
    content: @md <div class="info-hover-zone info-pos-bottom"><style>
.info-hover-zone { pointer-events: none; width: 100%; height: 100%; }
.info-trigger { position: absolute; top: 0; left: 0; width: 40px; height: 40px; cursor: pointer; pointer-events: auto; }
.info-trigger .info-popup {
  visibility: hidden; opacity: 0;
  position: absolute;
  width: 420px; background: #FFFFFF; border: 1px solid #E8E0D6; border-radius: 16px;
  box-shadow: 0 12px 40px rgba(0,0,0,0.10); padding: 24px 24px 28px;
  z-index: 9999; transition: opacity 0.18s ease, visibility 0.18s ease;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: #3D3229; line-height: 1.7; text-align: left;
  pointer-events: auto;
}
.info-trigger:hover .info-popup { visibility: visible; opacity: 1; }
/* ── Position variants ── */
.info-pos-bottom .info-popup { top: 46px; left: 0; }
.info-pos-top .info-popup    { bottom: 46px; left: 0; top: auto; }
.info-pos-right .info-popup  { top: 0; left: 46px; }
.info-pos-left .info-popup   { top: 0; right: 46px; left: auto; }
/* ── Title with left accent bar ── */
.info-popup .info-title { display: flex; align-items: center; gap: 12px; margin: 0 0 6px 0; }
.info-popup .info-title .accent-bar { width: 4px; height: 28px; background: #E1643F; border-radius: 2px; flex-shrink: 0; }
.info-popup .info-title span { font-size: 22px; font-weight: 500; color: #1E1E1E; letter-spacing: -0.3px; }

/* ── Section headers ── */
/* ── Section headers ── */
.info-popup .section-title { margin: 24px 0 4px 0; font-size: 16px; font-weight: 700; color: #2D2D2D; letter-spacing: -0.1px; line-height: 1.3; }
.info-popup .section-title:first-of-type { margin-top: 12px; }
/* ── Body text ── */
.info-popup p { margin: 0 0 0 0; font-size: 17px; color: #4B4340; line-height: 1.7; }
/* ── Code / formula ── */
.info-popup code { background: #FFF0EC; padding: 6px 16px; border-radius: 8px; font-size: 14px; font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace; color: #C0392B; display: inline-block; margin-top: 4px; }
</style><div class="info-trigger"><div class="info-popup"><div class="info-title"><div class="accent-bar"></div><span>MRR Over Time</span></div><div style="margin:18px 0 6px 0;font-size:18px;font-weight:600;color:#2D2D2D;letter-spacing:-0.1px;line-height:1.3">Definition</div><p style="font-size:17px">Monthly Recurring Revenue (MRR) is the total predictable revenue from all active subscriptions in a given month.</p><div style="margin:22px 0 6px 0;font-size:18px;font-weight:600;color:#2D2D2D;letter-spacing:-0.1px;line-height:1.3">Formular</div><p style="font-size:17px"><code>SUM(mrr) of all active subscriptions</code></p><div style="margin:22px 0 6px 0;font-size:18px;font-weight:600;color:#2D2D2D;letter-spacing:-0.1px;line-height:1.3">How to read this chart</div><p style="font-size:17px">Bars show Total MRR each month. The dashed line is the average MRR across the period. The orange line (right axis) tracks month-over-month growth rate %. Rising bars with positive growth = healthy. A dip below the average line signals a month to investigate.</p></div></div></div>;;
