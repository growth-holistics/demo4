  block v_p7pm: VizBlock {
    label: 'P&L Statement'
    viz: MetricSheet {
      dataset: demo_finance_di
      calculation saas_rev {
        label: 'SaaS Subscriptions'
        formula: @aql total_revenue
| where(fact_gl_entries.segment == "SaaS");;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation enterprise_rev {
        label: 'Enterprise Licenses'
        formula: @aql total_revenue
| where(fact_gl_entries.segment == "Enterprise");;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation services_rev {
        label: 'Professional Services'
        formula: @aql total_revenue;;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation cogs {
        label: 'Cost of Goods sold'
        formula: @aql sum(fact_gl_entries.actual_amount)
| where(dim_account.type == "COGS");;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation sales_expenses {
        label: 'Sales & Marketing'
        formula: @aql expenses
| where(fact_gl_entries.department == "Sales");;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation rd_expenses {
        label: 'Research & Development'
        formula: @aql expenses
| where(fact_gl_entries.department == "R&amp;D");;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation cs_expenses {
        label: 'Customer Services'
        formula: @aql expenses
| where(fact_gl_entries.department == "CS");;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation ga_expenses {
        label: 'General & Admin'
        formula: @aql expenses
| where(fact_gl_entries.department == "G&amp;A");;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation da_amount {
        label: 'Depreciation & Amort.'
        formula: @aql sum(fact_gl_entries.actual_amount)
| where(dim_account.type == "D&amp;A");;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation interest_tax_amount {
        label: 'Interest & Tax'
        formula: @aql sum(fact_gl_entries.actual_amount)
| where(dim_account.type in ["Interest", "Tax"]);;
        calc_type: 'measure'
        data_type: 'number'
      }
      theme {
        table {
          general {
            bg_color: '#FFFFFF'
            borders {
              outer: true
              vertical: true
              header: true
            }
          }
        }
      }
      date_field: VizFieldFull {
        ref: r(fact_gl_entries.date)
        transformation: 'datetrunc quarter'
        format {
          type: 'date'
          pattern: 'yyyy Qq'
        }
      }
      rows: [
        MetricSeries {
          field: VizFieldFull {
            ref: r(demo_finance_di.total_revenue)
            format {
              type: 'number'
              pattern: '[$$]#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            ref: 'saas_rev'
            format {
              type: 'number'
              pattern: '[$$]#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            indent: 5
            mark_type: 'line'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            ref: 'enterprise_rev'
            format {
              type: 'number'
              pattern: '[$$]#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            indent: 5
            mark_type: 'line'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            ref: 'services_rev'
            format {
              type: 'number'
              pattern: '[$$]#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            indent: 5
            mark_type: 'line'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            ref: 'cogs'
            format {
              type: 'number'
              pattern: '[$$]#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            ref: r(demo_finance_di.gross_profit)
            format {
              type: 'number'
              pattern: '[$$]#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            ref: r(demo_finance_di.expenses)
            format {
              type: 'number'
              pattern: '[$$]#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            ref: 'sales_expenses'
            format {
              type: 'number'
              pattern: '[$$]#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
