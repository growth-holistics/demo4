  block f_date_range: FilterBlock {
    label: 'Date Range'
    type: 'field'
    source: FieldFilterSource {
      dataset: demo_finance_di
      field: r(fact_gl_entries.date)
    }
    default {
      operator: 'matches'
      value: '2025'
    }
  }
  block v_bcw6: VizBlock {
    label: 'Revenue vs. Operating Expenses'
    viz: CombinationChart {
      dataset: demo_finance_di
      calculation abs_expenses {
        label: 'Abs Expenses'
        formula: @aql abs(expenses);;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        ref: r(fact_gl_entries.date)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        series {
          mark_type: 'column'
          field: VizFieldFull {
            label: 'Revenue'
            ref: r(demo_finance_di.total_revenue)
            format {
              type: 'number'
              pattern: '#,###,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            color: '#7638FFFF'
            color_palette: 0
          }
        }
        series {
          mark_type: 'column'
          field: VizFieldFull {
            label: 'Expenses'
            ref: 'abs_expenses'
            format {
              type: 'number'
              pattern: '#,###,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            color: '#FC8B37FF'
            color_palette: 0
          }
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            label: 'Net'
            ref: r(demo_finance_di.ebitda)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#00C56EFF'
            line_interpolation: 'smooth'
          }
        }
      }
      settings {
        show_data_points: true
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_1hht: VizBlock {
    label: 'Revenue Breakdown'
    viz: PieChart {
      dataset: demo_finance_di
      legend: VizFieldFull {
        ref: r(fact_gl_entries.breakdown_dim)
        format {
          type: 'text'
        }
      }
      series {
        field: VizFieldFull {
          label: ' '
          ref: r(demo_finance_di.total_revenue)
          format {
            type: 'number'
            pattern: '#,###0.00,,"M" [$$]'
            group_separator: ','
            decimal_separator: '.'
          }
        }
        settings {
          point {
            value: 'Enterprise'
            color: '#5BADFFFF'
          }
          point {
            value: 'SaaS'
            color: '#7638FFFF'
          }
          point {
            value: 'Services'
            color: '#FC8B37FF'
          }
          point {
            value: 'APAC'
            color: '#7638FFFF'
          }
          point {
            value: 'North America'
            color: '#5BADFFFF'
          }
        }
      }
      settings {
        display_as_donut: true
        show_total: true
        sort: 'desc'
        show_percentage: true
        data_label_position: 'outside'
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_s49h: VizBlock {
    label: 'P&L Waterfall — Revenue to Net Income'
    viz: CustomChart {
      dataset: demo_finance_di
      custom_chart_id: 34895
      field amount: VizFieldFull {
        ref: r(pl_waterfall.sum_amount)
        aggregation: 'sum'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      field label: VizFieldFull {
        ref: r(pl_waterfall.label)
        format {
          type: 'text'
        }
      }
      field sort_order: VizFieldFull {
        ref: r(demo_finance_di, pl_waterfall.label_sort_order)
        format {
          type: 'text'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
