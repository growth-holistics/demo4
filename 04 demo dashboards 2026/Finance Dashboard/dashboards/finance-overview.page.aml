  block t_f8fu: TextBlock {
    content: @md <div class="section-header">
  <div class="accent-bar"></div>
  <h1>Cashflow Overview</h1>
</div>;;
  }
  block v_87kg: VizBlock {
    label: 'Cash Flow by Category'
    viz: CombinationChart {
      dataset: demo_finance_di
      calculation operating_cf {
        label: 'Operating'
        formula: @aql sum(fact_cashflow_entries.amount)
| where(fact_cashflow_entries.cf_type == "Operating");;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation investing {
        label: 'Investing'
        formula: @aql abs(sum(fact_cashflow_entries.amount)
| where(fact_cashflow_entries.cf_type == "Investing"));;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation financing {
        label: 'Financing'
        formula: @aql abs(sum(fact_cashflow_entries.amount)
| where(fact_cashflow_entries.cf_type == "Financing"));;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation total_cashflow {
        label: 'Total Cashflow'
        formula: @aql operating_cf + investing + financing;;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        ref: r(fact_cashflow_entries.date)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      legend: VizFieldFull {
        ref: r(fact_cashflow_entries.cf_type)
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          axis_min: -100000
          axis_max: 275000
          stack_series_by: 'value'
        }
        series {
          field: VizFieldFull {
            label: ' '
            ref: r(fact_cashflow_entries.amount)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '[$$]#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            point {
              value: 'Financing'
              color: '#FC8B37FF'
            }
            point {
              value: 'Investing'
              color: '#5BADFFFF'
            }
            point {
              value: 'Operating'
              color: '#7638FFFF'
            }
          }
        }
      }
      y_axis {
        settings {
          alignment: 'right'
          axis_min: -100000
          axis_max: 275000
          hidden: true
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            label: 'Net'
            ref: r(fact_cashflow_entries.amount)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '[$$]#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
            break_by_legend: false
          }
          settings {
            color: '#00C56EFF'
            line_interpolation: 'smooth'
          }
        }
      }
      settings {
        show_data_points: true
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_xa1q: VizBlock {
    label: 'Cash Runway'
    viz: MarkdownViz {
      dataset: demo_finance_di
      rows: [
        VizFieldFull {
          ref: r(cash_runway.operating)
          format {
            type: 'number'
            pattern: '[$$]#,###0.00,"K"'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: r(cash_runway.investing)
          format {
            type: 'number'
            pattern: '[$$]#,###0.00,"K"'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: r(cash_runway.financing)
          format {
            type: 'number'
            pattern: '[$$]#,###0.00,"K"'
            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
