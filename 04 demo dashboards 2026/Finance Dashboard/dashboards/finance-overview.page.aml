            group_separator: ','
            decimal_separator: '.'
          }
        },
        VizFieldFull {
          ref: r(cash_runway.runway_months)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(cash_runway.runway_pct)
          format {
            type: 'number'
            pattern: '[$$]#,###0.00,"K"'
            group_separator: ','
            decimal_separator: '.'
          }
        }
      ]
      content: @md <style>
  * { box-sizing: border-box; }
  .runway-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 28px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #1B2559;
    width: 100%;
    box-shadow: 0 2px 12px rgba(118,56,255,0.08);
  }
  .runway-title { font-size: 18px; font-weight: 700; margin-bottom: 2px; color: #1B2559; }
  .runway-subtitle { font-size: 13px; color: #6B7A99; margin-bottom: 20px; }
  .runway-number { font-size: 64px; font-weight: 800; color: #7638FF; line-height: 1; }
  .runway-label { font-size: 15px; color: #6B7A99; margin: 4px 0 16px; }
  .runway-progress-bar-bg {
    background: #E0D9FF; border-radius: 999px;
    height: 8px; margin-bottom: 6px; width: 100%;
  }
  .runway-progress-bar-fill {
    background: #7638FF; height: 8px; border-radius: 999px; width: 0%;
  }
  .runway-progress-labels {
    display: flex; justify-content: space-between;
    font-size: 11px; color: #6B7A99; margin-bottom: 20px;
  }
  .runway-metrics-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
    margin-bottom: 16px; width: 100%;
  }
  .runway-metric-box { background: #F8F9FC; border-radius: 10px; padding: 14px; min-width: 0; }
  .runway-metric-label { font-size: 10px; font-weight: 700; color: #6B7A99; letter-spacing: 0.08em; }
  .runway-metric-value { font-size: 18px; font-weight: 700; margin-top: 4px; }
  .runway-positive { color: #00C56E; }
  .runway-negative { color: #FC0027; }
  .runway-insight-box {
    background: #F0EBFF; border: 1px solid #7638FF44;
    border-radius: 10px; padding: 14px; font-size: 13px; color: #6B7A99;
  }
  .runway-insight-title {
    font-size: 11px; font-weight: 700; color: #7638FF;
    letter-spacing: 0.08em; margin-bottom: 6px;
  }
  #runway-pct-value { display: none; }
</style>

<div class="runway-card">
  <div class="runway-title">Cash Runway</div>
  <div class="runway-subtitle">At current burn rate</div>

  <div class="runway-number">{{ rows[0].`Runway Months` }}</div>
  <div class="runway-label">months remaining</div>

  <div class="runway-progress-bar-bg">
    <div class="runway-progress-bar-fill" id="runway-fill"></div>
  </div>
  <div class="runway-progress-labels">
    <span>Now</span>
    <span>{{ rows[0].`Runway Months` }}mo</span>
    <span>24mo</span>
  </div>

  <div class="runway-metrics-grid">
    <div class="runway-metric-box">
      <div class="runway-metric-label">OPERATING</div>
      <div class="runway-metric-value runway-positive">{{ rows[0].`Operating` }}</div>
    </div>
    <div class="runway-metric-box">
      <div class="runway-metric-label">INVESTING</div>
      <div class="runway-metric-value runway-negative">{{ rows[0].`Investing` }}</div>
    </div>
    <div class="runway-metric-box">
      <div class="runway-metric-label">FINANCING</div>
      <div class="runway-metric-value runway-negative">{{ rows[0].`Financing` }}</div>
    </div>
    <div class="runway-metric-box">
      <div class="runway-metric-label">FREE CF</div>
      <div class="runway-metric-value runway-positive">{{ rows[0].`Free Cf` }}</div>
    </div>
  </div>

  <div class="runway-insight-box">
    <div class="runway-insight-title">💡 INSIGHT</div>
    Operating CF is positive — business is self-sustaining.
    Investing outflows reflect ongoing infrastructure spend.
  </div>
</div>

<span id="runway-pct-value">{{ rows[0].`Runway Pct` }}</span>

<script>
  setTimeout(function() {
    var pct = document.getElementById('runway-pct-value').innerText.trim();
    document.getElementById('runway-fill').style.width = pct + '%';
  }, 100);
</script> ;;
      settings {
