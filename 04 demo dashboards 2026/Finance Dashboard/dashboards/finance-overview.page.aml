  block v_2w8b: VizBlock {
    label: 'Gross Profit copy'
    viz: MetricKpi {
      dataset: demo_finance_di
      value: VizFieldFull {
        ref: r(demo_finance_di.gross_profit)
        format {
          type: 'number'
          pattern: '[$$]#,###0.00,,"M"'
          group_separator: ','
          decimal_separator: '.'
        }
      }
      compare_value: VizPopSettings {
        field: r(fact_gl_entries.date)
        value: RelativePopValue {
          duration: 1
          granularity: 'year'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        metric_value {
          font_size: 44
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_rt1y: VizBlock {
    label: 'Gross Profit copy copy'
    viz: AreaChart {
      dataset: demo_finance_di
      x_axis: VizFieldFull {
        ref: r(fact_gl_entries.date)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        settings {
          hidden: true
        }
        series {
          field: VizFieldFull {
            ref: r(demo_finance_di.gross_profit)
            format {
              type: 'number'
              pattern: '[$$]#,###0.00'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            color: '#00C56EFF'
            color_palette: 0
          }
        }
      }
      settings {
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
      hide_controls: true
    }
  }
