Dashboard finance_overview {
  title: 'Finance Overview'
  description: @md ## What it is
A simple Finance Overview dashboard that lets you track revenue, profitability, and cash runway across segments and scenarios — all in one scroll.

## Description
This dashboard is for finance leads, executives, and anyone who needs a quick read on company health without digging through spreadsheets. Instead of chasing numbers across tools, you get revenue trends, P&L breakdown, and cash flow all in one place — filterable by date range, scenario, and business segment.;;
  owner: 'di.hoang+20166@holistics.io'
  block title: TextBlock {
    content: @md <div class="section-header">
  <div class="accent-bar"></div>
  <h1>Key Performance Indicators</h1>
</div>;;
  }
  block v_1n2l: VizBlock {
    label: 'Total Revenue'
    viz: MetricKpi {
      dataset: demo_finance_di
      value: VizFieldFull {
        ref: r(demo_finance_di.total_revenue)
        format {
          type: 'number'
          pattern: '[$$]#,###0.00,,"M"'
          group_separator: ','
          decimal_separator: '.'
        }
      }
      compare_value: VizPopSettings {
        field: r(fact_gl_entries.date)
        value: RelativePopValue {
          duration: 1
          granularity: 'year'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        metric_value {
          font_size: 44
        }
      }
    }
    settings {
      hide_label: true
    }
  }
