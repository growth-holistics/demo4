  block f_breakdown: FilterBlock {
    label: 'Breakdown'
    type: 'field'
    source: FieldFilterSource {
      dataset: demo_finance_di
      field: r(fact_gl_entries.dim_choice)
    }
    default {
      operator: 'is'
      value: 'Segment'
    }
    settings {
      hide_label: true
      input_type: 'single'
    }
    theme: BlockTheme {
      border {
        border_width: 0
        border_style: 'none'
      }
      shadow: 'none'
    }
  }
  block f_amount_type: FilterBlock {
    label: 'Scenario'
    type: 'field'
    source: FieldFilterSource {
      dataset: demo_finance_di
      field: r(fact_gl_entries.filter_choice)
    }
    default {
      operator: 'is'
      value: 'Actual'
    }
    settings {
      input_type: 'single'
    }
  }
  block f_segment: FilterBlock {
    label: 'Segment'
    type: 'field'
    source: FieldFilterSource {
      dataset: demo_finance_di
      field: r(fact_gl_entries.segment)
    }
    default {
      operator: 'is'
      value: []
    }
  }
  block t_8m8p: TextBlock {
    content: @md <div 
  style="
    background: linear-gradient(135deg, #0D0A1A 0%, #1A1035 40%, #2C1A5E 75%, #1A0F3A 100%);
    border: 1.5px solid rgba(167,139,250,0.25);
    border-radius: 8px;
    padding: 20px 24px;
    font-family: 'Inter', sans-serif;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
  ">

  <!-- soft glow blobs -->
  <div style="position: absolute; top: -40px; right: -40px; width: 180px; height: 180px; background: radial-gradient(circle, rgba(118,56,255,0.18) 0%, transparent 70%); pointer-events: none;"></div>
  <div style="position: absolute; bottom: -30px; left: 30%; width: 140px; height: 140px; background: radial-gradient(circle, rgba(252,139,55,0.10) 0%, transparent 70%); pointer-events: none;"></div>

  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
    <div style="width: 3px; height: 28px; background: linear-gradient(to bottom, #FC8B37, #7638FF); border-radius: 2px; flex-shrink: 0;"></div>
    <h1 style="margin: 0; font-size: 24px; font-weight: 700; background: #ffffff; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; letter-spacing: -0.3px;">Finance Overview</h1>
  </div>

  <p style="margin: 0 0 16px 0; font-size: 16px; color: rgba(255, 255, 255, 1); padding-left: 26px;">Full-year performance across all segments · Scenario: Actual</p>

  <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap; padding-left: 13px; padding-top:24px; ">
    <span style="font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; background: rgba(118,56,255,0.22); color: #A78BFA; border: 1px solid rgba(118,56,255,0.4); letter-spacing: 0.4px;">FY 2025</span>
    <span style="font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; background: rgba(252,139,55,0.15); color: #FC8B37; border: 1px solid rgba(252,139,55,0.35); letter-spacing: 0.4px;">All Segments</span>
    <span style="font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; background: rgba(118,56,255,0.22); color: #A78BFA; border: 1px solid rgba(167,139,250,0.15); letter-spacing: 0.4px;">57mo runway</span>
  </div>
</div>;;
