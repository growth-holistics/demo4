  block v_fpz9: VizBlock {
    label: 'New vs. Returning Learners per Month'
    viz: ColumnChart {
      dataset: minh_edu
      calculation new_learners {
        label: 'New Learners'
        formula: @aql count_distinct(students_csv.id) | where(
  enrollments_csv.enrolled_at | month() == students_csv.signup_at | month()
);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation returning_learners {
        label: 'Returning Learners'
        formula: @aql count_distinct(students_csv.id) | where(
  enrollments_csv.enrolled_at | month() != students_csv.signup_at | month()
);;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        ref: r(enrollments_csv.enrolled_at)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        settings {
          show_data_label_by: 'value'
          stack_series_by: 'value'
          hidden: true
        }
        series {
          field: VizFieldFull {
            ref: 'new_learners'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#BED829FF'
          }
        }
        series {
          field: VizFieldFull {
            ref: 'returning_learners'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#0A85A7FF'
          }
        }
      }
      settings {
        row_limit: 10000
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block t_p8iu: sticky_note_lined('💡 Insight: Courses with completion', ' rates  above 20% tend to have ', ' higher learner satisfaction scores. ', ' Focus on replicating successful ', 'course structures and engagement ', 'strategies from top performers.', '', '', '')
  block v_srai: VizBlock {
    label: 'Top 3 instructors'
    viz: MarkdownViz {
      dataset: minh_edu
      calculation metric_d0fd5af {
        label: 'Count distinct of Courses Id'
        formula: @aql count_distinct(courses_csv.id);;
        calc_type: 'measure'
        data_type: 'number'
      }
      filter {
        field: r(courses_csv.instructor_name)
        operator: 'top'
        value: 3
        options {
          rank_by {
            field: 'metric_a0a766f'
            aggregation: 'custom'
            logic: 'standard'
          }
        }
      }
      rows: [
        VizFieldFull {
          ref: r(courses_csv.instructor_name)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(courses_csv.instructor_photo_url)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(courses_csv.instructor_photo_image)
          format {
            type: 'html'
          }
        }
      ]
      values: [
        VizFieldFull {
          label: 'Total Enrollments'
          ref: r(minh_edu.metric_a0a766f)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          label: 'Courses taught'
          ref: 'metric_d0fd5af'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(minh_edu.completion_rate)
          format {
            type: 'number'
            pattern: '#,###%'
          }
        },
        VizFieldFull {
          label: 'Rating'
          ref: r(minh_edu.avg_quiz_result)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      content: @md <style>
  .instructors-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 5rem;
    padding: 1.5rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .instructor-card {
    position: relative;
    border-radius: 1.5rem;
    border: 2px solid #C5E5E8;
    background: linear-gradient(180deg, #FFFFFF 0%, #F0F9FA 100%);
    padding: 2rem 1.5rem;
  }
  
  .vine-decoration {
    position: absolute;
    top: -24px;
    right: -14px;
    width: 150px;
    height: 150px;
  }
  
  .instructor-photo-container {
    position: relative;
    width: 180px;
    height: 180px;
    margin: 0 auto 1.5rem;
  }
  
  .instructor-photo {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center;
    background-color: #5F9EA0;
    display: block;
    margin: 10px auto;
    border: 2px solid #C5E5E8;
  }
  
  .rank-badge {
    position: absolute;
    bottom: 12px;
    right: 12px;
    width: 45px;
    height: 45px;
    border-radius: 50%;
    color: white;
    font-size: 1.25rem;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 3px solid white;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    z-index: 10;
  }
  
  .instructor-name {
    font-size: 1.75rem;
    font-weight: 600;
    color: #2F6F71;
    text-align: center;
    margin-bottom: 1.5rem;
  }
  
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  
  .metric-item {
    text-align: center;
  }
  
  .metric-value {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 1rem;
    background-color: #C5E5E8;
    color: #2F6F71;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  
  .metric-label {
    font-size: 0.875rem;
    color: #5F9EA0;
    font-weight: 500;
  }
  
  .rating-value {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    background-color: transparent !important;
    padding: 0.5rem 1rem;
    margin-bottom: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
