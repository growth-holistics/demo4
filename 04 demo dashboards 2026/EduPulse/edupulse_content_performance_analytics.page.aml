  }
  block v_hfnn: VizBlock {
    label: 'Total enrolled copy copy'
    viz: MetricKpi {
      dataset: minh_edu
      calculation metric_e6df75a {
        label: 'Untitled Metric'
        formula: @aql count(enrollments_csv.id) | where(enrollments_csv.status == 'completed');;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_abb9c53 {
        label: 'Untitled Metric'
        formula: @aql count(enrollments_csv.id) | where(enrollments_csv.status == 'dropped');;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        label: 'Dropped'
        ref: 'metric_abb9c53'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_8gpb: VizBlock {
    label: 'Average quiz score'
    viz: MetricKpi {
      dataset: minh_edu
      calculation metric_e6df75a {
        label: 'Untitled Metric'
        formula: @aql count(enrollments_csv.id) | where(enrollments_csv.status == 'completed');;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_abb9c53 {
        label: 'Untitled Metric'
        formula: @aql count(enrollments_csv.id) | where(enrollments_csv.status == 'dropped');;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_91ab1ac {
        label: 'Concat field'
        formula: @aql concat(cast(metric_b4d6dbe, 'text'), " ", "/10");;
        calc_type: 'measure'
        data_type: 'text'
      }
      value: VizFieldFull {
        label: 'Average Quiz Score'
        ref: r(minh_edu.avg_quiz_result)
        format {
          type: 'number'
          pattern: '#,###0.0'
          group_separator: ','
          decimal_separator: '.'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_xqjb: VizBlock {
    label: 'Enrollment funnel'
    viz: ConversionFunnel {
      dataset: minh_edu
      calculation enrollment_in_progress {
        label: 'I'
        formula: @aql count(enrollments_csv.id) -35 | where(enrollments_csv.status == 'in_progress');;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation enrollments_completed {
        label: 'Enrollments Completed'
        formula: @aql count(enrollments_csv.id) -40 | where(enrollments_csv.status == 'completed');;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation enrollments_dropped {
        label: 'Enrollments Dropped'
        formula: @aql count(enrollments_csv.id) -40 | where(enrollments_csv.status == 'dropped');;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_8388ba4 {
        label: 'Untitled Metric'
        formula: @aql count(enrollments_csv.id) | where(enrollments_csv.status == 'enrolled');;
        calc_type: 'measure'
        data_type: 'number'
      }
      values: [
        VizFieldFull {
          label: 'enrolled'
          ref: 'metric_8388ba4'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          label: 'in progress'
          ref: 'enrollment_in_progress'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          label: 'completed'
          ref: 'enrollments_completed'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          label: 'dropped'
          ref: 'enrollments_dropped'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      settings {
        circle_color: '#BED829FF'
        columns_color: '#0A85A7FF'
        row_limit: 10000
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_jumc: VizBlock {
    label: 'Completion Rate by Module'
    viz: BarChart {
      dataset: minh_edu
      calculation module_completion_rate {
        label: 'Module Completion Rate'
        formula: @aql (count(module_progress_csv.id) | where(enrollments_csv.status == 'completed')) 
/ 
count(module_progress_csv.id);;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        ref: r(courses_csv.title)
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          show_data_label_by: 'value'
          hidden: true
        }
        series {
          field: VizFieldFull {
            ref: 'module_completion_rate'
            format {
              type: 'number'
              pattern: '#,###%'
            }
          }
          settings {
            color: '#0A85A7FF'
          }
        }
      }
      settings {
        row_limit: 10000
        sort {
          field_index: 0
          direction: 'desc'
          type: 'series'
        }
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
