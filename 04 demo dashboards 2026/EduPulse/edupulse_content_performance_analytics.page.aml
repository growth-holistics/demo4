Dashboard edupulse_content_performance_analytics {
  theme: edu_pulse
  title: 'EduPulse Analytics'
  description: ''
  owner: 'minh.ntn@holistics.io'
  block v_qrr6: VizBlock {
    label: 'Completion Rate by Course'
    viz: BarChart {
      dataset: minh_edu
      x_axis: VizFieldFull {
        ref: r(courses_csv.title)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(minh_edu.completion_rate)
            format {
              type: 'number'
              pattern: '#,###%'
            }
          }
          settings {
            color: '#0A85A7FF'
          }
        }
      }
      settings {
        row_limit: 10000
        sort {
          field_index: 0
          direction: 'desc'
          type: 'yaxis'
        }
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_g7no: VizBlock {
    label: 'Total courses'
    viz: MetricKpi {
      dataset: minh_edu
      calculation metric_1e3c66e {
        label: 'Count distinct of Courses Id'
        formula: @aql count_distinct(courses_csv.id);;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        label: 'Total courses'
        ref: 'metric_1e3c66e'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_color: '#0F647BFF'
        }
        alignment: 'left'
        metric_value {
          font_color: '#0F647BFF'
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_2r7p: VizBlock {
    label: 'Overall Completion Rate compared with Overall Completion Rate Last 3 Months'
    viz: MetricKpi {
      dataset: minh_edu
      calculation overall_completion_rate_last_3_months {
        label: 'Overall Completion Rate Last 3 Months'
        formula: @aql (count(enrollments_csv.id) | where(enrollments_csv.status == 'completed', enrollments_csv.enrolled_at matches @(3 months ago))) 
/ 
(count(enrollments_csv.id) | where(enrollments_csv.enrolled_at matches @(3 months ago)));;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        ref: r(minh_edu.overall_completion_rate)
        format {
          type: 'number'
          pattern: '#,###%'
        }
      }
      compare_value: VizFieldFull {
        ref: 'overall_completion_rate_last_3_months'
        format {
          type: 'number'
          pattern: 'none'
        }
      }
      settings {
        display_mode: 'compare_by_number'
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_color: '#0F647BFF'
        }
        alignment: 'left'
        metric_value {
          font_color: '#0F647BFF'
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_6c2s: VizBlock {
    label: 'Avg Rating compared with Avg Rating Last 3 Months'
    viz: MetricKpi {
      dataset: minh_edu
      calculation metric_1e3c66e {
        label: 'Count distinct of Courses Id'
        formula: @aql count_distinct(courses_csv.id);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_8a3bff6 {
        label: 'Average of Course reviews Rating'
        formula: @aql avg(course_reviews_csv.rating);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation avg_rating_last_3_months {
        label: 'Avg Rating Last 3 Months'
        formula: @aql avg(course_reviews_csv.rating) | where(course_reviews_csv.reviewed_at matches @(3 months ago));;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        label: 'Avg Rating'
        ref: 'metric_8a3bff6'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      compare_value: VizFieldFull {
        ref: 'avg_rating_last_3_months'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_color: '#0F647BFF'
        }
        alignment: 'left'
        metric_value {
          font_color: '#0F647BFF'
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_hbuv: VizBlock {
    label: 'Course League Table'
    viz: DataTable {
      dataset: minh_edu
      calculation metric_2c6b485 {
        label: 'Count of Enrollments Id'
        formula: @aql count(enrollments_csv.id);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation enrollment_completion {
        label: 'Enrollment Completion'
        formula: @aql count(enrollments_csv.id) | where(enrollments_csv.status == 'completed');;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation avg_rating {
        label: 'Average of Course reviews Rating'
        formula: @aql avg(course_reviews_csv.rating);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation avg_days_to_complete {
        label: 'Avg Days To Complete'
        formula: @aql avg(date_diff('day', enrollments_csv.enrolled_at, enrollments_csv.completed_at)) 
| where(enrollments_csv.status == 'completed', enrollments_csv.completed_at > enrollments_csv.enrolled_at);;
        calc_type: 'measure'
        data_type: 'number'
      }
      fields: [
        VizFieldFull {
          ref: r(courses_csv.title)
          format {
            type: 'text'
          }
          uname: 'courses_csv_title'
        },
        VizFieldFull {
          ref: r(courses_csv.category)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          label: 'Total Enrollments'
          ref: 'metric_2c6b485'
          format {
            type: 'number'
            pattern: 'inherited'
          }
          uname: 'custom_metric_2c6b485_1'
        },
        VizFieldFull {
          label: 'Completions'
          ref: 'enrollment_completion'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          label: 'Completion Rate'
          ref: r(minh_edu.overall_completion_rate)
          format {
            type: 'number'
            pattern: '#,###%'
          }
        },
        VizFieldFull {
          label: 'Avg rating'
          ref: 'avg_rating'
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
        },
        VizFieldFull {
          ref: 'avg_days_to_complete'
          format {
            type: 'number'
            pattern: '#,###'
          }
        }
      ]
      settings {
        show_row_number: true
        sorts: [
          SortSetting {
            key: 'custom_metric_2c6b485_1'
            direction: 'desc'
          }
        ]
        row_limit: 10000
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        column_styles: [
          ColumnStyle {
            key: 'courses_csv_title'
            width: 233.93359375
          }
        ]
      }
    }
  }
  block v_qijb: VizBlock {
    label: 'Total enrolled'
    viz: MetricKpi {
      dataset: minh_edu
      value: VizFieldFull {
        label: 'Total enrolled'
        ref: r(enrollments_csv.id)
        aggregation: 'count'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }
