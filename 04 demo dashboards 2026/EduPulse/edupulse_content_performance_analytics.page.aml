    label: 'Total enrolled copy'
    viz: MetricKpi {
      dataset: minh_edu
      calculation metric_e6df75a {
        label: 'Untitled Metric'
        formula: @aql count(enrollments_csv.id) | where(enrollments_csv.status == 'completed');;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        label: 'Completed'
        ref: 'metric_e6df75a'
        format {
          type: 'number'
          pattern: 'inherited'
