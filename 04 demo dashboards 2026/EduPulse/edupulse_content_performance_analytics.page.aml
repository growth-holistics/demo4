  block v_4qfr: VizBlock {
    label: 'instructors table'
    viz: DataTable {
      dataset: minh_edu
      calculation metric_abcf2a7 {
        label: 'Count distinct of Courses Id'
        formula: @aql count_distinct(courses_csv.id);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation avg_days_to_complete {
        label: 'Avg Days To Complete'
        formula: @aql avg(date_diff('day', enrollments_csv.enrolled_at, enrollments_csv.completed_at)) | where(enrollments_csv.status == 'completed', enrollments_csv.completed_at > enrollments_csv.enrolled_at);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation active_learners {
        label: 'Active Learners'
        formula: @aql count(enrollments_csv.id) | where(enrollments_csv.status == 'enrolled' or enrollments_csv.status == 'in_progress');;
        calc_type: 'measure'
        data_type: 'number'
      }
      fields: [
        VizFieldFull {
          label: 'Instructor Photo'
          ref: r(courses_csv.instructor_photo_image)
          format {
            type: 'html'
          }
          uname: 'courses_csv_instructor_photo_image'
        },
        VizFieldFull {
          ref: r(courses_csv.instructor_name)
          format {
            type: 'text'
          }
          uname: 'courses_csv_instructor_name'
        },
        VizFieldFull {
          label: 'Total Enrollments'
          ref: r(minh_edu.metric_a0a766f)
          format {
            type: 'number'
            pattern: 'inherited'
          }
          uname: 'custom_metric_a0a766f'
        },
        VizFieldFull {
          ref: r(minh_edu.completion_rate)
          format {
            type: 'number'
            pattern: '#,###%'
          }
          uname: 'custom_completion_rate'
        },
        VizFieldFull {
          ref: 'avg_days_to_complete'
          format {
            type: 'number'
            pattern: '#,###'
          }
          uname: 'custom_avg_days_to_complete'
        },
        VizFieldFull {
          label: 'AVG of Quiz Score'
          ref: r(minh_edu.avg_quiz_result)
          format {
            type: 'number'
            pattern: 'inherited'
          }
          uname: 'custom_avg_quiz_result'
        },
        VizFieldFull {
          ref: 'active_learners'
          format {
            type: 'number'
            pattern: '#,###'
          }
        }
      ]
      settings {
        wrap_header_text: true
        show_row_number: true
        sorts: [
          SortSetting {
            key: 'custom_metric_a0a766f'
            direction: 'desc'
          }
        ]
        row_limit: 10000
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        frozen_columns: 0
        column_styles: [
          ColumnStyle {
            key: 'courses_csv_instructor_photo_image'
            width: 103.64453125
          },
          ColumnStyle {
            key: 'courses_csv_instructor_name'
            width: 135
          },
          ColumnStyle {
            key: 'custom_metric_a0a766f'
            width: 102.9140625
          },
          ColumnStyle {
            key: 'custom_completion_rate'
            width: 104.21875
          },
          ColumnStyle {
            key: 'custom_avg_quiz_result'
            width: 98.46875
          },
          ColumnStyle {
            key: 'custom_avg_days_to_complete'
            width: 89.0703125
          }
        ]
      }
    }
    settings {
      hide_label: true
    }
  }
  block t_52xu: TextBlock {
    content: @md <div style="width:100%;display:flex;align-items:center;padding:16px 16px;box-sizing:border-box;border-left:4px solid #A5DBE3;margin:1.5rem 0 2rem 0;">
  <div>
    <p style="margin:0 0 8px 0;font-size:14px;font-weight:600;color:#09495A;line-height:1.4;">
      🌟 Our <span style="color:#0F647B;text-decoration:underline;text-decoration-color:#A5DBE3;text-underline-offset:3px;">top-performing instructors</span> 
      maintain completion rates above <span style="color:#0F647B;text-decoration:underline;text-decoration-color:#A5DBE3;text-underline-offset:3px;">20%</span> 
      while achieving ratings of <span style="color:#0F647B;text-decoration:underline;text-decoration-color:#A5DBE3;text-underline-offset:3px;">5.0+</span>.
    </p>
    <p style="margin:0;font-size:13px;color:#4a6370;line-height:1.6;">
      They engage learners through <strong style="color:#09495A;">clear course structure</strong>, timely support, and 
      <strong style="color:#09495A;">practical examples</strong>. Focus on replicating their teaching approaches to improve overall platform performance.
    </p>
  </div>
</div>;;
    theme: clear_block_theme
  }
  block t_lqyb: TextBlock {
    theme: clear_block_theme
    content: @md <div style="width:100%;display:flex;align-items:center;padding:16px 16px;box-sizing:border-box;border-left:4px solid #A5DBE3;margin:1.5rem 0 2rem 0;">
  <div>
    <p style="margin:0 0 8px 0;font-size:14px;font-weight:600;color:#09495A;line-height:1.4;">
      💡 Understanding <span style="color:#0F647B;text-decoration:underline;text-decoration-color:#A5DBE3;text-underline-offset:3px;">growth patterns</span> 
      helps predict future demand and allocate resources to <span style="color:#0F647B;text-decoration:underline;text-decoration-color:#A5DBE3;text-underline-offset:3px;">high-performing periods</span>.
    </p>
    <p style="margin:0;font-size:13px;color:#4a6370;line-height:1.6;">
      Strong <strong style="color:#09495A;">returning learner rates</strong> indicate platform stickiness, while 
      <strong style="color:#09495A;">consistent enrollment growth</strong> signals effective marketing and course quality.
    </p>
  </div>
</div>;;
