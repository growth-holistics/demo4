  block v_ups4: VizBlock {
    label: 'Category'
    viz: MarkdownViz {
      dataset: minh_edu
      rows: [
        VizFieldFull {
          ref: r(courses_csv.category)
          format {
            type: 'text'
          }
        }
      ]
      content: @md <style>
  .category-filters {
    display: flex;
    gap: 1rem;
    padding: 1.5rem;
    flex-wrap: wrap;
    align-items: center;
  }
  
  .filter-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #2F6F71;
  }
  
  .category-button {
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #FFFFFF 0%, #F8FAFB 100%);
    border: 2px solid #C5E5E8;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #2F6F71;
    text-transform: capitalize;
  }
  
  .category-button:hover {
    border-color: #5F9EA0;
    background: linear-gradient(135deg, #F0F9FA 0%, #E8F4F5 100%);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(95, 158, 160, 0.2);
  }
  
  .h-drill-selected.category-button {
    border-color: #2F6F71;
    background: linear-gradient(135deg, #5F9EA0 0%, #2F6F71 100%);
    color: #FFFFFF;
    box-shadow: 0 4px 16px rgba(47, 111, 113, 0.3);
