  block table_campaign_performance_by_media_source: VizBlock {
    label: 'Campaign performance by Media source'
    viz: PivotTable {
      dataset: af_marketing_performance
      calculation impressions {
        label: 'Impressions'
        formula: @aql af_fact_daily_spend | sum(af_fact_daily_spend.impressions);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation clicks {
        label: 'Clicks'
        formula: @aql af_fact_daily_spend | sum(af_fact_daily_spend.clicks);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation installs {
        label: 'Installs'
        formula: @aql af_fact_daily_spend | sum(af_fact_daily_spend.installs);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation re_attributions {
        label: 'Re Attributions'
        formula: @aql af_fact_daily_spend | sum(af_fact_daily_spend.re_attributions);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation re_engagements {
        label: 'Re Engagements'
        formula: @aql af_fact_daily_spend | sum(af_fact_daily_spend.re_engagements);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation cost {
        label: 'Cost ($)'
        formula: @aql af_fact_daily_spend | sum(af_fact_daily_spend.spend_amount);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation ecpi {
        label: 'eCPI ($)'
        formula: @aql safe_divide(cost, installs);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation revenue {
        label: 'Revenue ($)'
        formula: @aql af_fact_revenue | sum(af_fact_revenue.amount);;
        calc_type: 'measure'
        data_type: 'number'
      }
      rows: [
        VizFieldFull {
          label: 'Media Source'
          ref: r(af_dim_campaigns.channel)
          format {
            type: 'text'
          }
          uname: 'af_dim_campaigns_channel_1'
        },
        VizFieldFull {
          label: 'Campaign Name'
          ref: r(af_dim_campaigns.name)
          format {
            type: 'text'
          }
          uname: 'af_dim_campaigns_name_1'
        }
      ]
      values: [
        VizFieldFull {
          label: 'Impressions'
          ref: 'impressions'
          format {
            type: 'number'
            pattern: '#,###0'
          }
          uname: 'custom_impressions'
        },
        VizFieldFull {
          label: 'Clicks'
          ref: 'clicks'
          format {
            type: 'number'
            pattern: '#,###0'
          }
          uname: 'custom_clicks'
        },
        VizFieldFull {
          label: 'Installs'
          ref: 'installs'
          format {
            type: 'number'
            pattern: '#,###0'
          }
          uname: 'custom_installs'
        },
        VizFieldFull {
          label: 'Re Attributions'
          ref: 're_attributions'
          format {
            type: 'number'
            pattern: '#,###0'
          }
          uname: 'custom_re_attributions'
        },
        VizFieldFull {
          label: 'Re Engagements'
          ref: 're_engagements'
          format {
            type: 'number'
            pattern: '#,###0'
          }
          uname: 'custom_re_engagements'
        },
        VizFieldFull {
          label: 'Cost ($)'
          ref: 'cost'
          format {
            type: 'number'
            pattern: '[$]#,###0.00'
          }
          uname: 'custom_cost'
        },
        VizFieldFull {
          label: 'eCPI ($)'
          ref: 'ecpi'
          format {
            type: 'number'
            pattern: '[$]#,###0.00'
          }
          uname: 'custom_ecpi'
        },
        VizFieldFull {
          label: 'Revenue ($)'
          ref: 'revenue'
          format {
            type: 'number'
            pattern: '[$]#,###0.00'
          }
          uname: 'custom_revenue'
        }
      ]
      settings {
        wrap_header_text: true
        pagination_size: 100
        show_row_total: true
        show_sub_total: true
        sorts: [
          SortSetting {
            key: 'af_dim_campaigns_channel_1'
            direction: 'asc'
          },
          SortSetting {
            key: 'af_dim_campaigns_name_1'
            direction: 'asc'
          }
        ]
        row_limit: 100
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        frozen_columns: 2
        column_styles: [
          ColumnStyle {
            key: 'af_dim_campaigns_channel_1'
            width: 136
          },
          ColumnStyle {
            key: 'af_dim_campaigns_name_1'
            width: 207
          },
          ColumnStyle {
            key: 'custom_impressions'
            width: 124
          },
          ColumnStyle {
            key: 'custom_clicks'
            width: 89
          },
          ColumnStyle {
            key: 'custom_installs'
            width: 94
          },
          ColumnStyle {
            key: 'custom_re_attributions'
            width: 139
          },
          ColumnStyle {
            key: 'custom_re_engagements'
            width: 150
          },
          ColumnStyle {
            key: 'custom_cost'
            width: 100
          },
          ColumnStyle {
            key: 'custom_ecpi'
            width: 100
          },
          ColumnStyle {
            key: 'custom_revenue'
            width: 123
          }
        ]
      }
    }
  }

  view: CanvasLayout {
    label: 'View 1'
    width: 1340
    height: 2480
    grid_size: 20
    auto_expand_vertically: true
    block title {
      position: pos(20, 20, 1300, 160)
    }
    // Filters + KPIs (no section header)
    block filter_app {
      position: pos(20, 200, 300, 80)
    }
    block filter_date_range {
      position: pos(340, 200, 300, 80)
    }
    block filter_view_type {
      position: pos(660, 200, 300, 80)
    }
    block filter_channel {
      position: pos(980, 200, 340, 80)
    }
    block kpi_active_users {
      position: pos(20, 300, 200, 140)
    }
    block kpi_revenue_actual {
      position: pos(240, 300, 200, 140)
    }
    block kpi_cost {
      position: pos(460, 300, 200, 140)
    }
    block kpi_attributions {
      position: pos(680, 300, 200, 140)
    }
    block kpi_revenue_d7 {
      position: pos(900, 300, 200, 140)
    }
    block kpi_roas_d7 {
      position: pos(1120, 300, 200, 140)
    }
    // 01 Trends
    block divider_trends {
      position: pos(20, 460, 1300, 60)
    }
    block chart_active_users_revenue {
      position: pos(20, 540, 640, 320)
    }
    block chart_top_event_unique_users_mom {
      position: pos(680, 540, 640, 320)
    }
    block divider_deep_dive {
      position: pos(20, 880, 1300, 60)
    }
    block chart_attributions_by_media_source {
      position: pos(20, 960, 640, 320)
    }
    block chart_attributions_by_app {
      position: pos(680, 960, 640, 320)
    }
    block divider_breakdown {
      position: pos(20, 1300, 1300, 60)
    }
    block chart_revenue_by_geo {
      position: pos(20, 1380, 640, 420)
    }
    block chart_top_events {
      position: pos(680, 1380, 640, 420)
    }
    block divider_campaign {
      position: pos(20, 1820, 1300, 60)
    }
    block table_campaign_performance_by_media_source {
      position: pos(20, 1900, 1300, 540)
    }
    mobile {
      mode: 'auto'
    }
    auto_expand_horizontally: true
    default_zoom: 'fit_to_width'
  }
  theme: ghibli_meadow
}