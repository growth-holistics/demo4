  block kpi_roas_d7: VizBlock {
    label: 'ROAS D7'
    viz: MetricKpi {
      dataset: af_marketing_performance
      calculation d7_revenue {
        label: 'D7 Revenue'
        formula: @aql af_fact_cohort_revenue | where(af_fact_cohort_revenue.day_number == 7) | sum(af_fact_cohort_revenue.cumulative_revenue);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation last_30_days_spend {
        label: 'Last 30 Days Spend'
        formula: @aql af_fact_daily_spend | sum(af_fact_daily_spend.spend_amount);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation roas_d7 {
        label: 'ROAS D7'
        formula: @aql safe_divide(d7_revenue, last_30_days_spend);;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        label: 'ROAS D7'
        ref: 'roas_d7'
        format {
          type: 'number'
          pattern: '#,###0.0%'
        }
      }
      compare_value: VizPopSettings {
        field: r(af_dim_dates.date)
        value: RelativePopValue {
          duration: 30
          granularity: 'day'
        }
        show_growth_rate: true
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_size: 16
        }
        alignment: 'left'
        metric_value {
          font_size: 40
        }
        compare_value {
          font_size: 16
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  // ===== Section dividers =====
  block divider_trends: TextBlock {
    content: @md <div class="sec-bar" style="background: #000; padding: 12px 20px; border-radius: 6px; display: flex; align-items: baseline; gap: 10px;">
  <span class="sec-num" style="font-family: 'Arial Black', Impact, sans-serif; font-size: 13px; font-weight: 900; color: #000; background: #A8C846; padding: 4px 10px; border-radius: 3px; letter-spacing: 3px;">01</span>
  <span class="sec-title" style="font-family: 'Arial Black', Impact, sans-serif; font-size: 13px; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: 2px;">Trends</span>
  <span class="sec-sub" style="font-family: Arial, sans-serif; font-size: 13px; color: #999;">— Are users growing? Is revenue following?</span>
</div>;;
  }
  block divider_deep_dive: TextBlock {
    content: @md <div class="sec-bar" style="background: #000; padding: 12px 20px; border-radius: 6px; display: flex; align-items: baseline; gap: 10px;">
  <span class="sec-num" style="font-family: 'Arial Black', Impact, sans-serif; font-size: 13px; font-weight: 900; color: #000; background: #A8C846; padding: 4px 10px; border-radius: 3px; letter-spacing: 3px;">02</span>
  <span class="sec-title" style="font-family: 'Arial Black', Impact, sans-serif; font-size: 13px; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: 2px;">Acquisition</span>
  <span class="sec-sub" style="font-family: Arial, sans-serif; font-size: 13px; color: #999;">— Which channels and apps drive installs?</span>
</div>;;
  }
  block divider_breakdown: TextBlock {
    content: @md <div class="sec-bar" style="background: #000; padding: 12px 20px; border-radius: 6px; display: flex; align-items: baseline; gap: 10px;">
  <span class="sec-num" style="font-family: 'Arial Black', Impact, sans-serif; font-size: 13px; font-weight: 900; color: #000; background: #A8C846; padding: 4px 10px; border-radius: 3px; letter-spacing: 3px;">03</span>
  <span class="sec-title" style="font-family: 'Arial Black', Impact, sans-serif; font-size: 13px; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: 2px;">Deep Dive</span>
  <span class="sec-sub" style="font-family: Arial, sans-serif; font-size: 13px; color: #999;">— Revenue by geography & top user actions</span>
</div>;;
  }
  block divider_campaign: TextBlock {
    content: @md <div class="sec-bar" style="background: #000; padding: 12px 20px; border-radius: 6px; display: flex; align-items: baseline; gap: 10px;">
  <span class="sec-num" style="font-family: 'Arial Black', Impact, sans-serif; font-size: 13px; font-weight: 900; color: #000; background: #A8C846; padding: 4px 10px; border-radius: 3px; letter-spacing: 3px;">04</span>
  <span class="sec-title" style="font-family: 'Arial Black', Impact, sans-serif; font-size: 13px; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: 2px;">Campaign Detail</span>
  <span class="sec-sub" style="font-family: Arial, sans-serif; font-size: 13px; color: #999;">— Every campaign, side by side</span>
</div>;;
  }
  block chart_active_users_revenue: VizBlock {
    label: 'Active users & revenue (actual)'
    viz: CombinationChart {
      dataset: af_marketing_performance
      calculation active_users {
        label: 'Active Users'
        formula: @aql af_fact_daily_active_users | sum(af_fact_daily_active_users.active_users);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation revenue_actual {
        label: 'Revenue (actual)'
        formula: @aql af_fact_revenue | sum(af_fact_revenue.amount);;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        label: 'Date'
        ref: r(af_dim_dates.date)
        transformation: 'datetrunc day'
        format {
          type: 'date'
          pattern: 'LLL dd, yyyy'
        }
        uname: 'af_dim_dates_date_2'
      }
      y_axis {
        series {
          mark_type: 'column'
          field: VizFieldFull {
            label: 'Active Users'
            ref: 'active_users'
            format {
              type: 'number'
              pattern: '#,###0'
            }
          }
          settings {
            color: '#BED829FF'
          }
        }
      }
      y_axis {
        settings {
          alignment: 'right'
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            label: 'Revenue (actual)'
            ref: 'revenue_actual'
            format {
              type: 'number'
              pattern: '[$]#,###0.00'
              group_separator: ','
              decimal_separator: '.'
            }
          }
        }
      }
      settings {
        row_limit: 100
        x_axis_label: 'Date'
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
