  block kpi_active_users: VizBlock {
    label: 'Active Users compared with Active Users (Prev. 1m)'
    viz: MetricKpi {
      dataset: af_marketing_performance
      calculation active_users_last_30_days {
        label: 'Active Users'
        formula: @aql af_fact_daily_active_users | sum(af_fact_daily_active_users.active_users);;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        label: 'Active Users'
        ref: 'active_users_last_30_days'
        format {
          type: 'number'
          pattern: '#,###0.00,,"M"'
          group_separator: ','
          decimal_separator: '.'
        }
      }
      compare_value: VizPopSettings {
        field: r(af_dim_dates.date)
        value: RelativePopValue {
          duration: 1
          granularity: 'month'
        }
        show_growth_rate: true
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_size: 16
          font_color: '#FFFFFFFF'
        }
        alignment: 'left'
        metric_value {
          font_size: 40
        }
        compare_value {
          font_size: 16
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block kpi_revenue_actual: VizBlock {
    label: 'Revenue (actual) compared with Revenue (actual) (Prev. 30d)'
    viz: MetricKpi {
      dataset: af_marketing_performance
      calculation revenue_actual {
        label: 'Revenue (actual)'
        formula: @aql sum(af_fact_revenue.amount);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation metric_c8cbf6d {
        label: 'PoP Comparison of Revenue (actual)'
        formula: @aql revenue_actual | relative_period(af_dim_dates.date, interval(-1 month), strict: true);;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        label: 'Revenue'
        ref: 'revenue_actual'
        format {
          type: 'number'
          pattern: '#,###0.00,"K"'
          group_separator: ','
          decimal_separator: '.'
        }
      }
      compare_value: VizPopSettings {
        field: r(af_dim_dates.date)
        value: RelativePopValue {
          duration: 30
          granularity: 'day'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_size: 16
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }
