  }
  block f_plan: FilterBlock {
    label: 'Plan'
    type: 'field'
    source: FieldFilterSource {
      dataset: product_usage_analytics
      field: r(plans.name)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
  }
  block t_lowu: TextBlock {
    content: @md ### Feature adoption;;
  }
  block f_category: FilterBlock {
    label: 'Category'
    type: 'field'
    source: FieldFilterSource {
      dataset: product_usage_analytics
      field: r(features.category)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
  }
  block f_date_range: FilterBlock {
    label: 'Date range'
    type: 'field'
    source: FieldFilterSource {
      dataset: product_usage_analytics
      field: r(feature_events.used_at)
    }
    default {
      operator: 'matches'
      value: '$H_NIL$'
    }
  }
  block v_k3lg: VizBlock {
    label: 'Total users compared with Total users (Prev. 1y)'
    viz: MetricKpi {
      dataset: product_usage_analytics
      value: VizFieldFull {
        label: 'Total users'
        ref: r(engagement_kpi_summary.total_users)
        aggregation: 'sum'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        label {
          font_color: '#1A1816FF'
        }
        alignment: 'left'
        metric_value {
          font_color: '#211F1CFF'
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_xzut: VizBlock {
