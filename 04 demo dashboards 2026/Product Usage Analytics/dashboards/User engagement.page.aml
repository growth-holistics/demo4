          pattern: 'LLL yyyy'
        }
      }
      legend: VizFieldFull {
        ref: r(usage_by_category.category)
        format {
          type: 'text'
        }
      }
      y_axis {
        label: 'Usage count'
        series {
          field: VizFieldFull {
            label: ' '
            ref: r(usage_by_category.usage_count)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            point {
              value: 'AI'
              color: '#3B2F80'
            }
            point {
              value: 'Automation'
              color: '#6E7B4E'
            }
            point {
              value: 'Collaboration'
              color: '#B5798E'
            }
            point {
              value: 'Core'
              color: '#E07A3AFF'
            }
            point {
              value: 'Integration'
              color: '#3B2F80'
            }
          }
        }
      }
      settings {
        row_limit: 10000
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_vmna: VizBlock {
    label: 'Feature adoption vs usage intensity'
    viz: ScatterChart {
      dataset: product_usage_analytics
      x_col: VizFieldFull {
        ref: r(feature_adoption_vs_usage.adoption_rate)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      y_col: VizFieldFull {
        ref: r(feature_adoption_vs_usage.avg_usage_per_user)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        row_limit: 10000
      }
    }
  }
  block v_jsun: VizBlock {
    label: 'Avg adoption rate'
    viz: MetricKpi {
      dataset: product_usage_analytics
      value: VizFieldFull {
        label: 'Avg adoption rate'
        ref: r(feature_kpi_summary.avg_adoption_rate)
        aggregation: 'sum'
        format {
          type: 'number'
          pattern: '#,###0.00\\%'
          group_separator: ','
          decimal_separator: '.'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_pulb: VizBlock {
    label: 'AI feature growth (MoM)'
    viz: MetricKpi {
      dataset: product_usage_analytics
      value: VizFieldFull {
        label: 'AI feature growth (MoM)'
        ref: r(feature_kpi_summary.ai_mom_growth)
