  block v_aqd2: VizBlock {
    label: 'Monthly metrics overview'
    viz: MetricSheet {
      dataset: product_usage_analytics
      theme {
        table {
          general {
            bg_color: '#FFFFFFFF'
          }
        }
      }
      date_field: VizFieldFull {
        ref: r(monthly_engagement_summary.month)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      rows: [
        MetricHeading {
          label: 'User engagement'
          settings {
            background_color: '#e1e3ea'
            text_color: '#31353f'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Total users'
            ref: r(monthly_engagement_summary.total_users)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Monthly active users'
            ref: r(monthly_engagement_summary.mau)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Avg. daily active users'
            ref: r(monthly_engagement_summary.avg_dau)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Stickiness rate'
            ref: r(monthly_engagement_summary.stickiness_pct)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###\\%'
            }
          }
          settings {
            mark_type: 'line'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Total sessions'
            ref: r(monthly_engagement_summary.total_sessions)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
          settings {
            mark_type: 'line'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Avg. sessions per user'
            ref: r(monthly_engagement_summary.avg_sessions_per_user)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            mark_type: 'line'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Avg. session duration'
            ref: r(monthly_engagement_summary.avg_session_duration)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            mark_type: 'line'
          }
        },
        MetricHeading {
          label: 'Content creation'
          settings {
            background_color: '#e1e3ea'
            text_color: '#31353f'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Pages created'
            ref: r(monthly_engagement_summary.pages_created)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Avg. word count'
            ref: r(monthly_engagement_summary.avg_word_count)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Unique creators'
            ref: r(monthly_engagement_summary.unique_creators)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
          settings {
            mark_type: 'line'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Total activities'
            ref: r(monthly_engagement_summary.total_activities)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Edits'
            ref: r(monthly_engagement_summary.edits)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Comments'
            ref: r(monthly_engagement_summary.comments)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
        },
        MetricHeading {
          label: 'Feature adoption'
          settings {
            background_color: '#e1e3ea'
            text_color: '#31353f'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Feature active users'
            ref: r(monthly_engagement_summary.feature_active_users)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Feature adoption rate'
            ref: r(monthly_engagement_summary.feature_adoption_pct)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'AI events'
            ref: r(monthly_engagement_summary.ai_events)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
          settings {
            mark_type: 'line'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'AI users'
            ref: r(monthly_engagement_summary.ai_users)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
        },
        MetricHeading {
          label: 'Device mix'
          settings {
            background_color: '#e1e3ea'
            text_color: '#31353f'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Desktop share'
            ref: r(monthly_engagement_summary.desktop_pct)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00\\%'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            mark_type: 'line'
          }
        },
        MetricSeries {
          field: VizFieldFull {
            label: 'Mobile share'
            ref: r(monthly_engagement_summary.mobile_pct)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00\\%'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            mark_type: 'line'
          }
        }
      ]
      settings {
        max_column: 7
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_controls: true
    }
  }
  block v_pqhr: VizBlock {
    label: 'Stickiness (DAU/MAU)'
    description: @md How consistently do they return daily?
;;
    viz: MetricKpi {
      dataset: product_usage_analytics
      calculation metric_e0967c6 {
        label: 'Average of Stickiness Ratio Stickiness Ratio'
        formula: @aql avg(stickiness_ratio.stickiness_ratio);;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        label: 'Stickiness (DAU/MAU)'
        ref: 'metric_e0967c6'
        format {
          type: 'number'
          pattern: '#,###%'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }

