Dashboard user_engagement {
  title: 'User engagement'
  description: ''
  owner: 'thang.lk@holistics.io'
  block title: TextBlock {
    content: @md ### User engagement;;
  }
  block v_q5t9: VizBlock {
    label: 'User health'
    viz: PieChart {
      dataset: product_usage_analytics
      legend: VizFieldFull {
        ref: r(users_.is_active_label)
        format {
          type: 'text'
        }
      }
      series {
        field: VizFieldFull {
          label: 'users'
          ref: r(users_.user_count)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
        settings {
          point {
            value: 'Active'
            color: '#E07A3AFF'
          }
          point {
            value: 'Inactive'
            color: '#1A1816FF'
          }
        }
      }
      settings {
        display_as_donut: true
        row_limit: 10000
        legend_label: 'hidden'
        show_percentage: true
        data_label_position: 'outside'
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_3akc: VizBlock {
    label: 'Active users trend'
    viz: LineChart {
      dataset: product_usage_analytics
      x_axis: VizFieldFull {
        ref: r(user_sessions.started_at_shifted)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            label: 'Unique active users'
            ref: r(user_sessions.unique_active_users)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#6E7B4E'
          }
        }
      }
      settings {
        row_limit: 10000
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_pypf: VizBlock {
    label: 'DAU/MAU Stickiness Ratio'
    description: 'How often monthly users return daily. Calculated as Daily Active Users / Monthly Active Users.'
    viz: LineChart {
      dataset: product_usage_analytics
      calculation metric_269226f {
        label: 'Avg. of Stickiness Ratio Stickiness Ratio'
        formula: @aql avg(stickiness_ratio.stickiness_ratio);;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        ref: r(stickiness_ratio.month)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'dd LLL'
        }
      }
      y_axis {
        settings {
          show_data_label_by: 'value'
          stack_series_by: 'value'
        }
        series {
          field: VizFieldFull {
            label: 'Stickiness Ratio (%)'
            ref: 'metric_269226f'
            format {
              type: 'number'
              pattern: '#,###0.00%'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            color: '#B5798E'
            line_interpolation: 'smooth'
          }
        }
      }
      settings {
        row_limit: 10000
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_tmun: VizBlock {
    label: 'Weekly session frequency'
    description: 'Avg. number of sessions per active user each week'
    viz: ColumnChart {
      dataset: product_usage_analytics
      calculation metric_4d5ba11 {
        label: 'Avg. of Session Frequency Sessions Per User'
        formula: @aql avg(session_frequency.sessions_per_user);;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        ref: r(session_frequency.week)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        label: 'Sessions Per User'
        settings {
          show_data_label_by: 'value'
        }
        series {
          field: VizFieldFull {
            label: 'Sessions per user'
            ref: 'metric_4d5ba11'
            format {
              type: 'number'
              pattern: '#,###0.00'
            }
          }
          settings {
            color: '#245E54'
          }
        }
      }
      settings {
        row_limit: 10000
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_m0aw: VizBlock {
    label: 'Pages created over time'
    viz: LineChart {
      dataset: product_usage_analytics
      x_axis: VizFieldFull {
        ref: r(pages.created_at_shifted)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            label: 'Pages created'
            ref: r(pages.id)
            aggregation: 'count'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
          settings {
            color: '#A67C52FF'
          }
        }
      }
      settings {
        row_limit: 10000
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_75vq: VizBlock {
    label: 'Active users by plan'
    viz: CombinationChart {
      dataset: product_usage_analytics
      x_axis: VizFieldFull {
        ref: r(engagement_by_plan.month)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      legend: VizFieldFull {
        ref: r(engagement_by_plan.plan_name)
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          show_stack_total: true
          show_total_in_tooltip: true
        }
        series {
          field: VizFieldFull {
            label: ' plan'
            ref: r(engagement_by_plan.active_users)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
          settings {
            point {
              value: 'business'
              color: '#E07A3AFF'
            }
            point {
              value: 'enterprise'
              color: '#6E7B4E'
            }
            point {
              value: 'free'
              color: '#802222'
            }
            point {
              value: 'plus'
              color: '#D4A574FF'
            }
          }
        }
      }
      settings {
        show_data_points: true
        show_rows_with_no_data: true
        row_limit: 10000
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_hn10: VizBlock {
    label: 'Feature usage trend'
    viz: LineChart {
      dataset: product_usage_analytics
      x_axis: VizFieldFull {
        ref: r(feature_usage_trend.month)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      legend: VizFieldFull {
        ref: r(feature_usage_trend.feature_name)
        format {
          type: 'text'
        }
      }
      y_axis {
        label: 'Usage count'
        settings {
          show_total_in_tooltip: true
        }
        series {
          field: VizFieldFull {
            label: ' '
            ref: r(feature_usage_trend.usage_count)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
        }
      }
      settings {
        show_rows_with_no_data: true
        row_limit: 10000
        legend_label: 'right'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_qdav: VizBlock {
    label: 'Feature adoption by plan'
    viz: BarChart {
      dataset: product_usage_analytics
      x_axis: VizFieldFull {
        ref: r(adoption_by_plan.feature_name)
        format {
          type: 'text'
        }
      }
      legend: VizFieldFull {
        ref: r(adoption_by_plan.plan_name)
        format {
          type: 'text'
        }
      }
      y_axis {
        label: 'Adoption rate'
        settings {
          show_data_label_by: 'value'
          hidden: true
        }
        series {
          field: VizFieldFull {
            label: 'plan user'
            ref: r(adoption_by_plan.adoption_rate)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###\\%'
            }
          }
          settings {
            point {
              value: 'business'
              color: '#E07A3AFF'
            }
            point {
              value: 'enterprise'
              color: '#6E7B4E'
            }
            point {
              value: 'free'
              color: '#802222'
            }
            point {
              value: 'plus'
              color: '#D4A574FF'
            }
          }
        }
      }
      tooltips: [
        VizTooltip {
          field: VizFieldFull {
            label: 'plan users'
            ref: r(adoption_by_plan.users_who_used)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
              group_separator: ','
              decimal_separator: '.'
            }
          }
        }
      ]
      settings {
        show_rows_with_no_data: true
        row_limit: 10000
        sort {
          field_index: 0
          direction: 'desc'
          type: 'xaxis'
        }
        legend_label: 'right'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_xpal: VizBlock {
    label: 'AI feature spotlight '
    viz: LineChart {
      dataset: product_usage_analytics
      x_axis: VizFieldFull {
        ref: r(ai_feature_spotlight.month)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      legend: VizFieldFull {
        ref: r(ai_feature_spotlight.feature_name)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(ai_feature_spotlight.usage_count)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: '#,###0.00,"K"'
            }
          }
          settings {
            point {
              value: 'AI Summarization'
              color: '#E07A3AFF'
            }
            point {
              value: 'AI Writing Assistant'
              color: '#245E54'
            }
          }
        }
      }
      settings {
        row_limit: 10000
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_csbm: VizBlock {
    label: 'Usage share by category'
    viz: AreaChart {
      dataset: product_usage_analytics
      x_axis: VizFieldFull {
        ref: r(usage_by_category.month)
        transformation: 'datetrunc month'
        format {
