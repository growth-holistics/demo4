  }
  block v_8y6d: VizBlock {
    label: 'Monthly active users'
    viz: MetricKpi {
      dataset: product_usage_analytics
      value: VizFieldFull {
        label: 'Monthly active users'
        ref: r(feature_kpi_summary.monthly_active_users)
