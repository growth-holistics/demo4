  block f_3exu: FilterBlock {
    label: 'Plan'
    type: 'field'
    source: FieldFilterSource {
      dataset: product_usage_analytics
      field: r(plans.name)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
