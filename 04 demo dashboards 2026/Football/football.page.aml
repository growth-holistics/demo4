  block v_ujun: VizBlock {
    label: 'Results'
    viz: DataTable {
      dataset: football_data
      calculation dim_home_team_with_logo {
        label: 'Home'
        formula: @aql concat(
          '<span style="margin:8px 0;display:flex;flex-direction:column;align-items:center;gap:8px;white-space:nowrap;"><img src="',
            home_team.logo_html,
            '" style="height:24px;border-radius:4px;"> ',
            home_team.team_name,
          '</span>'
        );;
        calc_type: 'dimension'
        data_type: 'text'
        model: matches_csv
      }
      calculation dim_result_text {
        label: 'Result'
        formula: @aql concat(
           '<div style="margin:20px auto;display:flex;flex-direction:column;align-items:center;gap:8px;white-space:nowrap;font-size:24px;">',cast(matches_csv.home_team_score, 'text'),
          ' - ',
          cast(matches_csv.away_team_score, 'text'),
          '</div>'
        );;
        calc_type: 'dimension'
        data_type: 'text'
        model: matches_csv
      }
      calculation dim_away_team_with_logo {
        label: 'Away'
        formula: @aql concat(
  '<span style="margin:8px 0;display:flex;flex-direction:column;    align-items:center;gap:8px;white-space:nowrap;"><img src="',
    away_team.logo_html,
    '" style="height:24px;border-radius:4px;"> ',
    away_team.team_name,
  '</span>'
);;
        calc_type: 'dimension'
        data_type: 'text'
        model: matches_csv
      }
      calculation dimension_74b8919 {
        label: 'Result (Home - Away)'
        formula: @aql concat(
  '<div style="margin:6px;display:flex;align-items:center;justify-content:center;gap:20px;width:100%;">',

    '<span style="display:flex;flex-direction:column;align-items:center;gap:8px;width:33.33%;text-align:center;white-space:normal;word-wrap:break-word;font-weight:600;">',
      '<img src="', home_team.logo_html, '" style="height:28px;border-radius:4px;">',
      home_team.team_name,
    '</span>',

    '<span style="display:inline-flex;font-size:28px;font-weight:600;width:33.33%;justify-content:center;align-items:center;gap:6px;">',
      cast(matches_csv.home_team_score, 'text'),
      '<span style="opacity:70%"> - </span>',
      cast(matches_csv.away_team_score, 'text'),
    '</span>',

    '<span style="display:flex;flex-direction:column;align-items:center;gap:8px;width:33.33%;text-align:center;white-space:normal;word-wrap:break-word;font-weight:600;">',
      '<img src="', away_team.logo_html, '" style="height:28px;border-radius:4px;">',
      away_team.team_name,
    '</span>',

  '</div>'
);;
        calc_type: 'dimension'
        data_type: 'text'
        model: matches_csv
      }
      fields: [
        VizFieldFull {
          ref: r(matches_csv.date_time)
          format {
            type: 'date'
            pattern: 'LLL dd, yyyy'
          }
          uname: 'matches_csv_date_time_1'
        },
        VizFieldFull {
          ref: ref('matches_csv', 'dimension_74b8919')
          format {
            type: 'html'
          }
          uname: 'matches_csv_dimension_74b8919'
        },
        VizFieldFull {
          ref: r(matches_csv.attendance)
          format {
            type: 'number'
            pattern: '#,###'
          }
          uname: 'matches_csv_attendance'
        },
        VizFieldFull {
          label: 'Stadium'
          ref: r(stadiums_csv.name)
          format {
            type: 'text'
          }
          uname: 'stadiums_csv_name'
        }
      ]
      settings {
        show_row_number: true
        sorts: [
          SortSetting {
            key: 'matches_csv_date_time_1'
            direction: 'desc'
          }
        ]
        row_limit: 10000
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        column_styles: [
          ColumnStyle {
            key: 'matches_csv_date_time_1'
            width: 157
          },
          ColumnStyle {
            key: 'matches_csv_dimension_74b8919'
            width: 745
          },
          ColumnStyle {
            key: 'matches_csv_attendance'
            width: 124.5
          },
          ColumnStyle {
            key: 'stadiums_csv_name'
            width: 205.5
          }
        ]
      }
    }
    settings {
      hide_label: true
    }
  }
