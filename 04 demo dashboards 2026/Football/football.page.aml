Dashboard champions_league {
  title: 'Uefa Champions League'
  description: @md A UEFA Champions League analytics dashboard that lets you explore competition-wide trends and team performance from 2016–2022

Reference:
- Data: https://www.kaggle.com/datasets/cbxkgl/uefa-champions-league-2016-2022-data/data
- Logo: https://football-logos.cc/
- Image: Bioscopes+, beIN SPORTS;;
  owner: 'son.hoang@holistics.io'
  block v_m532: VizBlock {
    label: 'Matches Played'
    viz: MetricKpi {
      dataset: football_data
      value: VizFieldFull {
        label: 'Matches'
        ref: r(football_data.total_match)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_w4nr: VizBlock {
    label: 'Results'
    viz: DataTable {
      dataset: football_data
      calculation dim_home_team_with_logo {
        label: 'Home'
        formula: @aql concat(
          '<span style="margin:8px 0;display:flex;flex-direction:column;align-items:center;gap:8px;white-space:nowrap;"><img src="',
            home_team.logo_html,
            '" style="height:24px;border-radius:4px;"> ',
            home_team.team_name,
          '</span>'
        );;
        calc_type: 'dimension'
        data_type: 'text'
        model: matches_csv
      }
      calculation dim_result_text {
        label: 'Result'
        formula: @aql concat(
           '<div style="margin:20px auto;display:flex;flex-direction:column;align-items:center;gap:8px;white-space:nowrap;font-size:24px;">',cast(matches_csv.home_team_score, 'text'),
          ' - ',
          cast(matches_csv.away_team_score, 'text'),
          '</div>'
        );;
        calc_type: 'dimension'
        data_type: 'text'
        model: matches_csv
      }
      calculation dim_away_team_with_logo {
        label: 'Away'
        formula: @aql concat(
  '<span style="margin:8px 0;display:flex;flex-direction:column;    align-items:center;gap:8px;white-space:nowrap;"><img src="',
    away_team.logo_html,
    '" style="height:24px;border-radius:4px;"> ',
    away_team.team_name,
  '</span>'
);;
        calc_type: 'dimension'
        data_type: 'text'
        model: matches_csv
      }
      calculation dimension_74b8919 {
        label: 'Result (Home - Away)'
        formula: @aql concat(
  '<div style="margin:6px;display:flex;align-items:center;justify-content:center;gap:20px;width:100%;">',

    '<span style="display:flex;flex-direction:column;align-items:center;gap:8px;width:33.33%;text-align:center;white-space:normal;word-wrap:break-word;font-weight:600;">',
      '<img src="', home_team.logo_html, '" style="height:28px;border-radius:4px;">',
      home_team.team_name,
    '</span>',

    '<span style="display:inline-flex;font-size:28px;font-weight:600;width:33.33%;justify-content:center;align-items:center;gap:6px;">',
      cast(matches_csv.home_team_score, 'text'),
      '<span style="opacity:70%"> - </span>',
      cast(matches_csv.away_team_score, 'text'),
    '</span>',

    '<span style="display:flex;flex-direction:column;align-items:center;gap:8px;width:33.33%;text-align:center;white-space:normal;word-wrap:break-word;font-weight:600;">',
      '<img src="', away_team.logo_html, '" style="height:28px;border-radius:4px;">',
      away_team.team_name,
    '</span>',

  '</div>'
);;
        calc_type: 'dimension'
        data_type: 'text'
        model: matches_csv
      }
      fields: [
        VizFieldFull {
          ref: r(matches_csv.date_time)
          format {
            type: 'date'
            pattern: 'LLL dd, yyyy'
          }
          uname: 'matches_csv_date_time_1'
        },
        VizFieldFull {
          ref: ref('matches_csv', 'dimension_74b8919')
          format {
            type: 'html'
          }
          uname: 'matches_csv_dimension_74b8919'
        },
        VizFieldFull {
          ref: r(matches_csv.attendance)
          format {
            type: 'number'
            pattern: '#,###'
          }
          uname: 'matches_csv_attendance'
        },
        VizFieldFull {
          label: 'Stadium'
          ref: r(stadiums_csv.name)
          format {
            type: 'text'
          }
          uname: 'stadiums_csv_name'
        }
      ]
      settings {
        show_row_number: true
        sorts: [
          SortSetting {
            key: 'matches_csv_date_time_1'
            direction: 'desc'
          }
        ]
        row_limit: 10000
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        column_styles: [
          ColumnStyle {
            key: 'matches_csv_date_time_1'
            width: 157
          },
          ColumnStyle {
            key: 'matches_csv_dimension_74b8919'
            width: 745
          },
          ColumnStyle {
            key: 'matches_csv_attendance'
            width: 124.5
          },
          ColumnStyle {
            key: 'stadiums_csv_name'
            width: 235.5
          }
        ]
      }
    }
    settings {
      hide_label: true
    }
  }
  block t_px72: TextBlock {
    content: @md <img style="width:100%;margin-bottom:0 !important;overflow:hidden;" src="https://i.ibb.co/ymRP2CrD/players2.png" alt="players" border="0"></a>;;
  }
  block v_isf6: VizBlock {
    label: 'Total Attendance'
    viz: MetricKpi {
      dataset: football_data
      calculation total_attendance2 {
        label: 'Total Attendance'
        formula: @aql matches_csv | sum(matches_csv.attendance);;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        label: 'Total Attendance'
        ref: r(football_data.total_attendance)
        format {
          type: 'number'
          pattern: '#,###'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }
  block v_le6e: VizBlock {
    label: 'Total Goals'
    viz: MetricKpi {
      dataset: football_data
      value: VizFieldFull {
        label: 'Goals'
        ref: r(football_data.total_goals_score)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }
  block f_season: FilterBlock {
    label: 'Season'
    type: 'field'
    source: FieldFilterSource {
      dataset: football_data
      field: r(matches_csv.season)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
  }
  block v_8m7w: VizBlock {
    label: 'Top scorers'
    viz: BarChart {
      dataset: football_data
      calculation total_goals {
        label: 'Total Goals'
        formula: @aql goals_csv | count(goals_csv.goal_id);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation total_goals_by_player {
        label: 'Total Goals By Player'
        formula: @aql total_goals | exclude_grains(goals_csv.goal_desc);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation top_10_players {
        label: 'Top 10 Players'
        formula: @aql top(10, players_csv.player_full_name, by: total_goals_by_player, logic: 'dense');;
        calc_type: 'measure'
        data_type: 'json'
      }
      filter {
        field: r(players_csv.player_full_name)
        operator: 'not_null'
        value: []
      }
      filter {
        field: r(goals_csv.goal_desc)
        operator: 'not_null'
        value: []
      }
      x_axis: VizFieldFull {
        label: 'Player Name'
        ref: r(players_csv.player_full_name)
        format {
          type: 'text'
        }
      }
      legend: VizFieldFull {
        label: 'Goal Category'
        ref: r(goals_csv.goal_desc)
        format {
          type: 'text'
        }
      }
      y_axis {
        label: 'Goals'
        settings {
          show_total_in_tooltip: true
          stack_series_by: 'value'
        }
        series {
          field: VizFieldFull {
            ref: 'total_goals'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color_palette: 22
            point {
              value: ''
              color: '#1F5E8F'
            }
            point {
              value: 'back heel'
              color: '#3A81D4'
            }
            point {
              value: 'bicycle kick'
              color: '#73C9F0'
            }
            point {
              value: 'free kick'
              color: '#B0E8FC'
            }
            point {
              value: 'header'
              color: '#A8442A'
            }
            point {
              value: 'ind. free kick'
              color: '#E57D34'
            }
            point {
              value: 'left-footed shot'
              color: '#FFA669'
            }
            point {
              value: 'own goal'
              color: '#F6C88A'
            }
            point {
              value: 'penalty'
              color: '#1F5E8F'
            }
            point {
              value: 'right-footed shot'
              color: '#3A81D4'
            }
          }
        }
      }
      settings {
        row_limit: 10
        sort {
          field_index: 0
          direction: 'desc'
          type: 'yaxis'
        }
        x_axis_label: 'Player Name'
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_akem: VizBlock {
    label: 'Stadium and attendance'
    viz: ScatterChart {
      dataset: football_data
      calculation dimension_c32bfd5 {
        label: 'Team'
        formula: @aql concat('<img src="', home_team.logo_html, '" style="display:inline-block;margin-left:16px;margin-top:8px;width:80px;border-radius:4px;" />');;
        calc_type: 'dimension'
        data_type: 'text'
        model: home_team
      }
      x_col: VizFieldFull {
        ref: r(stadiums_csv.capacity)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      y_col: VizFieldFull {
        label: 'Total Attendance'
        ref: r(football_data.total_attendance)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      group_col: VizFieldFull {
        ref: r(home_team.country)
        format {
          type: 'text'
        }
      }
      label_col: VizFieldFull {
        label: 'Stadium Name'
        ref: r(stadiums_csv.name)
        format {
          type: 'text'
        }
      }
      tooltips: [
        VizTooltip {
          field: VizFieldFull {
            ref: ref('home_team', 'dimension_c32bfd5')
            aggregation: 'min'
            format {
              type: 'html'
            }
          }
        }
      ]
      settings {
        row_limit: 100
      }
    }
  }
  block f_match_teams_team: FilterBlock {
    label: 'Team'
    type: 'field'
    source: FieldFilterSource {
      dataset: football_data
      field: r(match_teams.team_name)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
    settings {
      input_type: 'multiple'
    }
  }
  block t_xk5z: TextBlock {
    content: @md <img style="margin-bottom:0 !important;overflow:hidden;" src="https://i.ibb.co/ymRP2CrD/players2.png" alt="demo">;;
  }
