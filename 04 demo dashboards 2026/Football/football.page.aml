  block f_team_role: FilterBlock {
    label: 'Team Role'
    type: 'field'
    source: FieldFilterSource {
      dataset: football_data
      field: r(match_teams.team_role)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
  }
  block v_uu3g: VizBlock {
    label: 'Top scorers of these matches (not just selected team)'
    viz: BarChart {
      dataset: football_data
      calculation total_goals {
        label: 'Total Goals'
        formula: @aql goals_csv | count(goals_csv.goal_id);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation total_goals_by_player {
        label: 'Total Goals By Player'
        formula: @aql total_goals | exclude_grains(goals_csv.goal_desc);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation top_10_players {
        label: 'Top 10 Players'
        formula: @aql top(10, players_csv.player_full_name, by: total_goals_by_player, logic: 'dense');;
        calc_type: 'measure'
        data_type: 'json'
      }
      filter {
        field: r(players_csv.player_full_name)
        operator: 'not_null'
        value: []
      }
      filter {
        field: r(goals_csv.goal_desc)
        operator: 'not_null'
        value: []
      }
      x_axis: VizFieldFull {
        label: 'Player Name'
        ref: r(players_csv.player_full_name)
        format {
          type: 'text'
        }
      }
      legend: VizFieldFull {
        label: 'Goal Category'
        ref: r(goals_csv.goal_desc)
        format {
          type: 'text'
        }
      }
      y_axis {
        label: 'Goals'
        settings {
          show_total_in_tooltip: true
          stack_series_by: 'value'
        }
        series {
          field: VizFieldFull {
            ref: r(football_data.team_goals_by_scorer)
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
      settings {
        row_limit: 10
        sort {
          field_index: 0
          direction: 'desc'
          type: 'yaxis'
        }
        x_axis_label: 'Player Name'
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_49rl: VizBlock {
    label: 'Performance overview'
    viz: DataTable {
      dataset: football_data
      calculation team_draws {
        label: 'Draws'
        formula: @aql count(
  match_teams,
  case(
    when: match_teams.team_role == "home" and matches_csv.home_team_score == matches_csv.away_team_score, then: matches_csv.match_id,
    when: match_teams.team_role == "away" and matches_csv.away_team_score == matches_csv.home_team_score, then: matches_csv.match_id,
    else: null
  )
);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation team_losses {
        label: 'Losses'
        formula: @aql team_matches_played - team_wins - team_draws;;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation goal_difference {
        label: 'Goal Difference'
        formula: @aql goals_scored - goals_conceded;;
        calc_type: 'measure'
        data_type: 'number'
      }
      fields: [
        VizFieldFull {
          label: 'Team'
          ref: r(match_teams.team_name)
          format {
            type: 'text'
          }
          uname: 'team_name'
        },
        VizFieldFull {
          label: 'Matches'
          ref: r(football_data.team_matches_played)
          format {
            type: 'number'
            pattern: 'inherited'
          }
          uname: 'matches_played'
        },
        VizFieldFull {
          label: 'Wins'
          ref: r(football_data.team_wins)
          format {
            type: 'number'
            pattern: 'inherited'
          }
          uname: 'wins'
        },
        VizFieldFull {
          label: 'Draws'
          ref: 'team_draws'
          format {
            type: 'number'
            pattern: '#,###0'
          }
          uname: 'draws'
        },
        VizFieldFull {
          label: 'Losses'
          ref: 'team_losses'
          format {
            type: 'number'
            pattern: '#,###0'
          }
          uname: 'losses'
        },
        VizFieldFull {
          label: 'Win rate'
          ref: r(football_data.team_win_rate)
          format {
            type: 'number'
            pattern: '#,###0.0%'
          }
          uname: 'win_rate'
        },
        VizFieldFull {
          label: 'Goals scored'
          ref: r(football_data.goals_scored)
          format {
            type: 'number'
            pattern: 'inherited'
          }
          uname: 'goals_scored'
        },
        VizFieldFull {
          label: 'Goals conceded'
          ref: r(football_data.goals_conceded)
          format {
            type: 'number'
            pattern: 'inherited'
          }
          uname: 'goals_conceded'
        },
        VizFieldFull {
          label: 'Goal difference'
          ref: 'goal_difference'
          format {
            type: 'number'
            pattern: '#,###0'
          }
          uname: 'goal_difference'
        }
      ]
      settings {
        pagination_size: 100
        wrap_header_text: true
        show_row_number: true
        sorts: [
          SortSetting {
            key: 'wins'
            direction: 'desc'
          },
          SortSetting {
            key: 'goal_difference'
            direction: 'desc'
          },
          SortSetting {
            key: 'team_name'
            direction: 'asc'
          }
        ]
        conditional_formats: [
          ConditionalFormat {
            key: 'win_rate'
            format: ScaleFormat {
              min {
                value: 0
                color: '#1F5E8F'
              }
              mid {
                value: 0.5
                color: '#F6C88A'
              }
              max {
                value: 0.8
                color: '#E57D34'
              }
            }
          },
          ConditionalFormat {
            key: 'goals_scored'
            format: ScaleFormat {
              min {
                value: 0
                color: '#1F5E8F'
              }
              max {
                value: 100
                color: '#E57D34'
              }
            }
          },
          ConditionalFormat {
            key: 'goal_difference'
            format: ScaleFormat {
              min {
                value: -40
                color: '#1F5E8F'
              }
              max {
                value: 150
                color: '#E57D34'
              }
            }
          }
        ]
        row_limit: 10000
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        single_cell_display: 'normal'
        column_styles: [
          ColumnStyle {
            key: 'team_name'
            width: 182.3699999999999
          },
          ColumnStyle {
            key: 'matches_played'
            width: 125
          },
          ColumnStyle {
            key: 'wins'
            width: 113
          },
          ColumnStyle {
            key: 'draws'
            width: 113
          },
          ColumnStyle {
            key: 'losses'
            width: 114
          },
          ColumnStyle {
            key: 'win_rate'
            width: 123
          },
          ColumnStyle {
            key: 'goals_scored'
            width: 159
          },
          ColumnStyle {
            key: 'goals_conceded'
            width: 173.5
          },
          ColumnStyle {
            key: 'goal_difference'
            width: 184
          }
        ]
      }
    }
  }
