  block v_5vbc: VizBlock {
    label: 'Appearance Count by Country'
    viz: WordCloud {
      dataset: football_data
      calculation country {
        label: 'Country'
        formula: @aql case(
  when: match_teams.team_role == 'home', then: home_team.country,
  when: match_teams.team_role == 'away', then: away_team.country,
  else: null
);;
        calc_type: 'dimension'
        data_type: 'text'
        model: match_teams
      }
      calculation appearance_count {
        label: 'Appearance Count'
        formula: @aql match_teams | count(matches_csv.match_id);;
        calc_type: 'measure'
        data_type: 'number'
      }
      words: VizFieldFull {
        label: 'Country'
        ref: ref('match_teams', 'country')
        format {
          type: 'text'
        }
      }
      weight: VizFieldFull {
        label: 'Appearance Count'
        ref: 'appearance_count'
        format {
          type: 'number'
          pattern: '#,###'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_h5ig: VizBlock {
    label: 'Win/Draw/Loss'
    viz: ColumnChart {
      dataset: football_data
      calculation result_category {
        label: 'Result Category'
        formula: @aql case(
  when: match_teams.team_role == 'home', then: case(
    when: matches_csv.home_team_score > matches_csv.away_team_score, then: '1. Win',
    when: matches_csv.home_team_score < matches_csv.away_team_score, then: '3. Loss',
    else: '2. Draw'
  ),
  when: match_teams.team_role == 'away', then: case(
    when: matches_csv.away_team_score > matches_csv.home_team_score, then: '1. Win',
    when: matches_csv.away_team_score < matches_csv.home_team_score, then: '3. Loss',
    else: '2. Draw'
  ),
  else: '2. Draw'
);;
        calc_type: 'dimension'
        data_type: 'text'
        model: match_teams
      }
      calculation match_count {
        label: 'Match Count'
        formula: @aql matches_csv | count(matches_csv.match_id);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation win_match_count {
        label: 'Win Match Count'
        formula: @aql match_count | where(match_teams.result_category == '1. Win');;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation top_10_teams_by_win_match_count {
        label: 'Top 10 Teams By Win Match Count'
        formula: @aql top(10, match_teams.team_name, by: win_match_count, logic: 'dense');;
        calc_type: 'measure'
        data_type: 'json'
      }
      x_axis: VizFieldFull {
        label: 'Team Name'
        ref: r(match_teams.team_name)
        format {
          type: 'text'
        }
      }
      legend: VizFieldFull {
        label: 'Result Category'
        ref: ref('match_teams', 'result_category')
        format {
          type: 'text'
        }
      }
      y_axis {
        label: 'Matches'
        settings {
          axis_min: 0
          show_total_in_tooltip: true
          show_data_label_by: 'value'
        }
        series {
          field: VizFieldFull {
            label: 'Match Count'
            ref: 'match_count'
            format {
              type: 'number'
              pattern: '#,###'
            }
          }
          settings {
            point {
              value: '1. Win'
              color: '#3A81D4'
            }
            point {
              value: '2. Draw'
              color: '#F6C88A'
            }
            point {
              value: '3. Loss'
              color: '#A8442A'
            }
          }
        }
      }
      settings {
        row_limit: 10
        sort {
          field_index: 0
          direction: 'desc'
          type: 'yaxis'
        }
        x_axis_label: 'Team Name'
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
