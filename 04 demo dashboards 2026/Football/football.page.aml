  block v_afv5: VizBlock {
    label: 'Goals per match'
    viz: MetricKpi {
      dataset: football_data
      calculation metric_36cff2b {
        label: 'Goals per match'
        formula: @aql safe_divide(total_goals_score, total_match);;
        calc_type: 'measure'
        data_type: 'number'
      }
      value: VizFieldFull {
        ref: 'metric_36cff2b'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
      }
    }
    settings {
      hide_label: true
    }
  }
