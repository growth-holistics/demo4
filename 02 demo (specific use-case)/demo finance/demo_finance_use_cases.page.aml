  block v_rev_client: VizBlock {
    label: 'Revenue by Client'
    viz: DataTable {
      dataset: demo_finance_version_2
      calculation revenue_by_client {
        label: 'Revenue By Client'
        formula: @aql unique(finance_customer_invoices.customer_id)
          | select(v: revenue)
          | sum(v);;
        calc_type: 'measure'
        data_type: 'number'
      }
      fields: [
        VizFieldFull {
          ref: r(finance_customer_invoices.customer_id)
          label: 'Client ID'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(ecommerce_users.full_name)
          label: 'Client Name'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(ecommerce_users.gender)
          label: 'Gender'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(ecommerce_users.age_group)
          label: 'Age Demographic'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(ecommerce_cities.name)
          label: 'City'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(ecommerce_countries.name)
          label: 'Country'
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: 'revenue_by_client'
          label: 'Revenue'
          format {
            type: 'number'
            pattern: '[$]#,###0'
          }
        }
      ]
      settings {
        show_row_number: true
        row_limit: 100
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_rev_product: VizBlock {
    label: 'Revenue by top 10 Products'
    viz: BarChart {
      dataset: demo_finance_version_2
      calculation revenue_by_product {
        label: 'Revenue By Product'
        formula: @aql unique(ecommerce_products.id)
          | select(v: revenue)
          | sum(v);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation product_rank_by_revenue {
        label: 'Product Rank By Revenue'
        formula: @aql rank(order: revenue_by_product | desc());;
        calc_type: 'measure'
        data_type: 'number'
      }
      filter {
        field: r(ecommerce_products.name)
        operator: 'top'
        value: 10
        options {
          rank_by {
            field: 'revenue_by_product'
            aggregation: 'custom'
            logic: 'standard'
          }
        }
      }
      x_axis: VizFieldFull {
        label: 'Product Name'
        ref: r(ecommerce_products.name)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            label: 'Revenue'
            ref: 'revenue_by_product'
            format {
              type: 'number'
              pattern: '[$]#,###0'
            }
          }
          settings {
            color: '#2563EB'
          }
        }
      }
      settings {
        row_limit: 100
        sort {
          field_index: 0
          direction: 'desc'
          type: 'yaxis'
        }
        legend_label: 'hidden'
        x_axis_label: 'Product Name'
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_rev_variance: VizBlock {
    label: 'Revenue Trend with MoM and YoY Variance'
    viz: CombinationChart {
      dataset: demo_finance_version_2
      calculation previous_month_revenue {
        label: 'Previous Month Revenue'
        formula: @aql revenue | previous(order: dim_dates.date_key | month());;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation mom_absolute_change {
        label: 'MoM Absolute Change'
        formula: @aql revenue - previous_month_revenue;;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation mom_percent_change {
        label: 'MoM % Change'
        formula: @aql safe_divide(revenue - previous_month_revenue, previous_month_revenue);;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation same_month_last_year_revenue {
        label: 'Same Month Last Year Revenue'
        formula: @aql revenue | relative_period(dim_dates.date_key, interval(-1 year));;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation yoy_absolute_change {
        label: 'YoY Absolute Change'
        formula: @aql revenue - (revenue | relative_period(dim_dates.date_key, interval(-1 year)));;
        calc_type: 'measure'
        data_type: 'number'
      }
      calculation yoy_percent_change {
        label: 'YoY % Change'
        formula: @aql safe_divide(revenue - (revenue | relative_period(dim_dates.date_key, interval(-1 year))), (revenue | relative_period(dim_dates.date_key, interval(-1 year))));;
        calc_type: 'measure'
        data_type: 'number'
      }
      filter {
        field: r(dim_dates.date_key)
        operator: 'matches'
        value: 'last 3 years'
      }
      x_axis: VizFieldFull {
        label: 'Revenue Month'
        ref: r(dim_dates.date_key)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        label: 'Revenue'
        series {
          mark_type: 'column'
          field: VizFieldFull {
            label: 'Monthly Revenue'
            ref: r(demo_finance_version_2.revenue)
            format {
              type: 'number'
              pattern: '[$]#,###0'
            }
          }
          settings {
            color: '#2563EB'
          }
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            label: 'Same Month Last Year Revenue'
            ref: 'same_month_last_year_revenue'
            format {
              type: 'number'
              pattern: '[$]#,###0'
            }
          }
          settings {
            color: '#94A3B8'
            line_style: 'dashed'
          }
        }
      }
      y_axis {
        label: 'Variance %'
        series {
          mark_type: 'line'
          field: VizFieldFull {
            label: 'MoM % Change'
            ref: 'mom_percent_change'
            format {
              type: 'number'
              pattern: '#,###0.00%'
            }
          }
          settings {
            color: '#F59E0B'
          }
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            label: 'YoY % Change'
            ref: 'yoy_percent_change'
            format {
              type: 'number'
              pattern: '#,###0.00%'
            }
          }
          settings {
            color: '#10B981'
          }
        }
      }
      settings {
        show_data_points: true
        row_limit: 5000
        x_axis_label: 'Revenue Month'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_invoice_aging: VizBlock {
    label: 'Outstanding Invoices by Aging Bucket'
    viz: ColumnChart {
      dataset: demo_finance_version_2
      calculation invoice_count {
        label: 'Invoice Count'
        formula: @aql finance_customer_invoices | count(finance_customer_invoices.invoice_id);;
        calc_type: 'measure'
        data_type: 'number'
      }
      filter {
        field: r(finance_customer_invoices.invoice_status)
        operator: 'is'
        value: [
          'open',
          'partial'
        ]
      }
      x_axis: VizFieldFull {
        label: 'Aging Bucket'
        ref: r(finance_customer_invoices.aging_bucket)
        format {
          type: 'text'
        }
      }
      legend: VizFieldFull {
        label: 'Invoice Status'
        ref: r(finance_customer_invoices.invoice_status)
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          show_stack_total: true
          stack_series_by: 'value'
        }
        series {
          field: VizFieldFull {
            label: ' '
            ref: r(finance_customer_invoices.invoice_amount)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
      settings {
        row_limit: 5000
        x_axis_label: 'Aging Bucket'
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_rev_payment_type: VizBlock {
    label: 'Collected Payment Amount by Method'
    viz: BarChart {
      dataset: demo_finance_version_2
      calculation total_customer_payment_amount {
        label: 'Total Customer Payment Amount'
        formula: @aql finance_customer_payments | sum(finance_customer_payments.payment_amount);;
        calc_type: 'measure'
        data_type: 'number'
      }
      filter {
        field: r(finance_customer_payments.payment_status)
        operator: 'is'
        value: 'settled'
      }
      x_axis: VizFieldFull {
        label: 'Payment Method'
        ref: r(finance_customer_payments.payment_method)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            label: 'Collected Payment Amount'
            ref: 'total_customer_payment_amount'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#2563EB'
          }
        }
      }
      settings {
        row_limit: 5000
        legend_label: 'hidden'
        x_axis_label: 'Payment Method'
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_budget_vs_actual: VizBlock {
    label: 'Expense Budget vs Actual Cost by Month'
    viz: CombinationChart {
      dataset: demo_finance_version_2
      filter {
        field: r(dim_dates.date_key)
        operator: 'matches'
        value: 'last 24 months'
      }
      x_axis: VizFieldFull {
        ref: r(dim_dates.date_key)
        transformation: 'datetrunc month'
        label: 'Month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        label: 'Amount'
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(demo_finance_version_2.total_cost)
            label: 'Actual Cost'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#2563EB'
          }
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            ref: r(demo_finance_version_2.expense_budgets)
            label: 'Expense Budgets'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#A855F7'
            line_style: 'solid'
          }
        }
      }
      settings {
        row_limit: 5000
        legend_label: 'bottom'
        x_axis_label: 'Month'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_ta9y: VizBlock {
    label: 'Po Status and Count of Purchase Order Id'
    viz: DataTable {
      dataset: demo_finance_version_2
      fields: [
        VizFieldFull {
          ref: r(finance_purchase_orders.po_status)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(finance_purchase_orders.purchase_order_id)
          aggregation: 'count'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      settings {
        show_row_number: true
        row_limit: 5000
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
