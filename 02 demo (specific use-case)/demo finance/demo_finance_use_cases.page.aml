  block v_f69h: VizBlock {
    label: 'Top 10 vendors by spend'
    viz: ColumnChart {
      dataset: demo_finance_version_2
      filter {
        field: r(finance_dim_vendors.vendor_name)
        operator: 'top'
        value: 10
        options {
          rank_by {
            field: r(finance_supplier_payments.payment_amount)
            aggregation: 'sum'
            logic: 'standard'
          }
        }
      }
      x_axis: VizFieldFull {
        ref: r(finance_dim_vendors.vendor_name)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(finance_supplier_payments.payment_amount)
            aggregation: 'sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
      settings {
        row_limit: 5000
        sort {
          field_index: 0
          direction: 'desc'
          type: 'series'
        }
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_fuqv: VizBlock {
    label: 'Price Trend by Top 5 Vendors'
    viz: LineChart {
      dataset: demo_finance_version_2
      filter {
        field: r(finance_dim_vendors.vendor_name)
        operator: 'top'
        value: 5
        options {
          rank_by {
            field: r(finance_supplier_payments.payment_amount)
            aggregation: 'sum'
            logic: 'standard'
          }
        }
