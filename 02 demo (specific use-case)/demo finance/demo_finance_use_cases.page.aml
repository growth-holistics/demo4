          ref: r(finance_supplier_bills.bill_status)
          format {
            type: 'text'
          }
          uname: 'finance_supplier_bills_bill_status'
        },
        VizFieldFull {
          ref: r(finance_supplier_bills.bill_department)
          format {
            type: 'text'
          }
          uname: 'finance_supplier_bills_bill_department'
        },
        VizFieldFull {
          ref: r(finance_supplier_bills.bill_amount)
          format {
            type: 'number'
            pattern: 'inherited'
          }
          uname: 'finance_supplier_bills_bill_amount'
        },
        VizFieldFull {
          ref: r(finance_supplier_bills.paid_amount)
          format {
            type: 'number'
            pattern: 'inherited'
          }
