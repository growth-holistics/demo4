Dashboard demo_finance_use_cases {
  title: 'demo_finance_use_cases'
  description: ''
  owner: 'dong.ln@holistics.io'
  block title: TextBlock {
    content: @md # Revenue overview;;
  }
  block v_fin_gmv: VizBlock {
    label: 'GMV'
    viz: MetricKpi {
      dataset: demo_finance_version_2
      value: VizFieldFull {
        label: 'GMV'
        ref: r(demo_finance_version_2.gmv)
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        display_mode: 'single'
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        alignment: 'left'
        metric_value {
          font_size: 30
        }
      }
    }
    settings {
      hide_label: true
    }
  }
