Model gld_currency_param {
  type: 'query'
  label: 'Gld Currency Param'
  description: 'Define currencies for dashboards dynamic currency conversion'
  data_source_name: 'demodb'
  param currency {
    label: 'Display Currency'
    type: 'text'
    allowed_values: ['USD', 'EUR', 'GBP', 'SGD']
  }

  owner: 'mario@holistics.io'
  query: @sql SELECT 1;;
  models: [
  ]
}
