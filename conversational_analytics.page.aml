Dashboard conversational_analytics {
  title: 'Conversational Analytics'
  owner: 'vincent@holistics.io'
  block title: TextBlock {
    content: @md # Conversation Analytics - Workflow;;
  }
  block t_t40l: TextBlock {
    content: @md <img src = "https://holistics-media.s3.ap-southeast-1.amazonaws.com/files/6bb4b416-ai-dashboard-assistant-flow.svg?X-Amz-Algorithm=AWS4-HMAC-SHA256&X-Amz-Content-Sha256=UNSIGNED-PAYLOAD&X-Amz-Credential=AKIASDF5UORS4F2HVFWS%2F20260423%2Fap-southeast-1%2Fs3%2Faws4_request&X-Amz-Date=20260423T034855Z&X-Amz-Expires=3600&X-Amz-Signature=8660e00d45823f758f17b2c724ef43084699b5efa1360407329564a9aff2d67a&X-Amz-SignedHeaders=host&x-amz-checksum-mode=ENABLED&x-id=GetObject"> </img>;;
  }
  interactions: []
  view: TabLayout {
    label: 'View 1'
    tab view_1: CanvasLayout {
      label: 'Overview'
      width: 1300
      height: 820
      grid_size: 20
      auto_expand_vertically: true
      block title {
        position: pos(20, 20, 1260, 60)
      }
      block t_t40l {
        position: pos(20, 80, 660, 720)
      }
      mobile {
        mode: 'auto'
      }
    }
  }
  theme: H.themes.vanilla
}