Dashboard testing_claude {
  title: 'Testing Claude'

  block v1: VizBlock {
    label: 'Total Users by Age Demographic'
    viz: ColumnChart {
      dataset: demo_ecommerce_version_2
      x_axis: VizFieldFull {
        ref: r(ecommerce_users.age_group)
        label: 'Age Demographic'
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(demo_ecommerce_version_2.total_users)
            label: 'Total Users'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#4F46E5'
          }
        }
      }
      settings {
        row_limit: 100
        sort: LineFamilySort {
          type: 'xaxis'
          direction: 'asc'
        }
      }
    }
  }

  block v2: VizBlock {
    label: 'GMV This Year vs Last Year by Month'
    viz: LineChart {
      dataset: demo_ecommerce_version_2
      calculation gmv_last_year {
        label: 'GMV Last Year'
        formula: @aql gmv | relative_period(ecommerce_orders.created_at, interval(-1 year));;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        ref: r(ecommerce_orders.created_at)
        label: 'Month'
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        label: 'GMV'
        series {
          field: VizFieldFull {
            ref: r(demo_ecommerce_version_2.gmv)
            label: 'GMV This Year'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#2563EB'
            line_style: 'solid'
            line_interpolation: 'linear'
          }
        }
        series {
          field: VizFieldFull {
            ref: 'gmv_last_year'
            label: 'GMV Last Year'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#F59E0B'
            line_style: 'dashed'
            line_interpolation: 'linear'
          }
        }
        settings {
          alignment: 'left'
          scale: 'linear'
        }
      }
      tooltips: [
        VizTooltip {
          field: VizFieldFull {
            ref: r(ecommerce_orders.created_at)
            label: 'Month'
            transformation: 'datetrunc month'
            format {
              type: 'date'
              pattern: 'LLL yyyy'
            }
          }
        },
        VizTooltip {
          field: VizFieldFull {
            ref: r(demo_ecommerce_version_2.gmv)
            label: 'GMV This Year'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        },
        VizTooltip {
          field: VizFieldFull {
            ref: 'gmv_last_year'
            label: 'GMV Last Year'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      ]
      filter {
        field: r(ecommerce_orders.created_at)
        operator: 'matches'
        value: 'this year'
      }
      settings {
        legend_label: 'top'
        show_data_points: true
        connect_discontinuous_points: false
        row_limit: 100
        sort: LineFamilySort {
          type: 'xaxis'
          direction: 'asc'
        }
      }
    }
  }

  block v3: VizBlock {
    label: 'Total Orders by Country'
    viz: BarChart {
      dataset: demo_ecommerce_version_2
      x_axis: VizFieldFull {
        ref: r(ecommerce_countries.name)
        label: 'Country Name'
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(demo_ecommerce_version_2.total_orders)
            label: 'Total Orders'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#F1434B'
          }
        }
      }
      settings {
        row_limit: 100
        sort: LineFamilySort {
          type: 'yaxis'
          field_index: 0
          direction: 'desc'
        }
      }
    }
  }

  view: CanvasLayout {
    label: 'View 1'
    width: 1300
    height: 900
    grid_size: 20
    auto_expand_vertically: true
    block v1 {
      position: pos(20, 20, 620, 400)
    }
    block v2 {
      position: pos(660, 20, 620, 400)
    }
    block v3 {
      position: pos(20, 440, 620, 400)
    }
  }
}
