      content: @md <style>
/* Scoped styles for deals component */
.deals-container {
display: grid;
padding: 1.5rem;
grid-template-columns: repeat(2, minmax(0, 1fr));
column-gap: 1.5rem;
row-gap: 2rem;
list-style: none;
}

@media (min-width: 1024px) {
.deals-container {
grid-template-columns: repeat(3, minmax(0, 1fr));
column-gap: 2rem;
}
}

.deals-container .deal-container {
overflow: hidden;
border-radius: 0.75rem;
border: 1px solid #E5E7EB;
list-style: none;
}

.deals-container .deal-header {
display: flex;
padding: 1.5rem;
column-gap: 1rem;
align-items: center;
border-bottom: 1px solid rgb(17 24 39 / 0.05);
background-color: #F9FAFB;
}

.deals-container .deal-logo {
object-fit: cover;
flex: none;
border-radius: 0.5rem;
border: 1px solid rgb(229 231 235);
width: 4rem;
height: 4rem;
background-color: #ffffff;
}

.deals-container .deal-name {
font-size: 1rem;
line-height: 1.5rem;
font-weight: 500;
color: #111827;
}

.deals-container .deal-details {
padding: 1rem 1.5rem;
margin: -0.75rem 0;
border-color: #F3F4F6;
font-size: 0.875rem;
line-height: 1.5rem;
}

.deals-container .deal-details-inner {
display: flex;
padding: 0.3rem 0;
column-gap: 1rem;
justify-content: space-between;
}

.deals-container .deal-details-inner:last-of-type {
border-bottom-width: 0;
}

/* Selection state */
.deals-container .h-drill-selected {
color: green;
}

.deals-container .deal-container:has(.h-drill-selected) {
border-color: #2563EB;
background: #EFF6FF;
}

.deals-container .deal-name:has(.h-drill-selected) {
border-color: #2563EB;
background: #EFF6FF;
}
</style>

<ul class="deals-container">

{% map(rows) %}

<li class="deal-container">
<div class="deal-header">
<img src="{{ `Product Image Url`.raw }}" class="deal-logo" alt="{{ `Name`.raw }}">
<section class="deal-name flex flex-col items-start">
<div class="flex flex-row items-center">{{ `Name` }}</div>
</section>
</div>

<dl class="-my-3 divide-y divide-gray-100 px-6 py-4 text-sm leading-6">
<div class="deal-details-inner" style="border-bottom: none;">
<dt class="text-gray-500">Revenue</dt>
<dd class="flex items-start gap-x-2">
<section class="rounded-md ml-2 font-medium ring-1 ring-inset text-green-700 bg-green-50 ring-green-600/10" style="padding: 2px 6px">{{ values.`Revenue` }}</section>
</dd>
</div>

<div class="deal-details-inner">
<dt class="text-gray-500">Category</dt>
<dd class="flex items-start gap-x-2">
<div class="font-medium text-gray-900">{{ `Category Name` }}</div>
</dd>
</div>

<div class="deal-details-inner">
<dt class="text-gray-500">Price</dt>
<dd class="flex items-start gap-x-2">
<div class="font-medium text-gray-900">{{ values.`Total Price` }}</div>
</dd>
</div>
</dl>
</li>

{% end %}

</ul> ;;
