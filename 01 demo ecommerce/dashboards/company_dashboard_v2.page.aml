      content: @md <style>
  .mt {
    --node-w: clamp(100px, 12vw, 140px);
    --gap: clamp(6px, 1.5vw, 14px);
    --line-color: #999;
    --line-w: 2px;
    --stem-h: clamp(20px, 3vw, 30px);

    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
    display: flex;
    justify-content: center;
    padding: 16px;
    box-sizing: border-box;
  }

  /* Node wrapper: vertical flex column, centered */
  .mt .nw {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Branch row: horizontal flex, holds sibling branches */
  .mt .br-row {
    display: flex;
    gap: var(--gap);
  }

  /* Branch: one child subtree */
  .mt .br {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Vertical stem from parent down to branch row */
  .mt .stem {
    width: var(--line-w);
    height: var(--stem-h);
    background: var(--line-color);
    flex-shrink: 0;
  }

  /* Connector: horizontal bar + vertical stem to child node */
  .mt .conn {
    align-self: stretch;
    height: var(--stem-h);
    position: relative;
    flex-shrink: 0;
  }

  /* Horizontal bar segment (extends into flex gap via negative offsets) */
  .mt .conn::before {
    content: '';
    position: absolute;
    top: 0;
    left: calc(var(--gap) / -2);
    right: calc(var(--gap) / -2);
    height: var(--line-w);
    background: var(--line-color);
  }

  /* First child: bar from center to right edge */
  .mt .br-row > .br:first-child > .conn::before {
    left: 50%;
    right: calc(var(--gap) / -2);
  }

  /* Last child: bar from left edge to center */
  .mt .br-row > .br:last-child > .conn::before {
    left: calc(var(--gap) / -2);
    right: 50%;
  }

  /* Only child: no horizontal bar needed */
  .mt .br-row > .br:only-child > .conn::before {
    display: none;
  }

  /* Vertical stem from bar down to child */
  .mt .conn::after {
    content: '';
    position: absolute;
    left: calc(50% - var(--line-w) / 2);
    top: 0;
    width: var(--line-w);
    height: 100%;
    background: var(--line-color);
  }

  /* Node card */
  .mt .node {
    width: var(--node-w);
    min-width: 0;
    padding: 10px 8px 8px;
    border: 2px solid #d1d5db;
    border-radius: 12px;
    background: #fff;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
    display: flex;
    flex-direction: column;
    gap: 2px;
    box-sizing: border-box;
  }

  .mt .label {
    font-size: clamp(11px, 1.2vw, 14px);
    opacity: 0.7;
    text-align: center;
    margin: 0;
    padding: 0;
    line-height: 1.2;
    color: #333;
    white-space: normal !important;
    overflow-wrap: break-word;
    max-width: 100%;
  }

  .mt .value {
    font-size: clamp(14px, 1.5vw, 17px);
    font-weight: 700;
    text-align: center;
    margin: 0 !important;
    line-height: 1.2;
  }
</style>

<div class="mt">
<div class="nw">
<!-- Revenue -->
<article class="node">
<p class="label">Revenue</p>
<p class="value">{{ col_totals.`Revenue`.formatted }}</p>
<h-sparkline column="Revenue"  width="100" height="30" class="size-full"></h-sparkline>
</article>
<div class="stem"></div>
<div class="br-row">

<!-- NMV subtree -->
<div class="br">
  <div class="conn"></div>
  <div class="nw">
  <article class="node">
  <p class="label">NMV</p>
  <p class="value">{{ col_totals.`NMV`.formatted }}</p>
  <h-sparkline column="NMV"  width="100" height="30" class="size-full"></h-sparkline>
  </article>
  <div class="stem"></div>
<div class="br-row">

<!-- Order Fulfillment Rate (leaf) -->
<div class="br">
  <div class="conn"></div>
  <div class="nw">
  <article class="node">
  <p class="label">Order Fulfillment Rate</p>
  <p class="value">{{ col_totals.`Order Fulfillment Rate`.formatted }}</p>
  <h-sparkline column="Order Fulfillment Rate"  width="100" height="30" class="size-full"></h-sparkline>
  </article>
  </div>
</div>

<!-- GMV subtree -->
<div class="br">
  <div class="conn"></div>
  <div class="nw">
  <article class="node">
  <p class="label">GMV</p>
  <p class="value">{{ col_totals.`GMV`.formatted }}</p>
  <h-sparkline column="GMV"  width="100" height="30" class="size-full"></h-sparkline>
  </article>
  <div class="stem"></div>
<div class="br-row">

<!-- Order Quantity subtree -->
<div class="br">
<div class="conn"></div>
<div class="nw">
  <article class="node">
    <p class="label">Order Quantity</p>
    <p class="value">{{ col_totals.`Order Quantity`.formatted }}</p>
    <h-sparkline column="Order Quantity"  width="100" height="30" class="size-full" type="column"></h-sparkline>
  </article>
  <div class="stem"></div>
  <div class="br-row">
    <div class="br">
      <div class="conn"></div>
      <div class="nw">
        <article class="node">
          <p class="label">Merchant Count</p>
          <p class="value">{{ col_totals.`Merchant Count`.formatted }}</p>
          <h-sparkline column="Merchant Count"  width="100" height="30" class="size-full"></h-sparkline>
        </article>
      </div>
    </div>
    <div class="br">
      <div class="conn"></div>
      <div class="nw">
        <article class="node">
          <p class="label">Product Variety</p>
          <p class="value">{{ col_totals.`Product Variety`.formatted }}</p>
          <h-sparkline column="Product Variety"  width="100" height="30" class="size-full" ></h-sparkline>
        </article>
      </div>
    </div>
    <div class="br">
      <div class="conn"></div>
      <div class="nw">
        <article class="node">
          <p class="label">Buyer Count</p>
          <p class="value">{{ col_totals.`Buyer Count`.formatted }}</p>
          <h-sparkline column="Buyer Count"  width="100" height="30" class="size-full"></h-sparkline>
        </article>
      </div>
    </div>
  </div>
</div>
</div>

<!-- Purchase Price subtree -->
<div class="br">
<div class="conn"></div>
<div class="nw">
  <article class="node">
    <p class="label">Purchase Price</p>
    <p class="value">{{ col_totals.`Purchase Price`.formatted }}</p>
    <h-sparkline column="Purchase Price"  width="100" height="30" class="size-full" type="column"></h-sparkline>
  </article>
  <div class="stem"></div>
  <div class="br-row">
    <div class="br">
      <div class="conn"></div>
      <div class="nw">
        <article class="node">
          <p class="label">Order Item Price</p>
          <p class="value">{{ col_totals.`Order Item Price`.formatted }}</p>
          <h-sparkline column="Order Item Price"  width="100" height="30" class="size-full"></h-sparkline>
        </article>
      </div>
    </div>
    <div class="br">
      <div class="conn"></div>
      <div class="nw">
        <article class="node">
          <p class="label">Discount</p>
          <p class="value">{{ col_totals.`Discount`.formatted }}</p>
          <h-sparkline column="Discount"  width="100" height="30" class="size-full"></h-sparkline>
        </article>
      </div>
    </div>
  </div>
</div>
</div>

</div>
</div>
</div>

</div>
</div>
</div>

<!-- Commission (leaf) -->
<div class="br">
<div class="conn"></div>
<div class="nw">
<article class="node">
<p class="label">Commission</p>
<p class="value">{{ col_totals.`Commission`.formatted }}</p>
<h-sparkline column="Commission"  width="100" height="30" class="size-full"></h-sparkline>
</article>
</div>
</div>

</div>
</div>
